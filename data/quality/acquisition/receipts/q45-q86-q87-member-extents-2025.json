          "evidence_id": "mta_qbnr_q5_route_detail_2025#branch-transfer",
          "staged_block_id": "p001_b0056",
          "staged_text_surface": "normalized_text",
          "locator": "About the route",
          "raw_text": "The Q5 will provide all-day frequent service along Merrick Blvd between Jamaica and Laurelton. The route will no longer serve Green Acres Mall or Rosedale LIRR on weekdays. Weekday service to Green Acres Mall will be provided by the new Q87 and service to Rosedale LIRR will be provided by the new Q86 . On weekends, the Q5 will follow existing service patterns, terminating at Green Acres Mall during the day and at Rosedale LIRR overnight.",
          "raw_text_sha256": "sha256:9d3c50d27830e5e613dae22e24a47c64ae0932f978bf0e6a94eee268dc35e082"
        },
        {
          "evidence_id": "mta_qbnr_q5_route_detail_2025#existing-branch-patterns",
          "staged_block_id": "p001_b0099",
          "staged_text_surface": "normalized_text",
          "locator": "Frequency of service: Existing",
          "raw_text": "Existing frequencies reflect terminations in Laurelton on weekdays, Rosedale at all times, and at Green Acres Mall on weekends.",
          "raw_text_sha256": "sha256:9d6c6009f6942789ef432ad810ae119e2ddbe43149cee2c5d75f02b05fd17bef"
        },
        {
          "evidence_id": "mta_qbnr_q5_route_detail_2025#green-acres-endpoint",
