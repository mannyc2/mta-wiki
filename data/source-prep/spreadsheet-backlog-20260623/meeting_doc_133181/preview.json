        },
        {
          "row_number": 32,
          "cells": [
            {
              "ref": "A32",
              "column": "A",
              "row": 32,
              "style": "10",
              "text": ""
            },
            {
              "ref": "B32",
              "column": "B",
              "row": 32,
              "style": "2",
              "text": ""
            },
            {
              "ref": "C32",
              "column": "C",
              "row": 32,
              "style": "2",
