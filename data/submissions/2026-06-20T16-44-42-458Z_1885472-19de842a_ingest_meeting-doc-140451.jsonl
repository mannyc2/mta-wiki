{"submission_id":"sub_4537495cbe468c15","run_id":"2026-06-20T16-44-42-458Z_1885472-19de842a_ingest_meeting-doc-140451","submitted_at":"2026-06-20T18:06:37.253Z","tool_args_sha256":"sha256:4537495cbe468c159e50c4dd61ff7c6b2be640db87d4e453c6b2af234be2dd91","schema_version":2,"tool_args":{"source_id":"meeting_doc_140451","observation_kind":"claim","local_observation_id":"claim_overtime_variance_ytd2024","label":"Overtime Unfavorable Variance YTD April 2024","payload":{"claim_text":"NYCT and the LIRR were unfavorable by $117.0M and $8.9M, respectively, reflecting the continuation of drivers referenced for the month. MNR was unfavorable by $6.8M mainly due to scheduled service, vacancy/absentee coverage, and programmatic/routine maintenance.","subject":"Overtime Expense"},"evidence_refs":[{"source_id":"meeting_doc_140451","evidence_id":"meeting_doc_140451#p003_c0002","source_path":"raw/sources/meeting_doc_140451/blocks.jsonl","page_number":3,"block_id":"p003_c0002","text_sha256":"sha256:5501cc90b6207724b87824fcd90bb4424b9f55989e3a645bec471544850a77b6","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_06e45e7212b44ca4","run_id":"2026-06-20T16-44-42-458Z_1885472-19de842a_ingest_meeting-doc-140451","submitted_at":"2026-06-20T18:14:21.500Z","tool_args_sha256":"sha256:06e45e7212b44ca482de52ea10d361d324312bd6aa58afa791e896f910551450","schema_version":2,"tool_args":{"source_id":"meeting_doc_140451","observation_kind":"claim","local_observation_id":"claim_paratransit_variance_ytd2024","label":"Paratransit Unfavorable Variance YTD April 2024","payload":{"claim_text":"Unfavorable $29.1M at NYCT mainly due higher trip volume and support costs. This was mostly offset by higher paratransit reimbursement in Other Operating Revenue.","subject":"Paratransit Service Contracts"},"evidence_refs":[{"source_id":"meeting_doc_140451","evidence_id":"meeting_doc_140451#p004_c0002","source_path":"raw/sources/meeting_doc_140451/blocks.jsonl","page_number":4,"block_id":"p004_c0002","text_sha256":"sha256:a7c1b7a0c1c9f05b488a98b92fb4d99b54db89f1385729e21956bf47f549a9d3","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_f6f7342aaf9a3fb3","run_id":"2026-06-20T16-44-42-458Z_1885472-19de842a_ingest_meeting-doc-140451","submitted_at":"2026-06-20T18:14:50.914Z","tool_args_sha256":"sha256:f6f7342aaf9a3fb39ff51c1a7f5c9c0a292a45181b82e9bbd9a70f6b6bc34653","schema_version":2,"tool_args":{"source_id":"meeting_doc_140451","observation_kind":"claim","local_observation_id":"claim_payroll_variance_ytd2024","label":"Payroll Favorable Variance YTD April 2024","payload":{"claim_text":"NYCT, the LIRR, B&T, MTA Bus, and SIR were favorable by $64.1M, $12.3M, $6.6M, $6.6M, and $1.4M respectively, mainly due to vacancies. These results were partially offset by unfavorable variances of $14.2M at MNR.","subject":"Payroll Expense"},"evidence_refs":[{"source_id":"meeting_doc_140451","evidence_id":"meeting_doc_140451#p003_c0002","source_path":"raw/sources/meeting_doc_140451/blocks.jsonl","page_number":3,"block_id":"p003_c0002","text_sha256":"sha256:5501cc90b6207724b87824fcd90bb4424b9f55989e3a645bec471544850a77b6","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_bb953614fa1c612a","run_id":"2026-06-20T16-44-42-458Z_1885472-19de842a_ingest_meeting-doc-140451","submitted_at":"2026-06-20T18:15:18.746Z","tool_args_sha256":"sha256:bb953614fa1c612a0e88baacb8f45b3d21983cb8ba4a71dbbe71d554f0abddb1","schema_version":2,"tool_args":{"source_id":"meeting_doc_140451","observation_kind":"claim","local_observation_id":"claim_mnr_farebox_variance_apr2024","label":"MNR Farebox Favorable Variance April 2024","payload":{"claim_text":"MNR was favorable by $3.8M mainly due to higher ridership.","subject":"MNR Farebox Revenue"},"evidence_refs":[{"source_id":"meeting_doc_140451","evidence_id":"meeting_doc_140451#p003_c0002","source_path":"raw/sources/meeting_doc_140451/blocks.jsonl","page_number":3,"block_id":"p003_c0002","text_sha256":"sha256:5501cc90b6207724b87824fcd90bb4424b9f55989e3a645bec471544850a77b6","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_47ff89e21d01ffef","run_id":"2026-06-20T16-44-42-458Z_1885472-19de842a_ingest_meeting-doc-140451","submitted_at":"2026-06-20T18:15:46.342Z","tool_args_sha256":"sha256:47ff89e21d01ffefd10d9a9ab8dd501f9930181d610e657a0ce24422c189972a","schema_version":2,"tool_args":{"source_id":"meeting_doc_140451","observation_kind":"claim","local_observation_id":"claim_subsidies_variance_ytd2024","label":"Subsidies Unfavorable Variance YTD April 2024","payload":{"claim_text":"The unfavorable variance mainly reflected unfavorable Urban Tax of $56.3M, due to lower-than-expected commercial real estate transactions in NYC, PMT of $54.9M, partially due to timing of accruals, MRT of $49.0M, due to lower-than-expected mortgage activity, MTA Aid of $13.0M, and lower For-Hire Vehicle Surcharge of $7.8M.","subject":"Subsidies"},"evidence_refs":[{"source_id":"meeting_doc_140451","evidence_id":"meeting_doc_140451#p007_c0002","source_path":"raw/sources/meeting_doc_140451/blocks.jsonl","page_number":7,"block_id":"p007_c0002","text_sha256":"sha256:a97f222eb1b4cfad18a549ee49df21d59a5cd191c1dc72997b0651454b250e9c","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_f9beed0a63a41c70","run_id":"2026-06-20T16-44-42-458Z_1885472-19de842a_ingest_meeting-doc-140451","submitted_at":"2026-06-20T18:16:17.818Z","tool_args_sha256":"sha256:f9beed0a63a41c70b3f4030b80f54ff84252667353459622453e83c6bbc907c6","schema_version":2,"tool_args":{"source_id":"meeting_doc_140451","observation_kind":"claim","local_observation_id":"claim_professional_services_variance_ytd2024","label":"Professional Services Favorable Variance YTD April 2024","payload":{"claim_text":"MTA HQ was favorable by $36.0M, mainly due to a 2023 accounting adjustment. NYCT, MTA Bus, and MTAC&D were favorable by $4.1M, $4.0M, and $1.5M, respectively, due to the continuation of drivers referenced for the month, and B&T and GCMOC were favorable by $3.7M and $1.5M, respectively, due to timing.","subject":"Professional Services Contracts"},"evidence_refs":[{"source_id":"meeting_doc_140451","evidence_id":"meeting_doc_140451#p005_c0002","source_path":"raw/sources/meeting_doc_140451/blocks.jsonl","page_number":5,"block_id":"p005_c0002","text_sha256":"sha256:502078ceffb26bb66604c90674e4eecc565f49274abef35deb49f707c8f15f6d","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
