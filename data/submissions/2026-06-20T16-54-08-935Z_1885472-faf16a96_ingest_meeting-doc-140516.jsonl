{"submission_id":"sub_e7ecd8a4d9280186","run_id":"2026-06-20T16-54-08-935Z_1885472-faf16a96_ingest_meeting-doc-140516","submitted_at":"2026-06-20T17:40:10.593Z","tool_args_sha256":"sha256:e7ecd8a4d92801863c300365eea7111d337af7c7c983f94942320f70e2e90768","schema_version":2,"tool_args":{"source_id":"meeting_doc_140516","observation_kind":"project","local_observation_id":"project_meeting_doc_140516_uniTicket_discount","create_new":true,"label":"UniTicket Fare Discount Pilot","payload":{"project_name":"UniTicket Fare Discount Pilot","project_type":"fare pilot","status":"proposed","description":"Temporary fare pilot promotion for railroad customers for a discount up to 10% of the total combined fare of certain UniTicket products that connect riders in Orange and Rockland Counties with Metro-North Railroad service on the Harlem and Hudson Lines. Discounts on the connecting service portion range from 50%-90%. Available to customers who purchase a monthly ticket. Duration at least 12 months, may continue until next permanent fare change.","document_time_status":"planned","project_family":"fare_program"},"evidence_refs":[{"source_id":"meeting_doc_140516","evidence_id":"meeting_doc_140516#p001_c0007","source_path":"raw/sources/meeting_doc_140516/blocks.jsonl","page_number":1,"block_id":"p001_c0007","text_sha256":"sha256:2a70d8197ce1fd0be5b3ec2d8233ba3dc8e9e06ba8b9eedf29756faa8fb59bad","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_94a5134381c40d95","run_id":"2026-06-20T16-54-08-935Z_1885472-faf16a96_ingest_meeting-doc-140516","submitted_at":"2026-06-20T17:40:46.336Z","tool_args_sha256":"sha256:94a5134381c40d9508fa7ec0d210ab14a42ee38a8c485bb424ceecd5fa87919d","schema_version":2,"tool_args":{"source_id":"meeting_doc_140516","observation_kind":"project","local_observation_id":"project_meeting_doc_140516_summer_saturdays","create_new":true,"label":"Summer Saturdays Fare Pilot","payload":{"project_name":"Summer Saturdays","project_type":"fare pilot","status":"proposed","description":"Program on both Long Island Rail Road and Metro-North Railroad to promote weekend travel. Runs on Saturdays between July 6 and August 31, 2024. Allows monthly pass holders to travel to any destination on the railroad that issued their monthly pass, with up to two additional people, for $1 per person.","document_time_status":"planned","project_family":"fare_program"},"evidence_refs":[{"source_id":"meeting_doc_140516","evidence_id":"meeting_doc_140516#p002_c0004","source_path":"raw/sources/meeting_doc_140516/blocks.jsonl","page_number":2,"block_id":"p002_c0004","text_sha256":"sha256:6975178f85bc10835cffd864aeace21f67f3a62436c9ed3fb226d0fccaede625","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
