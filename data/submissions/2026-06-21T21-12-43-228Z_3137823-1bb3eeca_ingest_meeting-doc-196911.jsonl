{"submission_id":"sub_21e64a96349f010b","run_id":"2026-06-21T21-12-43-228Z_3137823-1bb3eeca_ingest_meeting-doc-196911","submitted_at":"2026-06-21T21:18:23.079Z","tool_args_sha256":"sha256:21e64a96349f010b2be8b1a6841dc86daa3c213af063fe7917fff0a3c0738b05","schema_version":2,"tool_args":{"source_id":"meeting_doc_196911","observation_kind":"event","local_observation_id":"event_signal_testing_feb14_16","label":"Signal testing February 14-16 (Presidents Day)","payload":{"event_kind":"signal testing","date_text":"February 14-16 (Including Presidents Day)","description":"Weekend signal testing at Queens Interlocking: two of four main tracks out of service. Bus service replaces train service between Stewart Manor and Hempstead. Westbound trains bypass stops at Hollis, Queens Village, and Elmont-UBS Arena. NYCT and NICE buses accommodate customers. No service at Bellerose Station or Country Life Press Station. Ronkonkoma service reduced to hourly in both directions.","event_family":"other","lifecycle_phase":"other","lifecycle_phase_other":"signal testing","date_text_normalized":{"raw_text":"February 14-16 (Including Presidents Day)","precision":"unknown","confidence":"unparsed"}},"evidence_refs":[{"source_id":"meeting_doc_196911","evidence_id":"meeting_doc_196911#p001_c0007","source_path":"raw/sources/meeting_doc_196911/blocks.jsonl","page_number":1,"block_id":"p001_c0007","text_sha256":"sha256:b1308043ef5926252dcbe84ea7ec69b768b01e4d53ee002cc2d6f64daff51242","text_source":"raw_text","source_quote":"On the weekends of February 7-8, February 14-16, and February 21-22"},{"source_id":"meeting_doc_196911","evidence_id":"meeting_doc_196911#p002_c0001","source_path":"raw/sources/meeting_doc_196911/blocks.jsonl","page_number":2,"block_id":"p002_c0001","text_sha256":"sha256:c8b7927d10e70bfebcce3b855cc0eed9cf059e0619dac8760edd35af1aa99e17","text_source":"raw_text","source_quote":"On February 14-16 (Including Presidents Day): With two of four main tracks out of service ... bus service 