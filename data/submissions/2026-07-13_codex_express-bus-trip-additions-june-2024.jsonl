{"submission_id":"sub_11ae118dc8b09c7c","run_id":"2026-07-13_codex_express-bus-trip-additions-june-2024","submitted_at":"2026-07-13T10:11:15.772Z","tool_args_sha256":"sha256:11ae118dc8b09c7c9dd897a616e02b40a241fd3f18bb9cbe629cec82882fdc61","schema_version":2,"tool_args":{"source_id":"meeting_doc_146846","observation_kind":"project","local_observation_id":"project_summer_2024_express_bus_service_additions","label":"Summer 2024 Express Bus Service Additions","raw_text":"Certain weekday trips were added to express bus routes BM2, BM5, SIM1C, SIM4C, SIM23 and SIM24 in summer 2024 in connection with the anticipated launch of Congestion Pricing. Following announcement of the pause in congestion pricing, Express Bus service on these routes would revert to their previous schedules until further notice.","payload":{"project_name":"Summer 2024 Express Bus Service Additions","project_type":"bus service change","status":"implemented","description":"Weekday peak-period trips added to BM2, BM5, SIM1C, SIM4C, SIM23, and SIM24 in summer 2024.","agency":"MTA New York City Transit","document_time_status":"implemented","project_family":"service_change","date_precision":"unknown"},"evidence_refs":[{"source_id":"meeting_doc_146846","evidence_id":"meeting_doc_146846#p001_c0005","source_path":"raw/sources/meeting_doc_146846/blocks.jsonl","page_number":1,"block_id":"p001_c0005","text_sha256":"sha256:d555d7d98db0b044c261c93f7957c834d15522b467a61ad7041ee9c3e71bf671","text_source":"raw_text","role":"implemented_project_status"}]},"validation":{"state":"accepted","issues":[],"warnings":["project.agency is relation context, not a closed enum or identity key. Agency names should link to entity records when supported. Suggested relation: implemented_by."]}}
