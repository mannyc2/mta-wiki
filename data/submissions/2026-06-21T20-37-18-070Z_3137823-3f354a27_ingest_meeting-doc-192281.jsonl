{"submission_id":"sub_c5b8dd77a675971c","run_id":"2026-06-21T20-37-18-070Z_3137823-3f354a27_ingest_meeting-doc-192281","submitted_at":"2026-06-21T20:44:54.763Z","tool_args_sha256":"sha256:c5b8dd77a675971c30c19178359097c6afecf21cf80a9c558da3c744febf55e2","schema_version":2,"tool_args":{"source_id":"meeting_doc_192281","observation_kind":"claim","local_observation_id":"claim_meeting_doc_192281_crz_net_revenues_lockbox","label":"CRZ Net Revenues deposited into MTA capital lockbox fund","payload":{"claim_text":"CRZ Net Revenues are deposited into the MTA capital lockbox fund and are permitted to be pledged by TBTA to secure and be applied to the payment of bonds, notes or other obligations of TBTA issued to finance: (i) costs of the CRZ Tolling Program, (ii) $15 billion in MTA transit and commuter rail capital projects included in the 2020-2024 MTA capital plan, and (iii) the excess, if any, for successor capital plans.","subject":"CRZ Net Revenues"},"evidence_refs":[{"source_id":"meeting_doc_192281","evidence_id":"meeting_doc_192281#p002_c0010","source_path":"raw/sources/meeting_doc_192281/blocks.jsonl","page_number":2,"block_id":"p002_c0010","text_sha256":"sha256:cb4a084a822ade097ac93279c92f0389d9a86daf09c20b6a2c1f98cadca45dc1","text_source":"raw_text","source_quote":"the tolls, fees and other charges generated under the CRZ Tolling Program (the \"CRZ Net Revenues\") are deposited into the MTA capital lockbox fund"}]},"validation":{"state":"accepted","issues":[]}}
