{"submission_id":"sub_4ca5fc0b5be7aae8","run_id":"2026-06-21T22-10-53-761Z_3137823-c7c5f2cd_ingest_meeting-doc-201731","submitted_at":"2026-06-21T22:20:06.480Z","tool_args_sha256":"sha256:4ca5fc0b5be7aae838501fb842018efe0c72f00c130f3384120623ab92168537","schema_version":2,"tool_args":{"source_id":"meeting_doc_201731","observation_kind":"claim","local_observation_id":"claim_real_property_disposition_guidelines_2026","label":"Real Property Disposition Guidelines","payload":{"claim_text":"Board approval of above guidelines as required annually by Public Authorities Law Sections 2895-2897. MTA Real Estate and MTA Corporate Compliance should be prepared to answer questions regarding these guidelines.","subject":"All-Agency Real Property Disposition Guidelines and All-Agency Personal Property Disposition Guidelines","description":"Annual Board approval of property disposition guidelines required by Public Authorities Law Sections 2895-2897."},"evidence_refs":[{"source_id":"meeting_doc_201731","evidence_id":"meeting_doc_201731#p001_c0003","source_path":"raw/sources/meeting_doc_201731/blocks.jsonl","page_number":1,"block_id":"p001_c0003","text_sha256":"sha256:5ef03a0aad882f948d039c32d656afc73fc582cee770a169cd0be6389ccc5c1a","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_6e0a3803bb6b7aa1","run_id":"2026-06-21T22-10-53-761Z_3137823-c7c5f2cd_ingest_meeting-doc-201731","submitted_at":"2026-06-21T22:20:19.175Z","tool_args_sha256":"sha256:6e0a3803bb6b7aa101f064f70d6da695f191223ff01fc50d803fc568b758a497","schema_version":2,"tool_args":{"source_id":"meeting_doc_201731","observation_kind":"claim","local_observation_id":"claim_mta_real_estate_disposition_guidelines_2026","label":"Real Estate Disposition Guidelines Approval","payload":{"claim_text":"To obtain MTA Board approval of (i) revised and updated MTA Real Estate Department's Real Property Disposition Guidelines (the '20256 Real Property Disposition Guidelines') and (ii) updated MTA's All-Agency Guidelines for the Disposal of Personal Property (the '20256 Personal Property Disposition Guidelines'), and the appointment of the MTA staff persons designated as the Personal Property Disposition Contracting Officers listed on Attachment C, each promulgated in accordance with Section 2895-2897 of the Public Authorities Law.","subject":"MTA Real Estate Department","description":"Board approval of revised Real Property Disposition Guidelines (20256) and Personal Property Disposition Guidelines (20256), and appointment of Personal Property Disposition Contracting Officers."},"evidence_refs":[{"source_id":"meeting_doc_201731","evidence_id":"meeting_doc_201731#p001_c0003","source_path":"raw/sources/meeting_doc_201731/blocks.jsonl","page_number":1,"block_id":"p001_c0003","text_sha256":"sha256:5ef03a0aad882f948d039c32d656afc73fc582cee770a169cd0be6389ccc5c1a","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_6194d476284672ba","run_id":"2026-06-21T22-10-53-761Z_3137823-c7c5f2cd_ingest_meeting-doc-201731","submitted_at":"2026-06-21T22:20:28.801Z","tool_args_sha256":"sha256:6194d476284672bac4284bbf68fe3398892ad1fef9ba73be1176d1033098a37b","schema_version":2,"tool_args":{"source_id":"meeting_doc_201731","observation_kind":"claim","local_observation_id":"claim_real_estate_licensing_out_policy_2026","label":"All-Agency Real Estate Licensing-Out Policy","payload":{"claim_text":"This All-Agency Real Estate Licensing-Out Policy seeks to create a single consolidated policy for the licensing-out to third parties of MTA Agency Property, to replace the Existing Licensing-Out Policies in order to provide for a more streamlined framework for MTA Real Estate and MTA Agencies to efficiently and productively enter into license agreements with third parties for MTA Agency Property on a short term and revocable basis.","subject":"All-Agency Real Estate Licensing-Out Policy","description":"Consolidation and amendment of MTA Real Estate policies governing the licensing of MTA agency properties to tenants."},"evidence_refs":[{"source_id":"meeting_doc_201731","evidence_id":"meeting_doc_201731#p001_c0003","source_path":"raw/sources/meeting_doc_201731/blocks.jsonl","page_number":1,"block_id":"p001_c0003","text_sha256":"sha256:5ef03a0aad882f948d039c32d656afc73fc582cee770a169cd0be6389ccc5c1a","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_a1a9065349f54cfc","run_id":"2026-06-21T22-10-53-761Z_3137823-c7c5f2cd_ingest_meeting-doc-201731","submitted_at":"2026-06-21T22:20:38.030Z","tool_args_sha256":"sha256:a1a9065349f54cfce242f1a7e9a59853afb478cb741d24bcd80b032546314602","schema_version":2,"tool_args":{"source_id":"meeting_doc_201731","observation_kind":"claim","local_observation_id":"claim_construction_access_policy_restatement_2026","label":"Construction Access Agreements Policy Restatement","payload":{"claim_text":"The existing policy for construction access agreements, adopted November 15, 1999 and amended on November 12, 2013 and June 23, 2021, allows MTA Real Estate to negotiate, acquire or grant third parties access rights and privileges required by MTA Agencies for capital projects or maintenance or repairs of operating facilities. These access rights are typically for the duration of the project and subject to a $10,000 per month limit.","subject":"MTA Real Estate licensing-in policy governing construction access agreements","description":"Restatement of MTA Real Estate licensing-in policy for construction access agreements, modified to remove authorization for MTA Real Estate to grant third parties and limited to acquisition of rights."},"evidence_refs":[{"source_id":"meeting_doc_201731","evidence_id":"meeting_doc_201731#p001_c0003","source_path":"raw/sources/meeting_doc_201731/blocks.jsonl","page_number":1,"block_id":"p001_c0003","text_sha256":"sha256:5ef03a0aad882f948d039c32d656afc73fc582cee770a169cd0be6389ccc5c1a","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
