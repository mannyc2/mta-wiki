{"submission_id":"sub_367a02f8f7f1bbc0","run_id":"2026-06-21T23-25-00-914Z_3137823-cea5414c_ingest_meeting-doc-42411","submitted_at":"2026-06-21T23:34:27.201Z","tool_args_sha256":"sha256:367a02f8f7f1bbc05df8251f3715c5e1ef4c6727a1735304fab3076fac424476","schema_version":2,"tool_args":{"source_id":"meeting_doc_42411","observation_kind":"project","local_observation_id":"project_electric_bus_procurement_60_2021","create_new":true,"label":"Electric Bus Procurement Increase 2021","raw_text":"President of MTA Construction & Development, Janno Lieber, and President of MTA Bus, Craig Cipriano recently announced plans to increase the next electric bus procurement this year from 45 to 60 – a 33% increase.","payload":{"project_name":"Electric Bus Procurement Increase 2021","project_type":"bus procurement","status":"announced","description":"Increase 2021 procurement of local all-electric buses from 45 to 60 (33% increase). Includes $39 million agreement with NYPA to install more than 50 overhead chargers at four MTA bus depots. First buses expected in late 2022.","document_time_status":"other","project_family":"other"},"evidence_refs":[{"source_id":"meeting_doc_42411","evidence_id":"meeting_doc_42411#p041_c0005","source_path":"raw/sources/meeting_doc_42411/blocks.jsonl","page_number":41,"block_id":"p041_c0005","text_sha256":"sha256:15e52e2e7cfc13d6950e3c9cc434a84eea2ce69fa00d2f1478ccf579803a082b","text_source":"raw_text"},{"source_id":"meeting_doc_42411","evidence_id":"meeting_doc_42411#p042_c0003","source_path":"raw/sources/meeting_doc_42411/blocks.jsonl","page_number":42,"block_id":"p042_c0003","text_sha256":"sha256:8f4819ad844d8f11d3ce907cd3659a39c7459de5669db4e7aacefda396be0265","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_a9a5eb093db1585e","run_id":"2026-06-21T23-25-00-914Z_3137823-cea5414c_ingest_meeting-doc-42411","submitted_at":"2026-06-21T23:34:35.847Z","tool_args_sha256":"sha256:a9a5eb093db1585e204acd1f91be0e7b455e3c8712c229b778ff1f54d4a0d7ff","schema_version":2,"tool_args":{"source_id":"meeting_doc_42411","observation_kind":"project","local_observation_id":"project_bdnqr_schedule_adjustments_fall2021","create_new":true,"label":"B D N Q R Weekday Evening Schedule Adjustments Fall 2021","raw_text":"NYC Transit is proposing to adjust B, D, N, Q and R schedules weekday evenings in fall 2021 to accommodate work train movements needed to facilitate ongoing and upcoming capital investments and maintenance work around the system.","payload":{"project_name":"B D N Q R Weekday Evening Schedule Adjustments","project_type":"schedule change","status":"proposed","description":"Proposal to adjust B, D, N, Q and R schedules weekday evenings in fall 2021 to accommodate work train movements for capital investments and maintenance work. D and N Manhattan-bound trains rerouted via 4th Avenue local track. Cost approximately $0.6 million annually.","routes_served":["B","D","N","Q","R"],"document_time_status":"planned","project_family":"other"},"evidence_refs":[{"source_id":"meeting_doc_42411","evidence_id":"meeting_doc_42411#p163_c0005","source_path":"raw/sources/meeting_doc_42411/blocks.jsonl","page_number":163,"block_id":"p163_c0005","text_sha256":"sha256:62f1da4e8a12a731973077ed92b8105dd9d75442f33bc64924b5de046251fa25","text_source":"raw_text"},{"source_id":"meeting_doc_42411","evidence_id":"meeting_doc_42411#p165_c0005","source_path":"raw/sources/meeting_doc_42411/blocks.jsonl","page_number":165,"block_id":"p165_c0005","text_sha256":"sha256:d0596377ae5f93dfdd775f4899f59c46d9f04a9551f2f7d474f62f300fa3bae6","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[],"warnings":["project.routes_served is relation context, not a closed enum or identity key. Route lists should become project-route relations when supported. Suggested relation: serves_route."]}}
