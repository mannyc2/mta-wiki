{"submission_id":"sub_f66968e7411ab654","run_id":"2026-06-22T20-45-01-128Z_336399-87ea922f_ingest_meeting-doc-85491","submitted_at":"2026-06-22T20:59:45.352Z","tool_args_sha256":"sha256:f66968e7411ab654f3793a396a1365dbba3f33066cbbe11ea9fc80296024fc95","schema_version":2,"tool_args":{"source_id":"meeting_doc_85491","observation_kind":"claim","local_observation_id":"claim_farebox_recovery_context_85491","label":"MTA Costs Not Recovered From Farebox","raw_text":"Approximately 20% (and sometimes more) of MTA costs are not recovered in the current year from farebox revenues, other operating revenues or subsidies.","payload":{"claim_text":"Approximately 20% (and sometimes more) of MTA costs are not recovered in the current year from farebox revenues, other operating revenues or subsidies.","data_type":"context","subject":"MTA","data_type_normalized":{"raw_text":"context","normalized_value":"context"}},"evidence_refs":[{"source_id":"meeting_doc_85491","evidence_id":"meeting_doc_85491#p001_c0006","source_path":"raw/sources/meeting_doc_85491/blocks.jsonl","page_number":1,"block_id":"p001_c0006","text_sha256":"sha256:8348be297ad32f8f08e9581190ea90e56bd4f301db3ef652922cf30e9f14c325","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_d624048f9f3668ff","run_id":"2026-06-22T20-45-01-128Z_336399-87ea922f_ingest_meeting-doc-85491","submitted_at":"2026-06-22T20:59:57.067Z","tool_args_sha256":"sha256:d624048f9f3668ff2c352f222fc9a1dffe84fe4cd7b7b97bb4ce7f27a1881bd0","schema_version":2,"tool_args":{"source_id":"meeting_doc_85491","observation_kind":"claim","local_observation_id":"claim_farebox_operating_def_85491","label":"Farebox Operating Ratio Definition","raw_text":"Farebox operating ratio focuses on Agency operating financial performance. It reflects the way MTA meets its statutory and bond-covenant budget-balancing requirements, and it excludes certain costs that are not subject to Agency control, but are provided centrally by the MTA.","payload":{"claim_text":"Farebox operating ratio focuses on Agency operating financial performance. It reflects the way MTA meets its statutory and bond-covenant budget-balancing requirements, and it excludes certain costs that are not subject to Agency control, but are provided centrally by the MTA.","data_type":"definition","subject":"farebox operating ratio","data_type_normalized":{"raw_text":"definition","normalized_value":"definition"}},"evidence_refs":[{"source_id":"meeting_doc_85491","evidence_id":"meeting_doc_85491#p001_c0007","source_path":"raw/sources/meeting_doc_85491/blocks.jsonl","page_number":1,"block_id":"p001_c0007","text_sha256":"sha256:0802d493aa9779f5b6afe68a09c5e3cc6e9ffb1ef72abde8b89a3a69a1bf1d74","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_ceff43758685772d","run_id":"2026-06-22T20-45-01-128Z_336399-87ea922f_ingest_meeting-doc-85491","submitted_at":"2026-06-22T21:00:12.231Z","tool_args_sha256":"sha256:ceff43758685772dfbefdd73953fa2a7e225a6d9cae6e5b065f3d0d9f7d7c18f","schema_version":2,"tool_args":{"source_id":"meeting_doc_85491","observation_kind":"claim","local_observation_id":"claim_lirr_mnr_methodology_85491","label":"Revised LIRR/MNR Ratio Methodology Note","raw_text":"In the agenda materials for the Meeting of the Metro-North and Long Island Committees, the calculations of the farebox operating and recovery ratios for the LIRR and MNR use a revised methodology to put the railroads on a more comparable basis. Those statistics, which are included in the respective financial and ridership reports of both Agencies, differ from the statistics presented in this table.","payload":{"claim_text":"In the agenda materials for the Meeting of the Metro-North and Long Island Committees, the calculations of the farebox operating and recovery ratios for the LIRR and MNR use a revised methodology to put the railroads on a more comparable basis. Those statistics, which are included in the respective financial and ridership reports of both Agencies, differ from the statistics presented in this table.","data_type":"methodology_note","subject":"LIRR and MNR farebox ratios","data_type_normalized":{"raw_text":"methodology_note","normalized_value":"methodology_note"}},"evidence_refs":[{"source_id":"meeting_doc_85491","evidence_id":"meeting_doc_85491#p001_c0008","source_path":"raw/sources/meeting_doc_85491/blocks.jsonl","page_number":1,"block_id":"p001_c0008","text_sha256":"sha256:a62f072a39810b5f67c90297a4742b430b2e103ab2bb848c67dd4fad0373b111","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
