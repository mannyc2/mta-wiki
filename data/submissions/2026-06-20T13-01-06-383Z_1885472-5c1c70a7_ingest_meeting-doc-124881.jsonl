{"submission_id":"sub_f782b94ed87ff2ef","run_id":"2026-06-20T13-01-06-383Z_1885472-5c1c70a7_ingest_meeting-doc-124881","submitted_at":"2026-06-20T14:06:46.730Z","tool_args_sha256":"sha256:f782b94ed87ff2ef826770a1722094214d05504554cf171f6bf06d24ff1746ee","schema_version":2,"tool_args":{"source_id":"meeting_doc_124881","observation_kind":"claim","local_observation_id":"claim_mdoc124881_fare_increase_aug2023","label":"August 2023 fare increase","payload":{"claim_text":"On August 20, 2023, fare increases went into effect across MTA subways, buses, and commuter railroads. With additional funding from New York State, the MTA was able to keep the fare increase to 4%. This was the first fare increase since 2019 and the first increase in the base subway and bus fare since 2015."},"evidence_refs":[{"source_id":"meeting_doc_124881","evidence_id":"meeting_doc_124881#p102_c0009","source_path":"raw/sources/meeting_doc_124881/blocks.jsonl","page_number":102,"block_id":"p102_c0009","text_sha256":"sha256:288d448e21be1ca7b11cf8acbb8a296aacd47b2291ec7f1868f4ad8394c9e7bb","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_e8b6a6a7c5d57781","run_id":"2026-06-20T13-01-06-383Z_1885472-5c1c70a7_ingest_meeting-doc-124881","submitted_at":"2026-06-20T14:07:14.160Z","tool_args_sha256":"sha256:e8b6a6a7c5d577816d77895db9db987e75b66098e0617276b32aebac633934bc","schema_version":2,"tool_args":{"source_id":"meeting_doc_124881","observation_kind":"claim","local_observation_id":"claim_mdoc124881_cbdtp","label":"Central Business District Tolling Program update","payload":{"claim_text":"The Central Business District Tolling Program (CBDTP) was authorized by the MTA Reform and Traffic Mobility Act and enacted in April 2019. On June 27, 2023, the Federal Highway Administration (FHWA) issued a Finding of No Significant Impact. The Traffic Mobility Review Board (TMRB) held its first meeting on July 19, 2023. Contractors have up to 310 days from the federal approval to complete the design, development, testing, and installation of the tolling system and equipment."},"evidence_refs":[{"source_id":"meeting_doc_124881","evidence_id":"meeting_doc_124881#p011_c0009","source_path":"raw/sources/meeting_doc_124881/blocks.jsonl","page_number":11,"block_id":"p011_c0009","text_sha256":"sha256:c6eda2043837eec1fa744bf520c14b6d886375a4d2f6bf798390b0843857a5c1","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_0c504d47c3b1f483","run_id":"2026-06-20T13-01-06-383Z_1885472-5c1c70a7_ingest_meeting-doc-124881","submitted_at":"2026-06-20T14:07:37.972Z","tool_args_sha256":"sha256:0c504d47c3b1f483d3c4d216321e758a5c5bd6ed35cf944197bc108e876c6411","schema_version":2,"tool_args":{"source_id":"meeting_doc_124881","observation_kind":"claim","local_observation_id":"claim_mdoc124881_mta_bus_employees","label":"MTA Bus Company employee count","payload":{"claim_text":"As of June 30, 2022, MTA Bus Company has 3,782 employees, approximately 3,665 of whom are represented by three different unions (now including the United Transit Leadership Organization) and five bargaining units."},"evidence_refs":[{"source_id":"meeting_doc_124881","evidence_id":"meeting_doc_124881#p018_c0007","source_path":"raw/sources/meeting_doc_124881/blocks.jsonl","page_number":18,"block_id":"p018_c0007","text_sha256":"sha256:a96b0abba0241a43bd814de30d4db446ea10f3200191f4d12b76110cafec94d6","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_bb373c1302771696","run_id":"2026-06-20T13-01-06-383Z_1885472-5c1c70a7_ingest_meeting-doc-124881","submitted_at":"2026-06-20T14:08:04.923Z","tool_args_sha256":"sha256:bb373c13027716967404d539c4a03785f3c06ff6784ea855b46259d737ded2bc","schema_version":2,"tool_args":{"source_id":"meeting_doc_124881","observation_kind":"claim","local_observation_id":"claim_mdoc124881_grand_central_madison","label":"Grand Central Madison terminal opening","payload":{"claim_text":"In January of 2023, the Grand Central Madison terminal was opened for LIRR service. Service was initially run as a shuttle between Jamaica and Grand Central Madison terminals. Full LIRR service to Grand Central Madison began in February, resulting in a 41% increase in overall LIRR service."},"evidence_refs":[{"source_id":"meeting_doc_124881","evidence_id":"meeting_doc_124881#p016_c0014","source_path":"raw/sources/meeting_doc_124881/blocks.jsonl","page_number":16,"block_id":"p016_c0014","text_sha256":"sha256:211bafd32a80b03abab5a7405dd1000cc3d215891463d6d2c0b61773d5f9a441","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
