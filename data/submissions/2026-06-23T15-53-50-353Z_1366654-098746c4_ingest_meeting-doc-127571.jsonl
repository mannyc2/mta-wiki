{"submission_id":"sub_8d906c2434327461","run_id":"2026-06-23T15-53-50-353Z_1366654-098746c4_ingest_meeting-doc-127571","submitted_at":"2026-06-23T16:05:30.885Z","tool_args_sha256":"sha256:8d906c24343274616019182d6e412242cebc55ead6149eba97b413839fe6cb8d","schema_version":2,"tool_args":{"source_id":"meeting_doc_127571","observation_kind":"claim","local_observation_id":"claim_farebox_recovery_ratio_definition","payload":{"claim_text":"Farebox recovery ratio has a long-term focus. It includes costs that are not funded in the current year, except in an accounting-ledger sense, but are, in effect, passed on to future years. Those costs include depreciation and interest on long-term debt. Approximately 20% (and sometimes more) of MTA costs are not recovered in the current year from farebox revenues, other operating revenues or subsidies. In addition, the recovery ratio allocates centralized MTA services to the Agencies, such as Security, the costs of the Inspector General, Civil Rights, Audit, Risk Management, Legal and Shared Services.","subject":"Farebox recovery ratio","data_type":"definition","data_type_normalized":{"raw_text":"definition","normalized_value":"definition"}},"evidence_refs":[{"source_id":"meeting_doc_127571","evidence_id":"meeting_doc_127571#p001_b0031","source_path":"raw/sources/meeting_doc_127571/blocks.jsonl","page_number":1,"block_id":"p001_b0031","text_sha256":"sha256:3feb1977b3ad44c0f52c744adf2ec5f5cf28ddea34662630ea90a4a16a9feb6f","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_46b83655345084dd","run_id":"2026-06-23T15-53-50-353Z_1366654-098746c4_ingest_meeting-doc-127571","submitted_at":"2026-06-23T16:05:36.698Z","tool_args_sha256":"sha256:46b83655345084dd9c2857ec7e6df83a7c86ace497f4d9dd40db9bfde8264aae","schema_version":2,"tool_args":{"source_id":"meeting_doc_127571","observation_kind":"claim","local_observation_id":"claim_farebox_operating_ratio_definition","payload":{"claim_text":"Farebox operating ratio focuses on Agency operating financial performance. It reflects the way MTA meets its statutory and bond-covenant budget-balancing requirements, and it excludes certain costs that are not subject to Agency control, but are provided centrally by the MTA.","subject":"Farebox operating ratio","data_type":"definition","data_type_normalized":{"raw_text":"definition","normalized_value":"definition"}},"evidence_refs":[{"source_id":"meeting_doc_127571","evidence_id":"meeting_doc_127571#p001_b0032","source_path":"raw/sources/meeting_doc_127571/blocks.jsonl","page_number":1,"block_id":"p001_b0032","text_sha256":"sha256:c3cb0d784594cbd7bdd9cdd48f107e434fd30437c4c88090873267ccb317e0af","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_dc6d889e80a8df58","run_id":"2026-06-23T15-53-50-353Z_1366654-098746c4_ingest_meeting-doc-127571","submitted_at":"2026-06-23T16:05:45.948Z","tool_args_sha256":"sha256:dc6d889e80a8df58c73d8e360d411e8798d8671c2e35dcf69e9091bc673ffa54","schema_version":2,"tool_args":{"source_id":"meeting_doc_127571","observation_kind":"claim","local_observation_id":"claim_lirr_mnr_revised_methodology","payload":{"claim_text":"In the agenda materials for the Meeting of the Metro-North and Long Island Rail Road Committees, the calculations of the farebox operating and recovery ratios for the LIRR and MNR use a revised methodology to put the railroads on a more comparable basis. Those statistics, which are included in the respective financial and ridership reports of both Agencies, differ from the statistics presented in this table.","subject":"LIRR/MNR farebox ratios revised methodology","data_type":"note","routes":["LIRR","MNR"],"data_type_normalized":{"raw_text":"note","normalized_value":"note"}},"evidence_refs":[{"source_id":"meeting_doc_127571","evidence_id":"meeting_doc_127571#p001_b0033","source_path":"raw/sources/meeting_doc_127571/blocks.jsonl","page_number":1,"block_id":"p001_b0033","text_sha256":"sha256:2edb36e48162301712ad8a286b54957443663b6cc0df8d076bf2641398124119","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[],"warnings":["claim.routes is relation context, not a closed enum or identity key. Route arrays should link to route records when supported. Suggested relation: route has_claim claim when the route endpoint resolves exactly."]}}
