{"submission_id":"sub_59bf80420c105697","run_id":"2026-06-23T16-01-43-624Z_1373642-44a917b7_ingest_meeting-doc-154866","submitted_at":"2026-06-23T16:14:42.875Z","tool_args_sha256":"sha256:59bf80420c1056971a3ef7eeb331552f192373aa8105d72425ca7db7974d949c","schema_version":2,"tool_args":{"source_id":"meeting_doc_154866","observation_kind":"claim","local_observation_id":"claim_farebox_recovery_ratio_definition","label":"Farebox Recovery Ratio Definition","payload":{"claim_text":"Farebox recovery ratio has a long-term focus. It includes costs that are not funded in the current year, except in an accounting-ledger sense, but are, in effect, passed on to future years; those costs include depreciation and interest on long-term debt. In addition, the recovery ratio allocates centralized MTA services to the Agencies, such as Security, the costs of the Inspector General, Civil Rights, Audit, Risk Management, Legal and Shared Services.","subject":"Farebox Recovery Ratio"},"evidence_refs":[{"source_id":"meeting_doc_154866","evidence_id":"meeting_doc_154866#p001_b0031","source_path":"raw/sources/meeting_doc_154866/blocks.jsonl","page_number":1,"block_id":"p001_b0031","text_sha256":"sha256:c5ee33600b07c4d09f0281de78293a8b7dd94e4a98068f055b327892136dd924","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_984090700e69f0a3","run_id":"2026-06-23T16-01-43-624Z_1373642-44a917b7_ingest_meeting-doc-154866","submitted_at":"2026-06-23T16:14:51.335Z","tool_args_sha256":"sha256:984090700e69f0a3ef16bcc167f13cb71c799b67716899979a8f10595f08dbfc","schema_version":2,"tool_args":{"source_id":"meeting_doc_154866","observation_kind":"claim","local_observation_id":"claim_farebox_operating_ratio_definition","label":"Farebox Operating Ratio Definition","payload":{"claim_text":"Farebox operating ratio focuses on Agency operating financial performance. It reflects the way MTA meets its statutory and bond-covenant budget-balancing requirements, and it excludes certain costs that are not subject to Agency control, but are provided centrally by the MTA.","subject":"Farebox Operating Ratio"},"evidence_refs":[{"source_id":"meeting_doc_154866","evidence_id":"meeting_doc_154866#p001_b0032","source_path":"raw/sources/meeting_doc_154866/blocks.jsonl","page_number":1,"block_id":"p001_b0032","text_sha256":"sha256:a0eb5fb38a411feee5505d67036384ab4c9af20e1d1f4f58cd63505846a7d1f7","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_7136d67f3b1b0837","run_id":"2026-06-23T16-01-43-624Z_1373642-44a917b7_ingest_meeting-doc-154866","submitted_at":"2026-06-23T16:15:00.428Z","tool_args_sha256":"sha256:7136d67f3b1b0837dc3ca531adb0b89f01aea9b199fc2c7db3dbb7ade3a7382e","schema_version":2,"tool_args":{"source_id":"meeting_doc_154866","observation_kind":"claim","local_observation_id":"claim_lirr_mnr_revised_methodology","label":"LIRR/MNR Revised Methodology Note","payload":{"claim_text":"The calculations of the farebox operating and recovery ratios for the LIRR and MNR use a revised methodology to put the railroads on a more comparable basis. Those statistics differ from the statistics presented in this table.","subject":"LIRR/MNR farebox methodology"},"evidence_refs":[{"source_id":"meeting_doc_154866","evidence_id":"meeting_doc_154866#p001_b0033","source_path":"raw/sources/meeting_doc_154866/blocks.jsonl","page_number":1,"block_id":"p001_b0033","text_sha256":"sha256:88ba94dc32bdd8238a1e2cdc5ed10f9194b13a62ca2837bd36d63586e02c6490","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
