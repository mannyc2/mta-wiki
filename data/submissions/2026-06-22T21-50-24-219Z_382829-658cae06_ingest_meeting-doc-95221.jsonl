{"submission_id":"sub_788e75e373c5eecb","run_id":"2026-06-22T21-50-24-219Z_382829-658cae06_ingest_meeting-doc-95221","submitted_at":"2026-06-22T21:59:45.751Z","tool_args_sha256":"sha256:788e75e373c5eecb58c5468a13dac7cacb4d13790421642bd690338ca47692ff","schema_version":2,"tool_args":{"source_id":"meeting_doc_95221","observation_kind":"project","local_observation_id":"project_meeting_doc_95221_third_track","target_record_id":"project_lirr-third-track-meeting-doc-104741","label":"LIRR Main Line Third Track","raw_text":"The new stretch of third track on the LIRR Main Line has already improved service for Long Island commuters. LIRR began service on the first section of the Main Line's new third track, serving New Hyde Park and Merillon Avenue, on August 15. The second section, serving Mineola, opened on Tuesday, August 30, and a third and final section of the third track will open this fall.","payload":{"project_name":"LIRR Main Line Third Track","status":"in progress","description":"Third track project on LIRR Main Line between Floral Park and Hicksville. $2.6 billion project including grade crossing eliminations, bridge replacements, new sound attenuation and retaining walls, and enhanced stations","agency":"MTA Construction & Development","operator":"Long Island Rail Road","document_time_status":"other"},"evidence_refs":[{"source_id":"meeting_doc_95221","evidence_id":"meeting_doc_95221#p004_c0009","source_path":"raw/sources/meeting_doc_95221/blocks.jsonl","page_number":4,"block_id":"p004_c0009","text_sha256":"sha256:139256b03c86c12abe76d19283e42173a286ca578d2554e386caa5df6c1ca4ff","text_source":"raw_text"},{"source_id":"meeting_doc_95221","evidence_id":"meeting_doc_95221#p024_c0003","source_path":"raw/sources/meeting_doc_95221/blocks.jsonl","page_number":24,"block_id":"p024_c0003","text_sha256":"sha256:4d5ba68fd85ac1de68460597dded6360ab8af5ee03a9b9cf74f074e1ef223eaa","text_source":"raw_text"},{"source_id":"meeting_doc_95221","evidence_id":"meeting_doc_95221#p025_c000