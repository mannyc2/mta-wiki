{"submission_id":"sub_178993217b55b0f1","run_id":"2026-06-22T21-50-24-219Z_382829-658cae06_ingest_meeting-doc-95221","submitted_at":"2026-06-22T21:59:59.306Z","tool_args_sha256":"sha256:178993217b55b0f125ef741f81ab21b8678741ba4c706a87e65c70e41d01c97a","schema_version":2,"tool_args":{"source_id":"meeting_doc_95221","observation_kind":"project","local_observation_id":"project_meeting_doc_95221_harlem_river_lift_bridge","create_new":true,"label":"Harlem River Lift Bridge Rehabilitation","raw_text":"In August, Metro-North completed rehabilitation of the Harlem River Lift Bridge (HRLB), Metro-North Railroad's longest span bridge east of the Hudson River and the only vertical lift span bridge operated by the railroad.","payload":{"project_name":"Harlem River Lift Bridge Rehabilitation","project_type":"infrastructure rehabilitation","status":"completed","description":"Rehabilitation of the HRLB including waterside protection, pier rehabilitation, seismic retrofit, safety improvements, fender system replacement, navigation lights, and various other repairs","agency":"Metro-North Railroad","borough":"Bronx","document_time_status":"implemented","project_family":"capital_or_infrastructure","borough_normalized":"bronx"},"evidence_refs":[{"source_id":"meeting_doc_95221","evidence_id":"meeting_doc_95221#p014_c0004","source_path":"raw/sources/meeting_doc_95221/blocks.jsonl","page_number":14,"block_id":"p014_c0004","text_sha256":"sha256:688c7e09071e687eb00f161c4fa5e9d70c06261ac406c071b7b112f8906dfaff","text_source":"raw_text"},{"source_id":"meeting_doc_95221","evidence_id":"meeting_doc_95221#p014_c0005","source_path":"raw/sources/meeting_doc_95221/blocks.jsonl","page_number":14,"block_id":"p014_c0005","text_sha256":"sha256:914a8dd9998f5072e420b997f07865d055ebb01d1a723a57e2307b577df559bc","text_source":"raw_text"},{"source_id":"meeting_doc_95221","evidence_id":"meeting_doc_95221#p014_c0006","source_path":"raw/sources/meeting_doc_95221/blocks.jsonl","page_number":14,"block_id":"p014_