{"submission_id":"sub_25642ed212f68648","run_id":"2026-06-22T21-50-24-219Z_382829-658cae06_ingest_meeting-doc-95221","submitted_at":"2026-06-22T22:00:38.149Z","tool_args_sha256":"sha256:25642ed212f68648c5d552f906f0083cde0e8942ce19014549f163cc97dc1015","schema_version":2,"tool_args":{"source_id":"meeting_doc_95221","observation_kind":"project","local_observation_id":"project_meeting_doc_95221_train_time_app","create_new":true,"label":"TrainTime App","raw_text":"In August, the MTA launched the new TrainTime app, a single app for both LIRR and Metro-North. TrainTime replaces the previously separate scheduling and ticketing apps for each railroad.","payload":{"project_name":"TrainTime App","project_type":"digital service launch","status":"launched","description":"A new one-stop app for commuter rail customers to purchase tickets, plan trips, and get real-time train location data, combining both LIRR and Metro-North scheduling and ticketing","document_time_status":"other","project_family":"other"},"evidence_refs":[{"source_id":"meeting_doc_95221","evidence_id":"meeting_doc_95221#p002_c0001","source_path":"raw/sources/meeting_doc_95221/blocks.jsonl","page_number":2,"block_id":"p002_c0001","text_sha256":"sha256:dc2a6ae293206fa9ac904fd3db795441a6667f2c68ec67a3ba8cd0072d660ba0","text_source":"raw_text"},{"source_id":"meeting_doc_95221","evidence_id":"meeting_doc_95221#p005_c0003","source_path":"raw/sources/meeting_doc_95221/blocks.jsonl","page_number":5,"block_id":"p005_c0003","text_sha256":"sha256:81f284537840ad26b598ba80d5fc6b91012afd9c4faebdf44555e26c42a79563","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
