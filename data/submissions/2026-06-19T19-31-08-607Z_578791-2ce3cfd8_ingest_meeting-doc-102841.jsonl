{"submission_id":"sub_d17646d892d2edf1","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:35:16.168Z","tool_args_sha256":"sha256:d17646d892d2edf149439698c718d32416a5f36ab18b53101b4f9661e7aa26bc","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"metric_claim","local_observation_id":"metric_meeting_doc_lunch_relief_cost_reduction","label":"Elimination of lunch reliefs cost reduction","payload":{"metric_name":"annual_cost_reduction","raw_value_text":"$10.5 million annually","value":10.5,"unit":"million USD","period":"annually","description":"The elimination of lunch reliefs is expected to reduce costs by $10.5 million annually","unit_normalized":{"raw_text":"million USD","normalized_unit":"million_usd","unit_family":"other"},"time_horizon":"annual"},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p001_c0013","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":1,"block_id":"p001_c0013","text_sha256":"sha256:857e475de29e4d0f54fa60219ab964f4cae7ff5b1d2b82ef1bb643987eef7829","text_source":"raw_text","source_quote":"The elimination of lunch reliefs is expected to reduce costs by $10.5 million annually, partially offset by a cost increase of $5.1 million from changes to Station Agent pay rates."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_a0ba71a16ffc50df","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:35:35.127Z","tool_args_sha256":"sha256:a0ba71a16ffc50df95f09bff3827926e70c9201d178516a499492baf3a4ee43f","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"metric_claim","local_observation_id":"metric_meeting_doc_station_agent_pay_increase","label":"Station Agent pay rate cost increase","payload":{"metric_name":"annual_cost_increase","raw_value_text":"$5.1 million","value":5.1,"unit":"million USD","period":"annually","description":"Partially offset by a cost increase of $5.1 million from changes to Station Agent pay rates","unit_normalized":{"raw_text":"million USD","normalized_unit":"million_usd","unit_family":"other"},"time_horizon":"annual"},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p001_c0013","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":1,"block_id":"p001_c0013","text_sha256":"sha256:857e475de29e4d0f54fa60219ab964f4cae7ff5b1d2b82ef1bb643987eef7829","text_source":"raw_text","source_quote":"The elimination of lunch reliefs is expected to reduce costs by $10.5 million annually, partially offset by a cost increase of $5.1 million from changes to Station Agent pay rates."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_23d34788f51cacce","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:38:31.998Z","tool_args_sha256":"sha256:23d34788f51cacce185a1be5ca50af9c99bd3c709acef475a39877647d5d406f","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"project","local_observation_id":"project_station_booth_service_reduction","create_new":true,"label":"Proposed Reduction or Elimination of Station Booth Service","payload":{"project_name":"Reduction or Elimination of Station Booth Service Throughout the Subway System, including Elimination of Station Booth Lunch Relief","project_type":"operational_change","status":"proposed","description":"The proposal is the reduction or elimination of station booth service throughout the subway system, including the elimination of station booth lunch relief. Station agents would work outside booths to provide a broader range of customer service functions. Each station would continue to be staffed by a minimum of one station agent per day 24/7, except during the lunch break period.","document_time_status":"planned","project_family":"other"},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p001_c0007","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":1,"block_id":"p001_c0007","text_sha256":"sha256:ee963da90fa1aa3bf6117f1c6192b6f4263ce923b56ab4e61239abbfab5ecdfc","text_source":"raw_text","source_quote":"The proposal that will be the subject of the public hearing for which board authorization is sought is the reduction or elimination of station booth service throughout the subway system, including the elimination of station booth lunch relief."},{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p001_c0008","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":1,"block_id":"p001_c0008","text_sha256":"sha256:e9ea0068e693a9937e98024cefddebc6e7e613c8bc1b08363c217c17ed3ae356","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_d0d923f0f5f236a4","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:39:28.932Z","tool_args_sha256":"sha256:d0d923f0f5f236a4fb5ac0c499078770efc88eda2024bdaa56d195739abb78a4","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"claim","local_observation_id":"claim_meeting_doc_current_booth_staffing","label":"Current station booth staffing","payload":{"claim_text":"Currently, each subway station or station complex has at least one booth that is staffed 24 hours per day, 7 days per week. Certain stations have one or more additional booths that are staffed full or part-time.","change_type":"existing_condition","data_type":"operational_policy","data_type_normalized":{"raw_text":"operational_policy","normalized_value":"operational_policy"},"change_type_normalized":{"raw_text":"existing_condition","normalized_value":"existing_condition"}},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p001_c0005","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":1,"block_id":"p001_c0005","text_sha256":"sha256:3e5e9176289b332cb9ab378f00a1173f658b9876345836f32dd8de74083c28a7","text_source":"raw_text","source_quote":"Currently, each subway station or station complex (also referred to herein as a station) has at least one booth that is staffed 24 hours per day, 7 days per week."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_003d201be7c57530","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:39:50.136Z","tool_args_sha256":"sha256:003d201be7c575305e14e09904abee1f963e615e8ab2b24f39a09a7c67fe55f4","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"claim","local_observation_id":"claim_meeting_doc_services_from_booths","label":"Services provided from station booths","payload":{"claim_text":"Services currently provided from booths by station agents are limited to providing customer information and assistance to customers who are not able to use the turnstiles or the AutoGate. Station Agents are limited in the services they can provide because they can only provide services from booths.","change_type":"existing_condition","data_type":"service_description","data_type_normalized":{"raw_text":"service_description","normalized_value":"service_description"},"change_type_normalized":{"raw_text":"existing_condition","normalized_value":"existing_condition"}},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p001_c0006","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":1,"block_id":"p001_c0006","text_sha256":"sha256:ea8a03e21a7122835e695bd5f2d7f7333b3633988e9d6fdb82fc573dfcd2ba68","text_source":"raw_text","source_quote":"services currently provided from booths by station agents are limited to providing customer information, such as about how to use the transit system, and to provide assistance to customers who are not able to use the turnstiles or the AutoGate."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_6ff6150a9d8a68de","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:40:10.655Z","tool_args_sha256":"sha256:6ff6150a9d8a68dea0914629634546a86c92fffe4898680d740f3ad6fb8e91fc","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"claim","local_observation_id":"claim_meeting_doc_fare_media_discontinued","label":"Fare media sales discontinued","payload":{"claim_text":"Historically, services provided from station booths included the sale or replenishment of fare media, but that service was discontinued during the COVID pandemic and will not be resumed.","change_type":"change","data_type":"service_change","data_type_normalized":{"raw_text":"service_change","normalized_value":"service_change"},"change_type_normalized":{"raw_text":"change","normalized_value":"change"}},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p001_c0006","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":1,"block_id":"p001_c0006","text_sha256":"sha256:ea8a03e21a7122835e695bd5f2d7f7333b3633988e9d6fdb82fc573dfcd2ba68","text_source":"raw_text","source_quote":"Historically, services provided from station booths included the sale or replenishment of fare media, but that service was discontinued during the COVID pandemic and will not be resumed."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_00dd71a0c0fb3f2a","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:40:28.915Z","tool_args_sha256":"sha256:00dd71a0c0fb3f2ae1efe597ac5a70fa9b931be0ba1ebc09a6555b52ffbe7609","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"claim","local_observation_id":"claim_meeting_doc_agents_outside_booths","label":"Station agents working outside booths","payload":{"claim_text":"The services that are currently provided from station booths would instead be provided by station agents working in the station but outside of the booths. Moving station agents outside of the booths would enable them to provide a broader range of customer service functions throughout the station, such as providing assistance at turnstiles, at MetroCard and OMNY vending machines, and on platforms.","change_type":"proposed_change","data_type":"operational_policy","data_type_normalized":{"raw_text":"operational_policy","normalized_value":"operational_policy"},"change_type_normalized":{"raw_text":"proposed_change","normalized_value":"proposed_change"}},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p001_c0007","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":1,"block_id":"p001_c0007","text_sha256":"sha256:ee963da90fa1aa3bf6117f1c6192b6f4263ce923b56ab4e61239abbfab5ecdfc","text_source":"raw_text","source_quote":"The services that are currently provided from station booths would instead be provided by station agents working in the station but outside of the booths."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_efa860ecd9c6b6b7","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:40:45.722Z","tool_args_sha256":"sha256:efa860ecd9c6b6b76e88f2e823efac634cd1366addca474d968dd2525af9c73b","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"claim","local_observation_id":"claim_meeting_doc_minimum_staffing","label":"Minimum staffing commitment","payload":{"claim_text":"Each station in which booth service is reduced or eliminated shall continue to be staffed by a minimum of one station agent per day 24 hours per day, 7 days per week, except during the period of the station agent's lunch break.","change_type":"proposed_change","data_type":"operational_policy","data_type_normalized":{"raw_text":"operational_policy","normalized_value":"operational_policy"},"change_type_normalized":{"raw_text":"proposed_change","normalized_value":"proposed_change"}},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p001_c0008","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":1,"block_id":"p001_c0008","text_sha256":"sha256:e9ea0068e693a9937e98024cefddebc6e7e613c8bc1b08363c217c17ed3ae356","text_source":"raw_text","source_quote":"Each station in which booth service is reduced or eliminated shall continue to be staffed by a minimum of one station agent per day 24 hours per day, 7 days per week (1), except during the period of the station agent's lunch break."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_6cd9ef2043681f46","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:41:49.386Z","tool_args_sha256":"sha256:6cd9ef2043681f460047def86fa151993fa53910d2b01da22864c7914b1513ec","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"claim","local_observation_id":"claim_meeting_doc_5_line_exception","label":"5 Line stations exception","payload":{"claim_text":"Five stations on the 5 Line in the Bronx (Eastchester-Dyre Av, Baychester Av, Gun Hill Rd, Pelham Pkwy, and Morris Park) are currently staffed 16 hours per day, and will continue to be staffed on that schedule.","change_type":"existing_condition","data_type":"exception","data_type_normalized":{"raw_text":"exception","normalized_value":"exception"},"change_type_normalized":{"raw_text":"existing_condition","normalized_value":"existing_condition"}},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p001_c0016","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":1,"block_id":"p001_c0016","text_sha256":"sha256:050d15ccdf4b1b643c5470abda0e41605ca696043424dfea47d1a8dc1151a6a2","text_source":"raw_text","source_quote":"Five stations on the 5 Line in the Bronx (Eastchester-Dyre Av, Baychester Av, Gun Hill Rd, Pelham Pkwy, and Morris Park) are currently staffed 16 hours per day, and will continue to be staffed on that schedule."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_945ac90ac2a7368d","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:42:10.139Z","tool_args_sha256":"sha256:945ac90ac2a7368da4332c19a5b4617450bb2daf6d797713c54ef639f93205c8","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"claim","local_observation_id":"claim_meeting_doc_alternative_no_change","label":"Alternative 1: No change","payload":{"claim_text":"Not advancing the proposal that will be the subject of the public hearing for which authorization is sought will prevent station agents from providing a comprehensive range of customer services that can only be delivered outside of the booths.","change_type":"alternative","data_type":"policy_option","data_type_normalized":{"raw_text":"policy_option","normalized_value":"policy_option"},"change_type_normalized":{"raw_text":"alternative","normalized_value":"alternative"}},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p003_c0006","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":3,"block_id":"p003_c0006","text_sha256":"sha256:efa63ed6994b926a845c419b0065d1758a8f73a7b7949d68293d8fe91675de28","text_source":"raw_text","source_quote":"1. No change. Not advancing the proposal that will be the subject of the public hearing for which authorization is sought will prevent station agents from providing a comprehensive range of customer services that can only be delivered outside of the booths."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_9d7f9d9d65bc3bce","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:42:29.467Z","tool_args_sha256":"sha256:9d7f9d9d65bc3bce1f7b7be2534b17dabe953438f8755cebdf254b293fcaa5d0","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"claim","local_observation_id":"claim_meeting_doc_alternative_add_agents","label":"Alternative 2: Maintain 24/7 booth service and add agents","payload":{"claim_text":"Maintain 24/7 station agent booth service throughout the system and add another station agent at each station to provide service outside of the booths. This would nearly double the station agent staffing costs.","change_type":"alternative","data_type":"policy_option","data_type_normalized":{"raw_text":"policy_option","normalized_value":"policy_option"},"change_type_normalized":{"raw_text":"alternative","normalized_value":"alternative"}},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p003_c0006","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":3,"block_id":"p003_c0006","text_sha256":"sha256:efa63ed6994b926a845c419b0065d1758a8f73a7b7949d68293d8fe91675de28","text_source":"raw_text","source_quote":"2. Maintain 24/7 station agent booth service throughout the system and add another station agent at each station to provide service outside of the booths. This would nearly double the station agent staffing costs."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_9e53aedb5b803833","run_id":"2026-06-19T19-31-08-607Z_578791-2ce3cfd8_ingest_meeting-doc-102841","submitted_at":"2026-06-19T19:42:48.523Z","tool_args_sha256":"sha256:9e53aedb5b803833e79e68daac3a631c024b39397577e03faa83b46cc5d53e6f","schema_version":2,"tool_args":{"source_id":"meeting_doc_102841","observation_kind":"claim","local_observation_id":"claim_meeting_doc_alternative_no_minimum","label":"Alternative 3: Reduce booth service without minimum staffing","payload":{"claim_text":"Advance a proposal for the reduction or elimination of station booth service throughout the subway system, but without a commitment to provide a minimum of one station agent at each station outside of the booths on a 24/7 (except lunch relief) basis. This would be less costly than the proposal being advanced, but would not enable us to provide customer service at all stations on a 24/7 basis.","change_type":"alternative","data_type":"policy_option","data_type_normalized":{"raw_text":"policy_option","normalized_value":"policy_option"},"change_type_normalized":{"raw_text":"alternative","normalized_value":"alternative"}},"evidence_refs":[{"source_id":"meeting_doc_102841","evidence_id":"meeting_doc_102841#p003_c0006","source_path":"raw/sources/meeting_doc_102841/blocks.jsonl","page_number":3,"block_id":"p003_c0006","text_sha256":"sha256:efa63ed6994b926a845c419b0065d1758a8f73a7b7949d68293d8fe91675de28","text_source":"raw_text","source_quote":"3. Advance a proposal for the reduction or elimination of station booth service throughout the subway system, but without a commitment to provide a minimum of one station agent at each station outside of the booths on a 24/7 (except lunch relief) basis."}]},"validation":{"state":"accepted","issues":[]}}
