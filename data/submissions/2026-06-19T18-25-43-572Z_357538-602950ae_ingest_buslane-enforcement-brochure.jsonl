{"submission_id":"sub_6a5b622729866ae0","run_id":"2026-06-19T18-25-43-572Z_357538-602950ae_ingest_buslane-enforcement-brochure","submitted_at":"2026-06-19T18:29:05.783Z","tool_args_sha256":"sha256:6a5b622729866ae0c115c50075430bab0e318fbaa12241ea2c295c7db2716de2","schema_version":2,"tool_args":{"source_id":"buslane_enforcement_brochure","observation_kind":"entity","local_observation_id":"entity_buslane_brochure_nyc_dot","target_record_id":"entity_nyc-dot","label":"NYC DOT","raw_text":"The City or MTA may operate bus lane cameras on any bus lanes to catch violators. NYC DOT posts signs along routes that have bus lane cameras as a warning for drivers.","payload":{"entity_name":"NYC DOT","entity_type":"agency","description":"New York City Department of Transportation; operates bus lane cameras and posts warning signs"},"evidence_refs":[{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p002_c0014","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":2,"block_id":"p002_c0014","text_sha256":"sha256:1e9e47bca67de2475a059ea5f918e4c7cdde69024a0da62dae71ba818afe02c7","text_source":"raw_text","role":"camera_operator"},{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p002_c0010","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":2,"block_id":"p002_c0010","text_sha256":"sha256:bb557f3e7f896079e9311006bb37cdff17ca19856b4c4f79bb4556f6ebedd1a7","text_source":"raw_text","role":"url"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_392a96ce7a13e3c9","run_id":"2026-06-19T18-25-43-572Z_357538-602950ae_ingest_buslane-enforcement-brochure","submitted_at":"2026-06-19T18:29:09.911Z","tool_args_sha256":"sha256:392a96ce7a13e3c9c6a6c6713685286a1140aa78c6ab71faab326aa1e46380d6","schema_version":2,"tool_args":{"source_id":"buslane_enforcement_brochure","observation_kind":"entity","local_observation_id":"entity_buslane_brochure_mta","target_record_id":"entity_mta-nyct","label":"MTA","raw_text":"The City or MTA may operate bus lane cameras on any bus lanes to catch violators.","payload":{"entity_name":"MTA","entity_type":"agency","description":"Metropolitan Transportation Authority; may operate bus lane cameras"},"evidence_refs":[{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p002_c0014","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":2,"block_id":"p002_c0014","text_sha256":"sha256:1e9e47bca67de2475a059ea5f918e4c7cdde69024a0da62dae71ba818afe02c7","text_source":"raw_text","role":"camera_operator"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_1c3e56a832261a6d","run_id":"2026-06-19T18-25-43-572Z_357538-602950ae_ingest_buslane-enforcement-brochure","submitted_at":"2026-06-19T18:29:14.116Z","tool_args_sha256":"sha256:1c3e56a832261a6dedece68916ce198492140feb29b86c79665c16cbca7b0ac1","schema_version":2,"tool_args":{"source_id":"buslane_enforcement_brochure","observation_kind":"entity","local_observation_id":"entity_buslane_brochure_nypd","target_record_id":"entity_nypd","label":"NYPD","raw_text":"NYPD patrols bus lanes, and issues both moving and parking violations. Each NYPD violation is $125.","payload":{"entity_name":"NYPD","entity_type":"agency","description":"New York City Police Department; patrols bus lanes and issues moving and parking violations"},"evidence_refs":[{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p002_c0019","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":2,"block_id":"p002_c0019","text_sha256":"sha256:56c7a9546ab669d72920107139d3b33f17d9b10f612c84864341821d27fb3fa6","text_source":"raw_text","role":"enforcement_authority"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_1694c4f62cdf405d","run_id":"2026-06-19T18-25-43-572Z_357538-602950ae_ingest_buslane-enforcement-brochure","submitted_at":"2026-06-19T18:31:28.746Z","tool_args_sha256":"sha256:1694c4f62cdf405d673aec6173a6c1fcf023598601a27b5d6d6a883e3c2872c2","schema_version":2,"tool_args":{"source_id":"buslane_enforcement_brochure","observation_kind":"claim","local_observation_id":"claim_bus_lane_definition","label":"Bus lane definition","raw_text":"It is a travel lane restricted to buses only during certain hours of the day. During this time, other vehicles may enter a bus lane only to make the next available right turn, or to quickly drop off or pick up passengers. Violating bus lane rules results in a $50 - $250 fine.","payload":{"claim_text":"A bus lane is a travel lane restricted to buses only during certain hours of the day. During this time, other vehicles may enter a bus lane only to make the next available right turn, or to quickly drop off or pick up passengers.","subject":"bus lane","description":"Definition of a bus lane and permitted uses"},"evidence_refs":[{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p001_c0011","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":1,"block_id":"p001_c0011","text_sha256":"sha256:e05008b6b78b3212c35ee9a9b7a3e2309eecf2366f4d126fd180dea2aa1c0a38","text_source":"raw_text","role":"definition"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_715051203a7b623f","run_id":"2026-06-19T18-25-43-572Z_357538-602950ae_ingest_buslane-enforcement-brochure","submitted_at":"2026-06-19T18:31:34.023Z","tool_args_sha256":"sha256:715051203a7b623f16b674de3028fd2cecec28e5b3c61855ad4316c6a9be4283","schema_version":2,"tool_args":{"source_id":"buslane_enforcement_brochure","observation_kind":"claim","local_observation_id":"claim_bus_lane_types","label":"Types of bus lanes","raw_text":"Curbside bus lanes: are travel lanes for buses at the curb. Parking and standing at the curb are not allowed during the hours the bus lane is in effect. Offset bus lanes: are travel lanes for buses one lane away from the curb. This makes parking or standing at the curb still possible. Center-running or median bus lanes: are in the middle of the roadway, such as Woodhaven Boulevard, Kings Highway, and 161st Street. Vehicles are not permitted to enter the bus lanes for any reason while the bus lane is in effect. Busways: allocate the whole roadway to buses and local access.","payload":{"claim_text":"Types of bus lanes include: curbside bus lanes (travel lanes for buses at the curb, no parking/standing during hours in effect), offset bus lanes (one lane away from curb, parking still possible), center-running or median bus lanes (middle of roadway, e.g. Woodhaven Boulevard, Kings Highway, 161st Street; vehicles cannot enter for any reason while in effect), and busways (whole roadway allocated to buses and local access).","subject":"bus lane types","description":"Four types of bus lanes described in the brochure"},"evidence_refs":[{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p001_c0015","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":1,"block_id":"p001_c0015","text_sha256":"sha256:786e45bdd380eb5b00eb9be793ae0d963ed53157b5db45d6a352d39ad65ce50e","text_source":"raw_text","role":"description"},{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p001_c0017","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":1,"block_id":"p001_c0017","text_sha256":"sha256:32a936d8985bba5e50a5fcd0e84a7953732fb3a85b1a56aa32303722e080e851","text_source":"raw_text","role":"description"},{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p001_c0019","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":1,"block_id":"p001_c0019","text_sha256":"sha256:a3973a7684bc12eb64bf06c15f99c6007f2a20611afee39f8b0c0469b9d5fe7c","text_source":"raw_text","role":"description"},{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p001_c0021","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":1,"block_id":"p001_c0021","text_sha256":"sha256:de4100f81fb17d2e9a16a2e1307bbdb7c92fbddb4a0a8b697431fd89bad93b0d","text_source":"raw_text","role":"description"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_458c62cc6955c413","run_id":"2026-06-19T18-25-43-572Z_357538-602950ae_ingest_buslane-enforcement-brochure","submitted_at":"2026-06-19T18:31:39.313Z","tool_args_sha256":"sha256:458c62cc6955c413b5521f0982b8a21759f53c3b69111de1b2ae5e7a1f4130af","schema_version":2,"tool_args":{"source_id":"buslane_enforcement_brochure","observation_kind":"claim","local_observation_id":"claim_bus_lane_entry_rules","label":"Bus lane entry rules","raw_text":"Unless otherwise restricted, vehicles may use the bus lane to make the next available right turn. Look, signal, then enter the bus lane toward the end of the block you are turning from. If possible, arrange your pick up or drop off where there isn't a bus lane. You may stop in the bus lane for the time it takes a passenger to enter the vehicle from the curb, or exit the vehicle and get onto the sidewalk. You cannot pick-up or deliver goods in a bus lane during the hours it is in effect.","payload":{"claim_text":"Unless otherwise restricted, vehicles may use the bus lane to make the next available right turn. You may stop in the bus lane for the time it takes a passenger to enter/exit. You cannot pick-up or deliver goods in a bus lane during the hours it is in effect.","subject":"bus lane entry rules","description":"Rules for entering bus lanes for right turns, passenger pick-up/drop-off, and deliveries"},"evidence_refs":[{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p001_c0005","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":1,"block_id":"p001_c0005","text_sha256":"sha256:6543de95d28c99e6669cbe07c800b3491e9099a2a34e17dcfb5471bef711eb0c","text_source":"raw_text","role":"rule"},{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p001_c0007","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":1,"block_id":"p001_c0007","text_sha256":"sha256:7dbdca75af1ea4ac37cedd9e9b55140f56186b0c446953e3be544d3ae4961651","text_source":"raw_text","role":"rule"},{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p001_c0009","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":1,"block_id":"p001_c0009","text_sha256":"sha256:2784edb8e8d0b3d1da1dd7217013597392c59b1c9b9d7478db99ab8991a7213d","text_source":"raw_text","role":"rule"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_c4e3dcf9f216fdf6","run_id":"2026-06-19T18-25-43-572Z_357538-602950ae_ingest_buslane-enforcement-brochure","submitted_at":"2026-06-19T18:31:44.214Z","tool_args_sha256":"sha256:c4e3dcf9f216fdf6baab2cfd5323112dd6bfdadbfdb87781627de11cd674f20d","schema_version":2,"tool_args":{"source_id":"buslane_enforcement_brochure","observation_kind":"claim","local_observation_id":"claim_bus_lane_enforcement_methods","label":"Bus lane enforcement methods","raw_text":"If you drive, park, or stand in a bus lane during hours of operation you face fines starting at $50. NYC enforces bus lanes in two ways:","payload":{"claim_text":"NYC enforces bus lanes in two ways: Bus Lane Cameras and Police Enforcement.","subject":"bus lane enforcement","description":"Two methods of bus lane enforcement: cameras and police"},"evidence_refs":[{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p002_c0012","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":2,"block_id":"p002_c0012","text_sha256":"sha256:55b2a8a7e7153a6bc6b06c60598489b7ca89a98860b15755e8707905699ec0be","text_source":"raw_text","role":"enforcement"}]},"validation":{"state":"accepted","issues":[]}}
