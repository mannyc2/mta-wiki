{"submission_id":"sub_02b1c83455d32f1a","run_id":"2026-06-19T18-25-43-572Z_357538-602950ae_ingest_buslane-enforcement-brochure","submitted_at":"2026-06-19T18:26:29.179Z","tool_args_sha256":"sha256:02b1c83455d32f1ad13dfbee47ba7f0c1117546f76d6d82e2b23b468e3cbe476","schema_version":2,"tool_args":{"source_id":"buslane_enforcement_brochure","observation_kind":"source","local_observation_id":"source_buslane_enforcement_brochure","label":"Bus Lanes in NYC brochure","raw_text":"Over two million people ride the bus every day in New York City. Bus lanes keep buses from getting stuck in traffic, making bus travel fast and more reliable.","payload":{"title":"Bus Lanes in NYC","content_type":"brochure","publisher":"NYC DOT","source_url":"nyc.gov/betterbuses","description":"Brochure explaining bus lane rules, types of bus lanes, and enforcement fines in New York City","authority_tier":"plan_document"},"evidence_refs":[{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p001_c0001","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":1,"block_id":"p001_c0001","text_sha256":"sha256:68d9b825671ecedc53d0970abb76398c07149b7fd8af1a9964cfdb936c35cbd2","text_source":"raw_text","role":"title_area"},{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p002_c0002","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":2,"block_id":"p002_c0002","text_sha256":"sha256:28686dc1cd3dd7ac3a5c99ac547d0f8dddd6d3d2dbcd7e85d1920b8120567c59","text_source":"raw_text","role":"content"},{"source_id":"buslane_enforcement_brochure","evidence_id":"buslane_enforcement_brochure#p002_c0010","source_path":"raw/sources/buslane_enforcement_brochure/blocks.jsonl","page_number":2,"block_id":"p002_c0010","text_sha256":"sha256:bb557f3e7f896079e9311006bb37cdff17ca19856b4c4f79bb4556f6ebedd1a7","text_source":"raw_text","role":"url"}]},"validation":{"state":"accepted","issues":[],"warnings":["