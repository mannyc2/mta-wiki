{"submission_id":"sub_f58eb231ab6b82ae","run_id":"2026-06-19T19-42-29-048Z_578791-ed65fccf_ingest_meeting-doc-105966","submitted_at":"2026-06-19T20:29:18.730Z","tool_args_sha256":"sha256:f58eb231ab6b82ae0c25fc602fbbd37c0804e9e94b8e0c497fc742df820d1907","schema_version":2,"tool_args":{"source_id":"meeting_doc_105966","observation_kind":"claim","local_observation_id":"claim_community_coach_responsibility_finding","label":"Community Coach found responsible despite prior SAI","payload":{"claim_text":"In connection with a previous contract awarded to Community Coach, it was found to be responsible notwithstanding significant adverse information (\"SAI\") pursuant to the All-Agency Responsibility Guidelines and such responsibility finding was approved by the MNR Acting President in consultation with the MNR General Counsel in January 2018. No new SAI has been found relating to Community Coach and Community Coach has been found to be responsible.","description":"Community Coach responsibility determination with SAI context"},"evidence_refs":[{"source_id":"meeting_doc_105966","evidence_id":"meeting_doc_105966#p002_c0004","source_path":"raw/sources/meeting_doc_105966/blocks.jsonl","page_number":2,"block_id":"p002_c0004","text_sha256":"sha256:30c8c8cdd3887b500eb5f9d8a9b0b400ecfd984387a2bc11699901dbb09cb2f3","text_source":"raw_text","role":"responsibility_determination"}]},"validation":{"state":"accepted","issues":[]}}
