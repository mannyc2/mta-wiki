{"submission_id":"sub_4e7722353012e687","run_id":"2026-06-21T17-44-58-781Z_2907661-828b76ed_ingest_meeting-doc-174181","submitted_at":"2026-06-21T18:15:17.055Z","tool_args_sha256":"sha256:4e7722353012e6878abe94ebb0c3cd6842e4a9a94eefa0fc942a1bd0e27feba0","schema_version":2,"tool_args":{"source_id":"meeting_doc_174181","observation_kind":"claim","local_observation_id":"claim_payroll_mobility_tax_change","label":"Payroll Mobility Tax changes for capital funding","payload":{"claim_text":"To support the 2025-2029 Capital Plan, the enacted State FY 2026 Budget made changes to the Payroll Mobility Tax (PMT) that are intended to generate new, recurring revenue of approximately $1.4 billion in the first full year.","description":"PMT rate increased for largest businesses with payrolls of $10M or more while reducing or eliminating taxes for small businesses. Revenue apportioned 80% NYCT/SIR/MTA Bus, 10% LIRR, 10% Metro-North."},"evidence_refs":[{"source_id":"meeting_doc_174181","evidence_id":"meeting_doc_174181#p084_c0017","source_path":"raw/sources/meeting_doc_174181/blocks.jsonl","page_number":84,"block_id":"p084_c0017","text_sha256":"sha256:8e36c595aa12d7bc17eb562c80b776a1fb00bafc261d39adc6dca41103affeb9","text_source":"raw_text"},{"source_id":"meeting_doc_174181","evidence_id":"meeting_doc_174181#p084_c0018","source_path":"raw/sources/meeting_doc_174181/blocks.jsonl","page_number":84,"block_id":"p084_c0018","text_sha256":"sha256:36e2d7b1674182e6799de326e00691035ff567f79df636777f30c20fea6a35e0","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_58f1f9c83444b6a8","run_id":"2026-06-21T17-44-58-781Z_2907661-828b76ed_ingest_meeting-doc-174181","submitted_at":"2026-06-21T18:15:26.816Z","tool_args_sha256":"sha256:58f1f9c83444b6a834ec0456656fcf5e917583898a5062aa65592e732507bb3a","schema_version":2,"tool_args":{"source_id":"meeting_doc_174181","observation_kind":"claim","local_observation_id":"claim_cd_efficiency","label":"MTA C&D efficiency results","payload":{"claim_text":"Since its creation in 2019, Construction & Development has overhauled the MTA's approach to capital work, averaging over $9 billion annually in new work and completing $7 billion of projects in 2023.","description":"Since 2020, contractor bids have come in 6% below professional estimates, saving $890 million. Additional $395 million saved on insurance costs and more than $800 million on in-house support services."},"evidence_refs":[{"source_id":"meeting_doc_174181","evidence_id":"meeting_doc_174181#p081_c0004","source_path":"raw/sources/meeting_doc_174181/blocks.jsonl","page_number":81,"block_id":"p081_c0004","text_sha256":"sha256:3d745d0efaa6059a2939467534ec393f1e45bb89571efd9a07e1db2325010531","text_source":"raw_text"},{"source_id":"meeting_doc_174181","evidence_id":"meeting_doc_174181#p081_c0005","source_path":"raw/sources/meeting_doc_174181/blocks.jsonl","page_number":81,"block_id":"p081_c0005","text_sha256":"sha256:13b240c257fa55b9060788ba4f1680f7683bbcd0e073657683a60412969f7bf6","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
