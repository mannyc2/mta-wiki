{"submission_id":"sub_9cffb06d7fbd3965","run_id":"2026-06-21T17-44-58-781Z_2907661-828b76ed_ingest_meeting-doc-174181","submitted_at":"2026-06-21T18:00:21.679Z","tool_args_sha256":"sha256:9cffb06d7fbd3965b37e2e7910ef5618cbdba0709af7e97c5a2555b98ba1e1f1","schema_version":2,"tool_args":{"source_id":"meeting_doc_174181","observation_kind":"project","local_observation_id":"project_2025_2029_capital_plan","create_new":true,"label":"2025-2029 Capital Plan","raw_text":"The proposed 2025-2029 Capital Plan includes $65.4 billion in transit and commuter investments to be approved by the MTA's Capital Program Review Board (CPRB), as well as an additional approved $3 billion in investment by MTA's Bridges and Tunnels.","payload":{"project_name":"2025-2029 Capital Plan","project_type":"capital plan","status":"proposed","description":"The ninth MTA five-year capital plan, totaling $68.4 billion in transit and commuter investments. $65.4 billion subject to CPRB approval plus $3 billion in MTA Bridges and Tunnels self-funded investment. Approved by MTA Board on September 25, 2024, vetoed by CPRB on December 24, 2024.","document_time_status":"planned","project_family":"capital_or_infrastructure"},"evidence_refs":[{"source_id":"meeting_doc_174181","evidence_id":"meeting_doc_174181#p084_c0003","source_path":"raw/sources/meeting_doc_174181/blocks.jsonl","page_number":84,"block_id":"p084_c0003","text_sha256":"sha256:cb7e5f519cfe21965c6b740418b2ed461e99b567bb0e8c54404404b3c6e98868","text_source":"raw_text"},{"source_id":"meeting_doc_174181","evidence_id":"meeting_doc_174181#p084_c0005","source_path":"raw/sources/meeting_doc_174181/blocks.jsonl","page_number":84,"block_id":"p084_c0005","text_sha256":"sha256:2efffc39c67a9ab450d68d57bbdd3816c90b9fcbc37095daf46ed5eeaa972350","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_edc7b7b26e20d4a9","run_id":"2026-06-21T17-44-58-781Z_2907661-828b76ed_ingest_meeting-doc-174181","submitted_at":"2026-06-21T18:03:40.374Z","tool_args_sha256":"sha256:edc7b7b26e20d4a99cfe4c7fb2419478a539c7da2d21ac5cd918a2d068ac4425","schema_version":2,"tool_args":{"source_id":"meeting_doc_174181","observation_kind":"project","local_observation_id":"project_ibx_2025_2029","target_record_id":"project_interborough-express-2020-2024","label":"Interborough Express (IBX)","raw_text":"The Interborough Express (IBX) is a generational opportunity to provide transformative new rapid transit service between Brooklyn and Queens. In this Capital Plan, the MTA will complete design and get shovels in the ground to start construction on this vital new link.","payload":{"project_name":"Interborough Express","project_type":"light rail expansion","status":"proposed","description":"Transformative new rapid transit service between Brooklyn and Queens. Transforming a lightly used freight railway into a light-rail line serving almost 1 million nearby residents and connecting 17 subway lines, more than 50 bus routes and Long Island Rail Road.","boroughs":["Brooklyn","Queens"],"document_time_status":"planned","project_family":"other","boroughs_normalized":["brooklyn","queens"]},"evidence_refs":[{"source_id":"meeting_doc_174181","evidence_id":"meeting_doc_174181#p093_c0004","source_path":"raw/sources/meeting_doc_174181/blocks.jsonl","page_number":93,"block_id":"p093_c0004","text_sha256":"sha256:99738224882537e0f78444db82deda57ecb9d261fcabf4b1edab22e0fe3a38ba","text_source":"raw_text"},{"source_id":"meeting_doc_174181","evidence_id":"meeting_doc_174181#p093_c0008","source_path":"raw/sources/meeting_doc_174181/blocks.jsonl","page_number":93,"block_id":"p093_c0008","text_sha256":"sha256:a6d7399092098b2ffcf1626b2716c8444006476051cbec79e54ed344598983f9","text_source":"raw_text"},{"source_id":"meeting_doc_174181","evidence_id":"meeting_doc_174181#p093_c0012","source_path":"raw