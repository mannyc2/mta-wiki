{"submission_id":"sub_963b74c758cfc7e0","run_id":"2026-06-20T16-37-38-043Z_1885472-ea1edbdf_ingest_meeting-doc-140421","submitted_at":"2026-06-20T17:43:36.156Z","tool_args_sha256":"sha256:963b74c758cfc7e0f90ea435452a94cbbd9bfc9b5c5c65e901bca3ec8b3625ea","schema_version":2,"tool_args":{"source_id":"meeting_doc_140421","observation_kind":"claim","local_observation_id":"claim_ossining_permit_earth_day_policy","label":"Short-Term Permit Under Board Policy","payload":{"claim_text":"Pursuant to the Board-approved policy on October 24, 2002, governing the short-term licensing of railroad facilities by municipal and not-for-profit corporations for non-commercial activities which allows for the issuance of short-term permits for these types of uses provided that no single event exceeds 72 hours, the Town has been granted permission to utilize 112 parking spaces in Lots 14a and 14b at the Station for the Town's annual Earth Day event on Saturday, April 20, 2024, scheduled from 5:00 am to 7:30 pm.","subject":"Short-term parking permit","location":"Ossining Station, Town of Ossining, Westchester County, New York","location_normalized":{"raw_text":"Ossining Station, Town of Ossining, Westchester County, New York"}},"evidence_refs":[{"source_id":"meeting_doc_140421","evidence_id":"meeting_doc_140421#p002_c0010","source_path":"raw/sources/meeting_doc_140421/blocks.jsonl","page_number":2,"block_id":"p002_c0010","text_sha256":"sha256:c91e01432885a18db92906dda6a054a7fa2d724966120484491aecda4a069abb","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
