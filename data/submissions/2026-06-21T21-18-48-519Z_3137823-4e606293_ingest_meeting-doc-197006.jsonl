{"submission_id":"sub_ef1fa71697e9af99","run_id":"2026-06-21T21-18-48-519Z_3137823-4e606293_ingest_meeting-doc-197006","submitted_at":"2026-06-21T21:31:04.356Z","tool_args_sha256":"sha256:ef1fa71697e9af99a9c99b2570b62d4e246685945d32bff4697dea022510af7e","schema_version":2,"tool_args":{"source_id":"meeting_doc_197006","observation_kind":"claim","local_observation_id":"claim_adr_program_description","label":"ADR Program Description","payload":{"claim_text":"The alternative dispute resolution (ADR) program is an alternative method for managing workers' compensation claims for represented workers. The main goals of the program are to ultimately lower the MTA's overall insurance costs, reduce the cost of claims by getting injured workers to receive prompt treatment and return to work quickly. This program will include on-site medical care to evaluate and triage any injuries that arise during construction for Contract 2, as well as a provision for a qualified network of medical providers for injured workers to access.","subject":"Alternative Dispute Resolution (ADR) program","description":"Description of the ADR program for Second Avenue Subway Phase II Contract 2"},"evidence_refs":[{"source_id":"meeting_doc_197006","evidence_id":"meeting_doc_197006#p002_c0012","source_path":"raw/sources/meeting_doc_197006/blocks.jsonl","page_number":2,"block_id":"p002_c0012","text_sha256":"sha256:382ce8fb740e1c787b49198880bfe7bcaa20bbc21743d5bd8997cac34ae76b11","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_ae285fc4b2102b77","run_id":"2026-06-21T21-18-48-519Z_3137823-4e606293_ingest_meeting-doc-197006","submitted_at":"2026-06-21T21:31:12.014Z","tool_args_sha256":"sha256:ae285fc4b2102b77c67a7dba4d1a65037d1ad851518c372d525d2fbe34550be9","schema_version":2,"tool_args":{"source_id":"meeting_doc_197006","observation_kind":"claim","local_observation_id":"claim_nova_bus_procurement_info","label":"Nova Bus bus procurement","payload":{"claim_text":"The first item was a request for Board approval to exercise an option of the contract for the purchase of 165 low-floor 40-foot diesel-electric hybrid buses awarded to Nova Bus (US) Inc. and procure an additional 100 low-floor 40-foot clean diesel Option Buses.","subject":"NYC Transit bus procurement","description":"Information item for NYC Transit: option exercise for 165 hybrid buses and additional 100 clean diesel buses from Nova Bus (US) Inc."},"evidence_refs":[{"source_id":"meeting_doc_197006","evidence_id":"meeting_doc_197006#p003_c0014","source_path":"raw/sources/meeting_doc_197006/blocks.jsonl","page_number":3,"block_id":"p003_c0014","text_sha256":"sha256:19f3170fd1ee619105a2a834ef9d80ffb43470705e8f19775d7bb1f2ad38f61a","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_caa111e2a4963a90","run_id":"2026-06-21T21-18-48-519Z_3137823-4e606293_ingest_meeting-doc-197006","submitted_at":"2026-06-21T21:31:19.496Z","tool_args_sha256":"sha256:caa111e2a4963a90619281e1f19c2b502915dca74bab1c50b1d21ae834a9a56e","schema_version":2,"tool_args":{"source_id":"meeting_doc_197006","observation_kind":"claim","local_observation_id":"claim_laser_train_modules_procurement","label":"Laser train modules procurement","payload":{"claim_text":"The item was a request that the Board approve the award of a noncompetitive miscellaneous service contract for the leasing of three laser train modules (one for MNR and two for LIRR) for Rail-Based Cleaning to Laser Tribology BV.","subject":"Rail-Based Cleaning laser train modules","description":"Information item for Metro-North Railroad and Long Island Rail Road: leasing three laser train modules from Laser Tribology BV"},"evidence_refs":[{"source_id":"meeting_doc_197006","evidence_id":"meeting_doc_197006#p004_c0003","source_path":"raw/sources/meeting_doc_197006/blocks.jsonl","page_number":4,"block_id":"p004_c0003","text_sha256":"sha256:74948de4d3735b7a77dee6f7677c7927e4a98cb01fea2882ac5be0bd6fee7482","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
