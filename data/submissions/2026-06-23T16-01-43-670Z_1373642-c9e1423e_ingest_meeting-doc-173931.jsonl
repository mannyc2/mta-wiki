{"submission_id":"sub_17756d546480a1ff","run_id":"2026-06-23T16-01-43-670Z_1373642-c9e1423e_ingest_meeting-doc-173931","submitted_at":"2026-06-23T16:04:49.401Z","tool_args_sha256":"sha256:17756d546480a1ffec36bf76759fbe87f04493cd9b21709047c301967fe830ab","schema_version":2,"tool_args":{"source_id":"meeting_doc_173931","observation_kind":"claim","local_observation_id":"claim_meeting_doc_173931_program_description","payload":{"claim_text":"MTA's fuel hedging program mitigates budget risk by dollar cost averaging approximately 50% of projected fuel expenses. The goal of the program is to be 50% hedged for the next 12 months. Monthly hedges are equal to approximately 4% of the projected fuel purchases expected to occur 13-24 months from each hedge execution date. The actual percentage hedged could be higher or lower than the 50% target depending on the actual levels of fuel consumption. While the fuel hedging program includes compressed natural gas, there are currently no active hedges.","description":"Fuel Hedging Program description"},"evidence_refs":[{"source_id":"meeting_doc_173931","evidence_id":"meeting_doc_173931#p001_b0033","source_path":"raw/sources/meeting_doc_173931/blocks.jsonl","page_number":1,"block_id":"p001_b0033","text_sha256":"sha256:f9f8a173491325bc61eed9bcff5d0fe8101aeed749a041302f323222ab2db6e4","text_source":"raw_text","source_quote":"MTA's fuel hedging program mitigates budget risk by dollar cost averaging approximately 50% of projected fuel expenses. The goal of the program is to be 50% hedged for the next 12 months. Monthly hedges are equal to approximately 4% of the projected fuel purchases expected to occur 13-24 months from each hedge execution date. The actual percentage hedged could be higher or lower than the 50% target depending on the actual levels of fuel consumption. While the fuel heding program includes compressed natrual gas, there are currently no actve hedges."}]},"validation":{"state":"rejected","issues":["evidence_refs[0].source_quote must be 280 characters or fewer"]}}
