{"submission_id":"sub_ec732284514e8005","run_id":"2026-06-20T19-26-51-796Z_1885472-880eb566_ingest_meeting-doc-155481","submitted_at":"2026-06-20T22:40:49.749Z","tool_args_sha256":"sha256:ec732284514e8005b2970cdb78c4442d08ec131ef3be264f248266e9b536a327","schema_version":2,"tool_args":{"source_id":"meeting_doc_155481","observation_kind":"claim","local_observation_id":"claim_meeting_doc_155481_cbd_pause","label":"Central Business District Tolling Program implementation paused","payload":{"claim_text":"On June 5, 2024, Governor Hochul announced her intention to pause the implementation of Central Business District Tolling Program. The MTA Board adopted a resolution on June 26, 2024 recognizing the pause, extending implementation until a tolling agreement has been executed.","description":"Governor Hochul paused the Central Business District Tolling Program (congestion pricing) implementation, which had been scheduled for mid-2024. The pause indefinitely delays the program and its anticipated $15 billion in capital funding for the MTA 2020-2024 Capital Program."},"evidence_refs":[{"source_id":"meeting_doc_155481","evidence_id":"meeting_doc_155481#p043_c0012","source_path":"raw/sources/meeting_doc_155481/blocks.jsonl","page_number":43,"block_id":"p043_c0012","text_sha256":"sha256:92a4a62ea09632d287577cf9b0bcf60bc566c3b42d517637ee2ba86fd836375b","text_source":"raw_text"},{"source_id":"meeting_doc_155481","evidence_id":"meeting_doc_155481#p048_c0011","source_path":"raw/sources/meeting_doc_155481/blocks.jsonl","page_number":48,"block_id":"p048_c0011","text_sha256":"sha256:d2f007bee74ed6fe989d4ca43a679626318a9030fcb585a8feb6f8e418c8f33f","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
