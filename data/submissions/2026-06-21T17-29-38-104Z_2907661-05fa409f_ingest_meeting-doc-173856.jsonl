{"submission_id":"sub_22b15c3c06cc3513","run_id":"2026-06-21T17-29-38-104Z_2907661-05fa409f_ingest_meeting-doc-173856","submitted_at":"2026-06-21T17:35:41.954Z","tool_args_sha256":"sha256:22b15c3c06cc35132e7b04f958fd4317a64ba3770d019617650e624fc7ccfb39","schema_version":2,"tool_args":{"source_id":"meeting_doc_173856","observation_kind":"claim","local_observation_id":"claim_meeting_doc_173856_board_resolution","label":"Board Resolution for eminent domain proceedings","payload":{"claim_text":"BE IT RESOLVED that the Chairman or designated staff member of the MTA is authorized to proceed with the acquisition of real property interests by negotiated agreements or eminent domain and to schedule and undertake such preliminary steps, including holding a public hearing, as may be required under the Eminent Domain Procedure Law. The proposed acquisitions will be subject to prior, satisfactory completion of any required environmental reviews.","subject":"MTA Board","description":"Board resolution authorizing property acquisition through negotiated agreements or eminent domain"},"evidence_refs":[{"source_id":"meeting_doc_173856","evidence_id":"meeting_doc_173856#p002_c0009","source_path":"raw/sources/meeting_doc_173856/blocks.jsonl","page_number":2,"block_id":"p002_c0009","text_sha256":"sha256:b39aa8d41c9a1018f544632b3fbce5c3700552d10383bdfb47d08f712610a84c","text_source":"raw_text","role":"resolution_text"},{"source_id":"meeting_doc_173856","evidence_id":"meeting_doc_173856#p002_c0010","source_path":"raw/sources/meeting_doc_173856/blocks.jsonl","page_number":2,"block_id":"p002_c0010","text_sha256":"sha256:6f03f4f2194a324b12767e60a188c332209778615160be23a14c5a7c3c0b1779","text_source":"raw_text","role":"environmental_review_condition"},{"source_id":"meeting_doc_173856","evidence_id":"meeting_doc_173856#p002_c0012","source_path":"raw/sources/meeting_doc_173856/blocks.jsonl","page_number":2,"block_id":"p002_c0012","text_sha256":"sha256:ab54639ed3597a01496d6d75b14abd2690e1f162a0d