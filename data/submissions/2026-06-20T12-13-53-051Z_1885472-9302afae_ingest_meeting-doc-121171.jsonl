{"submission_id":"sub_da35cb3afa1d62c3","run_id":"2026-06-20T12-13-53-051Z_1885472-9302afae_ingest_meeting-doc-121171","submitted_at":"2026-06-20T12:32:23.600Z","tool_args_sha256":"sha256:da35cb3afa1d62c3c00c9d44139ddc71ab26776d3a800620ba96012d45bb4501","schema_version":2,"tool_args":{"source_id":"meeting_doc_121171","observation_kind":"claim","local_observation_id":"claim_meeting_doc_121171_note1_methodology","label":"Debt Service Calculation Methodology Note 1","payload":{"claim_text":"Forecasted debt service is calculated based upon projected monthly deposits from available pledged revenues into debt service accounts. Actual payments to bondholders are made from the debt service accounts when due as required for each series of bonds and do not conform to this schedule.","subject":"Debt Service","data_type":"methodology","data_type_normalized":{"raw_text":"methodology","normalized_value":"methodology"}},"evidence_refs":[{"source_id":"meeting_doc_121171","evidence_id":"meeting_doc_121171#p001_c0004","source_path":"raw/sources/meeting_doc_121171/blocks.jsonl","page_number":1,"block_id":"p001_c0004","text_sha256":"sha256:64a97cbce3719edab8c2d9ff6ffc4047b506528de853a82e3864a2db93becab5","text_source":"raw_text","role":"content","source_quote":"Forecasted debt service is calculated based upon projected monthly deposits from available pledged revenues into debt service accounts. Actual payments to bondholders are made from the debt service accounts when due as required for each series of bonds and do not conform to this schedule."}]},"validation":{"state":"rejected","issues":["evidence_refs[0].source_quote must be 280 characters or fewer"]}}
{"submission_id":"sub_c0fa44557c551719","run_id":"2026-06-20T12-13-53-051Z_1885472-9302afae_ingest_meeting-doc-121171","submitted_at":"2026-06-20T12:32:49.968Z","tool_args_sha256":"sha256:c0fa44557c5517194f7a82c9a52563f0509f497194af4db100dbfb73b2644a88","schema_version":2,"tool_args":{"source_id":"meeting_doc_121171","observation_kind":"claim","local_observation_id":"claim_meeting_doc_121171_note3_allocation","label":"Debt Service Allocation Note 3","payload":{"claim_text":"Debt service is allocated among Transit, Commuter, MTA Bus, and TBTA categories based on actual spending of bond proceeds for approved capital projects. Allocation of 2 Broadway COPs is based on occupancy.","subject":"Debt Service Allocation","data_type":"methodology","data_type_normalized":{"raw_text":"methodology","normalized_value":"methodology"}},"evidence_refs":[{"source_id":"meeting_doc_121171","evidence_id":"meeting_doc_121171#p001_c0006","source_path":"raw/sources/meeting_doc_121171/blocks.jsonl","page_number":1,"block_id":"p001_c0006","text_sha256":"sha256:2c7d85074966ca7aaab96f9437c18d15a6bafceeaa150abd9a2916640051e3d7","text_source":"raw_text","role":"content","source_quote":"Debt service is allocated among Transit, Commuter, MTA Bus, and TBTA categories based on actual spending of bond proceeds for approved capital projects."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_e13af483f7d7fdec","run_id":"2026-06-20T12-13-53-051Z_1885472-9302afae_ingest_meeting-doc-121171","submitted_at":"2026-06-20T12:33:15.752Z","tool_args_sha256":"sha256:e13af483f7d7fdecdf26f1c9833e1a8e258bf3b6c8323c3e4b20fec34c5e819d","schema_version":2,"tool_args":{"source_id":"meeting_doc_121171","observation_kind":"claim","local_observation_id":"claim_meeting_doc_121171_note2_calendarization","label":"Calendarization Methodology Note 2","payload":{"claim_text":"Generally, the calendarization of monthly debt service deposits is calculated by dividing projected annual debt service by 12. Month to month variations ('timing differences') on the existing debt portfolio can occur based upon, among other things, (a) for all bonds, the date when income from the securities in which the debt service accounts are invested becomes available varies, (b) for variable rate financings, differences between (i) the budgeted interest rate and the actual interest rate, (ii) projected interest payment dates to bondholders and actual interest payment dates to bondholders, and (iii) projected monthly funding dates for accrued debt service and actual funding dates, (c) for transactions with swaps, the difference between when MTA/TBTA funds debt service and the receipt of the corresponding swap payment by the counterparty, and difference between rates received and rates paid and (d) for commercial paper, the interest payment date is the date of the maturity of the commercial paper and the dealers set the term of the commercial paper from 1 to 270 days, which is not foreseeable at the time the annual debt service budgets are prepared.","subject":"Debt Service Calendarization","data_type":"methodology","data_type_normalized":{"raw_text":"methodology","normalized_value":"methodology"}},"evidence_refs":[{"source_id":"meeting_doc_121171","evidence_id":"meeting_doc_121171#p001_c0005","source_path":"raw/sources/meeting_doc_121171/blocks.jsonl","page_number":1,"block_id":"p001_c0005","text_sha256":"sha256:d4badf003114d38e396c4c6d3fdf9c61167e433d161e2240b4926503d7e05f7e","text_source":"raw_text","role":"content","source_quote":"the calendarization of monthly debt service deposits is calculated by dividing projected annual debt service by 12"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_6f5323420a42f84c","run_id":"2026-06-20T12-13-53-051Z_1885472-9302afae_ingest_meeting-doc-121171","submitted_at":"2026-06-20T12:34:25.210Z","tool_args_sha256":"sha256:6f5323420a42f84ced05524f2dd062dbc468801eb99843e94f9e5107809499c8","schema_version":2,"tool_args":{"source_id":"meeting_doc_121171","observation_kind":"claim","local_observation_id":"claim_meeting_doc_121171_note1_methodology","label":"Debt Service Calculation Methodology Note 1","payload":{"claim_text":"Forecasted debt service is calculated based upon projected monthly deposits from available pledged revenues into debt service accounts. Actual payments to bondholders are made from the debt service accounts when due as required for each series of bonds and do not conform to this schedule.","subject":"Debt Service","data_type":"methodology","data_type_normalized":{"raw_text":"methodology","normalized_value":"methodology"}},"evidence_refs":[{"source_id":"meeting_doc_121171","evidence_id":"meeting_doc_121171#p001_c0004","source_path":"raw/sources/meeting_doc_121171/blocks.jsonl","page_number":1,"block_id":"p001_c0004","text_sha256":"sha256:64a97cbce3719edab8c2d9ff6ffc4047b506528de853a82e3864a2db93becab5","text_source":"raw_text","role":"content","source_quote":"Forecasted debt service is calculated based upon projected monthly deposits from available pledged revenues into debt service accounts."}]},"validation":{"state":"accepted","issues":[]}}
