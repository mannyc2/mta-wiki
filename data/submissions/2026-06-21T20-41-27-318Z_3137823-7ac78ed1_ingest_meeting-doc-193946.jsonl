{"submission_id":"sub_afb8f3af4467bdd5","run_id":"2026-06-21T20-41-27-318Z_3137823-7ac78ed1_ingest_meeting-doc-193946","submitted_at":"2026-06-21T20:47:37.324Z","tool_args_sha256":"sha256:afb8f3af4467bdd5f725e0810daaf9ea4b14485b9e69b6871e114cc2b0e599a5","schema_version":2,"tool_args":{"source_id":"meeting_doc_193946","observation_kind":"claim","local_observation_id":"claim_meeting_doc_193946_r20_008","label":"NTSB R-20-008: LIRR Enhanced Awareness Location","raw_text":"R-20-008: Queens Village, NY: Mitigate risks associated with using train approach warning as a method of on-track protection. UPDATE: MTA submitted an update to the NTSB outlining LIRR's Enhanced Awareness Location initiative, which includes targeted training and revised procedures to mitigate risks associated with train approach warning methods. Implementation is underway.","payload":{"claim_text":"MTA submitted an update to the NTSB outlining LIRR's Enhanced Awareness Location initiative, which includes targeted training and revised procedures to mitigate risks associated with train approach warning methods. Implementation is underway.","subject":"LIRR","data_type":"status_update","change_type":"implementation","data_type_normalized":{"raw_text":"status_update","normalized_value":"status_update"},"change_type_normalized":{"raw_text":"implementation","normalized_value":"implementation"}},"evidence_refs":[{"source_id":"meeting_doc_193946","evidence_id":"meeting_doc_193946#p004_c0003","source_path":"raw/sources/meeting_doc_193946/blocks.jsonl","page_number":4,"block_id":"p004_c0003","text_sha256":"sha256:91ea4b2c130ab7e31ac4440dc7a11ace629036ed4b821d02d3e6a746f33615d3","text_source":"raw_text","role":"table_body"}]},"validation":{"state":"accepted","issues":[]}}
