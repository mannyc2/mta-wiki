{"submission_id":"sub_eac7a359c0d42a7a","run_id":"2026-06-23T16-29-38-261Z_1400822-05b8498e_ingest_meeting-doc-194196","submitted_at":"2026-06-23T16:40:09.895Z","tool_args_sha256":"sha256:eac7a359c0d42a7adc50acb48e2526050960596922b4349c4bb00feb0a9fe7c5","schema_version":2,"tool_args":{"source_id":"meeting_doc_194196","observation_kind":"claim","local_observation_id":"claim_fuel_hedging_program_description","label":"Fuel Hedging Program description","payload":{"claim_text":"MTA's fuel hedging program mitigates budget risk by dollar cost averaging approximately 50% of projected fuel expenses. The goal of the program is to be 50% hedged for the next 12 months. Monthly hedges are equal to approximately 4% of the projected fuel purchases expected to occur 13-24 months from each hedge execution date. The actual percentage hedged could be higher or lower than the 50% target depending on the actual levels of fuel consumption."},"evidence_refs":[{"source_id":"meeting_doc_194196","evidence_id":"meeting_doc_194196#p001_b0033","source_path":"raw/sources/meeting_doc_194196/blocks.jsonl","page_number":1,"block_id":"p001_b0033","text_sha256":"sha256:f9f8a173491325bc61eed9bcff5d0fe8101aeed749a041302f323222ab2db6e4","text_source":"raw_text","role":"program_description"}]},"validation":{"state":"accepted","issues":[]}}
