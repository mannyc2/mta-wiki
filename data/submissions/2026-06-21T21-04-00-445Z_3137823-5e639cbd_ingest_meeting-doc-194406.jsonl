{"submission_id":"sub_122c9abdcbef8825","run_id":"2026-06-21T21-04-00-445Z_3137823-5e639cbd_ingest_meeting-doc-194406","submitted_at":"2026-06-21T21:29:24.258Z","tool_args_sha256":"sha256:122c9abdcbef8825825aefe361e7c2dcf3e700bd536191a6b7bbb255e0589cae","schema_version":2,"tool_args":{"source_id":"meeting_doc_194406","observation_kind":"claim","local_observation_id":"claim_penn_station_access_delay","label":"Penn Station Access delayed to 2030","payload":{"claim_text":"Full completion of the Penn Station Access project, originally scheduled for 2027, is now expected to be delayed until 2030. Nevertheless, MTA is planning to begin providing about 30 percent of the planned scheduled service to three of the four new Bronx stations in 2027.","subject":"Penn Station Access project","change_type":"delayed","change_type_normalized":{"raw_text":"delayed","normalized_value":"delayed"}},"evidence_refs":[{"source_id":"meeting_doc_194406","evidence_id":"meeting_doc_194406#p058_c0009","source_path":"raw/sources/meeting_doc_194406/blocks.jsonl","page_number":58,"block_id":"p058_c0009","text_sha256":"sha256:4789f8032898edf51d2fb048ff6f450970f90cae175295466ba868de9cc8cd82","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_3ba58ba4922aa9b0","run_id":"2026-06-21T21-04-00-445Z_3137823-5e639cbd_ingest_meeting-doc-194406","submitted_at":"2026-06-21T21:29:33.991Z","tool_args_sha256":"sha256:3ba58ba4922aa9b0c57933c739b42c4017c8db422c24a3b7c5fd1310d4a89ff0","schema_version":2,"tool_args":{"source_id":"meeting_doc_194406","observation_kind":"claim","local_observation_id":"claim_fema_covid_risk","label":"FEMA COVID reimbursement risk","payload":{"claim_text":"The MTA expects reimbursement through the Federal Emergency Management Agency (FEMA) for direct COVID-related expenses incurred during the pandemic. These reimbursements have already slipped beyond the anticipated date of receipt, and should these reimbursements not materialize, the Plan will be put into deficit by $200 million in 2026, and deficits will be $200 million higher in both 2027 and 2028.","subject":"FEMA COVID reimbursement"},"evidence_refs":[{"source_id":"meeting_doc_194406","evidence_id":"meeting_doc_194406#p059_c0004","source_path":"raw/sources/meeting_doc_194406/blocks.jsonl","page_number":59,"block_id":"p059_c0004","text_sha256":"sha256:924058c1421009e53844982529a5968a3a9929ebb596b9e0076cb5cc907cb4c0","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_8c60967ca790a5c9","run_id":"2026-06-21T21-04-00-445Z_3137823-5e639cbd_ingest_meeting-doc-194406","submitted_at":"2026-06-21T21:29:44.190Z","tool_args_sha256":"sha256:8c60967ca790a5c97004f30a950c119d6b845136820bfbbf676bd9bf0c68d33c","schema_version":2,"tool_args":{"source_id":"meeting_doc_194406","observation_kind":"claim","local_observation_id":"claim_casino_revenue_risk","label":"Casino revenue financial plan risk","payload":{"claim_text":"The awarding of casino licenses is expected by the end of 2025. Should the commencement of operations be delayed, the Plan, which assumes license and gaming tax revenues of $500 million in both 2026 and 2027, $600 million in 2028, and $200 million in 2029, will be out of balance."},"evidence_refs":[{"source_id":"meeting_doc_194406","evidence_id":"meeting_doc_194406#p059_c0004","source_path":"raw/sources/meeting_doc_194406/blocks.jsonl","page_number":59,"block_id":"p059_c0004","text_sha256":"sha256:924058c1421009e53844982529a5968a3a9929ebb596b9e0076cb5cc907cb4c0","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
