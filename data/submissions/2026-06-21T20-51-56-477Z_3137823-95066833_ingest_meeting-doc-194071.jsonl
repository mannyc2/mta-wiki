{"submission_id":"sub_9f64541d0b232166","run_id":"2026-06-21T20-51-56-477Z_3137823-95066833_ingest_meeting-doc-194071","submitted_at":"2026-06-21T21:02:08.971Z","tool_args_sha256":"sha256:9f64541d0b232166796592c040eb9781b4d88e3d3006eb1de8905ca26eaf5700","schema_version":2,"tool_args":{"source_id":"meeting_doc_194071","observation_kind":"claim","local_observation_id":"claim_meeting_doc_194071_mtacc_oversight","label":"MTACC capital project oversight responsibilities","payload":{"claim_text":"With respect to capital projects undertaken by the MTA Capital Construction Company (MTACC) on behalf of LIRR or LIB: 1. Review and make recommendations... 2. Review and make recommendations... 3. Monitor the progress of the capital projects... 4. Monitor the budget and the schedule... 5. Monitor the progress of contract commitments and completions... 6. Track funding needs of capital projects as well as the availability of funds","subject":"Committee on Operations of the Long Island Rail Road and the Metropolitan Suburban Bus Authority"},"evidence_refs":[{"source_id":"meeting_doc_194071","evidence_id":"meeting_doc_194071#p003_c0003","source_path":"raw/sources/meeting_doc_194071/blocks.jsonl","page_number":3,"block_id":"p003_c0003","text_sha256":"sha256:c2f2b754c398101cb4f08d3579b32e07693d371b46e2f76cd78a339ca088f394","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
