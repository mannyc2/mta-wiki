{"submission_id":"sub_6ef031a156e7c6c3","run_id":"2026-06-20T12-13-50-420Z_1885472-a2749045_ingest_meeting-doc-115181","submitted_at":"2026-06-20T12:26:58.971Z","tool_args_sha256":"sha256:6ef031a156e7c6c3cacfae5231b7cc92b85b8ff51203b029ed4af9918cc3036f","schema_version":2,"tool_args":{"source_id":"meeting_doc_115181","observation_kind":"metric_claim","local_observation_id":"metric_meeting_doc_115181_expected_easement_fee","label":"Expected Total Easement Fee","payload":{"metric_name":"expected_easement_fee","raw_value_text":"$28 million or less","value":28000000,"unit":"USD","value_max":28000000,"description":"Expected total easement fee for all properties, based on appraisals at 30% Design stage","unit_normalized":{"raw_text":"USD","normalized_unit":"dollars","unit_family":"money"}},"evidence_refs":[{"source_id":"meeting_doc_115181","evidence_id":"meeting_doc_115181#p002_c0011","source_path":"raw/sources/meeting_doc_115181/blocks.jsonl","page_number":2,"block_id":"p002_c0011","text_sha256":"sha256:69cbd68f81e29add74195b11946a6302816f83c04564344983bcbfe1e23037c3","text_source":"raw_text","source_quote":"The total easement fee for all properties is expected to be $28 million or less based on appraisals obtained to date"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_9eac82ee516844b7","run_id":"2026-06-20T12-13-50-420Z_1885472-a2749045_ingest_meeting-doc-115181","submitted_at":"2026-06-20T12:28:17.939Z","tool_args_sha256":"sha256:9eac82ee516844b70f1a51d616fb54a5eddc1f203e383403416701b40f1b2cbb","schema_version":2,"tool_args":{"source_id":"meeting_doc_115181","observation_kind":"claim","local_observation_id":"claim_meeting_doc_115181_psa_service","label":"PSA Service Description","payload":{"claim_text":"PSA will be a new Metro-North link to Penn Station that will provide one-seat passenger rail service for Metro-North's New Haven Line customers. The new Metro-North service will run through the Bronx via Amtrak's Hell Gate Line, enter Queens via the Hell Gate Bridge, and connect to the LIRR Mainline at Harold Interlocking, from which it will access Penn Station.","subject":"Penn Station Access Project","description":"Description of the new Metro-North service routing for PSA"},"evidence_refs":[{"source_id":"meeting_doc_115181","evidence_id":"meeting_doc_115181#p002_c0007","source_path":"raw/sources/meeting_doc_115181/blocks.jsonl","page_number":2,"block_id":"p002_c0007","text_sha256":"sha256:0e2eaa634d461a0bb6f83fcfaefcde6591f778d019521d5476b148ff0c72fd5e","text_source":"raw_text","source_quote":"PSA will be a new Metro-North link to Penn Station that will provide one-seat passenger rail service for Metro-North's New Haven Line customers."},{"source_id":"meeting_doc_115181","evidence_id":"meeting_doc_115181#p002_c0007","source_path":"raw/sources/meeting_doc_115181/blocks.jsonl","page_number":2,"block_id":"p002_c0007","text_sha256":"sha256:0e2eaa634d461a0bb6f83fcfaefcde6591f778d019521d5476b148ff0c72fd5e","text_source":"raw_text","source_quote":"The new Metro-North service will run through the Bronx via Amtrak's Hell Gate Line, enter Queens via the Hell Gate Bridge, and connect to the LIRR Mainline at Harold Interlocking, from which it will access Penn Station."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_3eefafe3d4f96be5","run_id":"2026-06-20T12-13-50-420Z_1885472-a2749045_ingest_meeting-doc-115181","submitted_at":"2026-06-20T12:28:45.084Z","tool_args_sha256":"sha256:3eefafe3d4f96be542f44cb3c850aecd0101d31ac0423af6791a4be047b698c8","schema_version":2,"tool_args":{"source_id":"meeting_doc_115181","observation_kind":"claim","local_observation_id":"claim_meeting_doc_115181_design_stage_easements","label":"Easement Design Stage Note","payload":{"claim_text":"Permanent easements established at the 30% Design stage. Changes to permanent easements are likely due to Design-Build project delivery method. The master easement agreement will have a mechanism to adjust the easement fee should easements need revision as designs advance to the 100% stage.","subject":"Penn Station Access Project","description":"Current easements are at 30% design stage and subject to change under Design-Build delivery"},"evidence_refs":[{"source_id":"meeting_doc_115181","evidence_id":"meeting_doc_115181#p001_c0008","source_path":"raw/sources/meeting_doc_115181/blocks.jsonl","page_number":1,"block_id":"p001_c0008","text_sha256":"sha256:3163982868d55112784fcc35ae4878a1ea1318f2f599c839d83cb9af36f7703f","text_source":"raw_text","source_quote":"Permanent easements (per 30% Design stage)"},{"source_id":"meeting_doc_115181","evidence_id":"meeting_doc_115181#p002_c0012","source_path":"raw/sources/meeting_doc_115181/blocks.jsonl","page_number":2,"block_id":"p002_c0012","text_sha256":"sha256:f694f873fb63675f8ba22e97c57a84f2471430f24c07e46e293b8b49bd788e82","text_source":"raw_text","source_quote":"Since PSA has adopted the Design-Build project delivery method, changes to permanent easements established at the 30% Design stage are likely."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_7ab4d21b9e588507","run_id":"2026-06-20T12-13-50-420Z_1885472-a2749045_ingest_meeting-doc-115181","submitted_at":"2026-06-20T12:29:15.122Z","tool_args_sha256":"sha256:7ab4d21b9e588507a8b65f85f745cb0f2cc6ab4e4a1d16c516d1a3a9c9dac80b","schema_version":2,"tool_args":{"source_id":"meeting_doc_115181","observation_kind":"claim","local_observation_id":"claim_meeting_doc_115181_fee_adjustment","label":"Easement Fee Adjustment Mechanism","payload":{"claim_text":"Should the size of the permanent easements change as designs advance to 100% design stage, the easement fee will be adjusted as appropriate on a pro-rata basis. If the total exceeds $28 million, additional Board approval will be required.","subject":"Penn Station Access Project","description":"Easement fee adjustment mechanism if design changes occur"},"evidence_refs":[{"source_id":"meeting_doc_115181","evidence_id":"meeting_doc_115181#p001_c0008","source_path":"raw/sources/meeting_doc_115181/blocks.jsonl","page_number":1,"block_id":"p001_c0008","text_sha256":"sha256:3163982868d55112784fcc35ae4878a1ea1318f2f599c839d83cb9af36f7703f","text_source":"raw_text","source_quote":"Should the size of the permanent easements change as designs advance to 100% design stage, the easement fee will be adjusted as appropriate on a pro-rata basis. If the total exceeds $28 million, additional Board approval will be required."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_646c0ffeaea7b21b","run_id":"2026-06-20T12-13-50-420Z_1885472-a2749045_ingest_meeting-doc-115181","submitted_at":"2026-06-20T12:29:44.632Z","tool_args_sha256":"sha256:646c0ffeaea7b21ba19acea8242dd41502f3e151dd5f93f407ec29243a01a83f","schema_version":2,"tool_args":{"source_id":"meeting_doc_115181","observation_kind":"claim","local_observation_id":"claim_meeting_doc_115181_cost_share_terms","label":"Cost Share Agreement Terms","payload":{"claim_text":"Amtrak agreed to grant to the MTA any permanent real estate interests required for PSA and MTA agreed to negotiate fair market value for any easements granted by Amtrak, with the fair market value of the Amtrak easements to be based on a mutually agreed to appraised values.","subject":"Penn Station Access Project","description":"Terms of the Cost Share Agreement between MTA and Amtrak regarding property rights"},"evidence_refs":[{"source_id":"meeting_doc_115181","evidence_id":"meeting_doc_115181#p002_c0009","source_path":"raw/sources/meeting_doc_115181/blocks.jsonl","page_number":2,"block_id":"p002_c0009","text_sha256":"sha256:663dae89706e66484049f489f8816b76ee47a998ae0818cbb88b544fb86bbe35","text_source":"raw_text","source_quote":"Per the Cost Share Agreement, Amtrak agreed to grant to the MTA any permanent real estate interests required for PSA and MTA agreed to negotiate fair market value for any easements granted by Amtrak, with the fair market value of the Amtrak easements to be based on a mutually agreed to appraised values."}]},"validation":{"state":"rejected","issues":["evidence_refs[0].source_quote must be 280 characters or fewer"]}}
