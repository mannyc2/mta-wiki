{"submission_id":"sub_6d784a858f69c2c8","run_id":"2026-06-22T19-00-12-718Z_223560-1f715ddc_ingest_meeting-doc-37071","submitted_at":"2026-06-22T19:24:12.542Z","tool_args_sha256":"sha256:6d784a858f69c2c8f13dec025d35263bad94d702d9df34266e64261de8b36c5d","schema_version":2,"tool_args":{"source_id":"meeting_doc_37071","observation_kind":"project","local_observation_id":"project_esa_systems_facilities_contract_mod","create_new":true,"label":"ESA Systems Facilities Contract Modification","raw_text":"MTA Construction and Development request the Board ratify a retroactive modification (No. 415) to the ESA Systems Facilities contract (CS179) to: (i) revise and resubmit detailed design drawings and test procedures for five systems in the Grand Central Terminal; (ii) relocate fire alarm, telephone, security, radio, and public address system devices; and (iii) modify Access Restraints in Zone 4 of the Grand Central Terminal Concourse. The modification will also extend Substantial Completion and will include an acceleration incentive payment for timely completion.","payload":{"project_name":"ESA Systems Facilities Contract Modification (CS179.415)","project_type":"contract modification","status":"pending board ratification","description":"Retroactive modification to ESA Systems Facilities contract for design drawings, device relocation, and access restraints at Grand Central Terminal","document_time_status":"other","project_family":"other"},"evidence_refs":[{"source_id":"meeting_doc_37071","evidence_id":"meeting_doc_37071#p005_c0002","source_path":"raw/sources/meeting_doc_37071/blocks.jsonl","page_number":5,"block_id":"p005_c0002","text_sha256":"sha256:d71872644cabda027e5d303eb86dda9ebf9086927d50e954b06c2c7b16c240a4","text_source":"raw_text","source_quote":"MTA Construction and Development request the Board ratify a retroactive modification (No. 415) to the ESA Systems Facilities contract (CS179)"},{"source_id":"meeting_doc_37071","evidence_id":"meeting_doc_37071#p128_c0006","so