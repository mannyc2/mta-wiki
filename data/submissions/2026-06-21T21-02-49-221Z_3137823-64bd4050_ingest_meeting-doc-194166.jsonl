{"submission_id":"sub_293e9e6acf0a80ee","run_id":"2026-06-21T21-02-49-221Z_3137823-64bd4050_ingest_meeting-doc-194166","submitted_at":"2026-06-21T21:19:16.256Z","tool_args_sha256":"sha256:293e9e6acf0a80ee23e74a84ef922a2cc2bd36de9938e485e8179825d0d75597","schema_version":2,"tool_args":{"source_id":"meeting_doc_194166","observation_kind":"claim","local_observation_id":"claim_meeting_doc_194166_fine_structure_tiers","label":"Fare Evasion Fine Tiers","payload":{"claim_text":"On January 1, 2025, the fine structure for fare evasion violations changed. Fines for fare evasion are now based on the number of violations committed during a four-year period: Warning (first offense) - no fine; Tier 2 (second offense) - $100 fine ($50 for Fair Fare NYC participants); Tier 3 (third offense) - $150 fine ($75 for Fair Fare NYC participants). Those who pay on time in full receive a $50 credit on an OMNY card for full-fare customers or a $25 credit on an OMNY card for Fair Fare NYC participants.","data_type":"policy","data_type_normalized":{"raw_text":"policy","normalized_value":"policy"}},"evidence_refs":[{"source_id":"meeting_doc_194166","evidence_id":"meeting_doc_194166#p002_c0006","source_path":"raw/sources/meeting_doc_194166/blocks.jsonl","page_number":2,"block_id":"p002_c0006","text_sha256":"sha256:97d03d32e4d2b1ad2715b6470e53ef70fd56a745cc7580e0db3c60ce5f9db67f","text_source":"raw_text","role":"statement"},{"source_id":"meeting_doc_194166","evidence_id":"meeting_doc_194166#p002_c0007","source_path":"raw/sources/meeting_doc_194166/blocks.jsonl","page_number":2,"block_id":"p002_c0007","text_sha256":"sha256:1e3d7f401f164a330a5e69dc79e5a3d892ebef0991e09755f329da3c1254501c","text_source":"raw_text","role":"data"},{"source_id":"meeting_doc_194166","evidence_id":"meeting_doc_194166#p002_c0009","source_path":"raw/sources/meeting_doc_194166/blocks.jsonl","page_number":2,"block_id":"p002_c0009","text_sha256":"sha256:99c830e101360bc7ca1bccf69216978ca3c63779aaaba4ba9ee8fbd322edce3a","text_s