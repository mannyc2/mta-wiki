{"submission_id":"sub_409c9112c01264d0","run_id":"2026-06-23T15-53-50-470Z_1366654-3291ee72_ingest_meeting-doc-151906","submitted_at":"2026-06-23T15:56:31.708Z","tool_args_sha256":"sha256:409c9112c01264d0c2bd068219bd8da2608969222a0c2c54dc0b1f605325a409","schema_version":2,"tool_args":{"source_id":"meeting_doc_151906","observation_kind":"claim","local_observation_id":"claim_fuel_hedge_program_description","label":"Fuel Hedging Program description","payload":{"claim_text":"MTA's fuel hedging program mitigates budget risk by dollar cost averaging approximately 50% of projected fuel expenses. The goal of the program is to be 50% hedged for the next 12 months. Monthly hedges are equal to approximately 4% of the projected fuel purchases expected to occur 13-24 months from each hedge execution date. The actual percentage hedged could be higher or lower than the 50% target depending on the actual levels of fuel consumption. While the fuel hedging program includes compressed natural gas, there are currently no active hedges."},"evidence_refs":[{"source_id":"meeting_doc_151906","evidence_id":"meeting_doc_151906#p001_b0033","source_path":"raw/sources/meeting_doc_151906/blocks.jsonl","page_number":1,"block_id":"p001_b0033","text_sha256":"sha256:f9f8a173491325bc61eed9bcff5d0fe8101aeed749a041302f323222ab2db6e4","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
