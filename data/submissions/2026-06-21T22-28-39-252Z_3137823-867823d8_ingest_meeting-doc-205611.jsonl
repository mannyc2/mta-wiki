{"submission_id":"sub_5424705a3ebfcbc6","run_id":"2026-06-21T22-28-39-252Z_3137823-867823d8_ingest_meeting-doc-205611","submitted_at":"2026-06-21T22:48:40.888Z","tool_args_sha256":"sha256:5424705a3ebfcbc689ea1e85e5aa0d5a0950cea16ca9b78c5f06ca42f2c5cf9e","schema_version":2,"tool_args":{"source_id":"meeting_doc_205611","observation_kind":"claim","local_observation_id":"claim_ptc_consortium_closeout_meeting_doc_205611","label":"PTC Consortium contract in close-out process","raw_text":"The PTC Consortium contract is currently in the close-out process and will not be renewed.","payload":{"claim_text":"The PTC Consortium contract is currently in the close-out process and will not be renewed. The work each Consortium member performed pursuant to the Railroad's PTC Contract was, in large part, proprietary to each firm. As such, in order for the Railroads to maintain and upgrade as necessary the existing PTC System it is necessary to enter into sole source agreements with each firm individually for future expansion, enhancements and support to the existing PTC system.","subject":"PTC Consortium","description":"Prior PTC Consortium contract (including Wabtec, Bombardier, Siemens) is in close-out; sole-source agreements with each firm are needed going forward"},"evidence_refs":[{"source_id":"meeting_doc_205611","evidence_id":"meeting_doc_205611#p006_c0007","source_path":"raw/sources/meeting_doc_205611/blocks.jsonl","page_number":6,"block_id":"p006_c0007","text_sha256":"sha256:0fdec7854ec0b6ec53a5b742636424a5b019243e25653960afd2908983d0618e","text_source":"raw_text","source_quote":"The PTC Consortium contract is currently in the close-out process and will not be renewed."}]},"validation":{"state":"accepted","issues":[]}}
