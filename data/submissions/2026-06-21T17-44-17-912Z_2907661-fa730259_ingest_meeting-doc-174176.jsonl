{"submission_id":"sub_60048b4f79973088","run_id":"2026-06-21T17-44-17-912Z_2907661-fa730259_ingest_meeting-doc-174176","submitted_at":"2026-06-21T17:49:09.598Z","tool_args_sha256":"sha256:60048b4f7997308812b5fabb57b2eb1ced2d0eb4ae334a6cf181a9ebc64a21cb","schema_version":2,"tool_args":{"source_id":"meeting_doc_174176","observation_kind":"project","local_observation_id":"project_meeting_doc_174176_2025_2029_capital_plan","create_new":true,"label":"MTA 2025-2029 Capital Plan","raw_text":"To obtain MTA Board approval of the proposed $68.4 billion MTA 2025-2029 Capital Plan presented herein and to authorize the MTA to re-submit the $65.4 billion Capital Program Review Board (CPRB) portion of it to the CPRB for its review and approval, in accordance with Public Authorities Law §1269-b., as well as the $3.0 billion non-CPRB portion proposed by MTA Bridge and Tunnels (B&T).","payload":{"project_name":"MTA 2025-2029 Capital Plan","project_type":"capital plan","status":"resubmission for board approval","description":"Proposed $68.4 billion capital plan with $65.4 billion CPRB portion and $3.0 billion non-CPRB B&T portion. Includes investments in state of good repair, ADA accessibility, stations, signals, power, new railcars, electric buses, and expansion projects including Interborough Express and Grand Central Artery Initiative.","boroughs":["Bronx","Brooklyn","Manhattan","Queens","Staten Island"],"document_time_status":"other","project_family":"capital_or_infrastructure","boroughs_normalized":["bronx","brooklyn","manhattan","queens","staten_island"]},"evidence_refs":[{"source_id":"meeting_doc_174176","evidence_id":"meeting_doc_174176#p003_c0009","source_path":"raw/sources/meeting_doc_174176/blocks.jsonl","page_number":3,"block_id":"p003_c0009","text_sha256":"sha256:a7fc3ef01fc2f1fd931520a7826bfb2d25be73b0cdf5ed842af0f97aa7d7b3c6","text_source":"raw_text"},{"source_id":"meeting_doc_174176","evidence_id":"meeting_doc_174176#p003_c0012","source_path":"raw/sources/meeting_doc_1