{"submission_id":"sub_92bbb6c51d68c0cd","run_id":"2026-06-20T12-13-52-259Z_1885472-762529b1_ingest_meeting-doc-115396","submitted_at":"2026-06-20T12:31:08.436Z","tool_args_sha256":"sha256:92bbb6c51d68c0cd5c8201e72af9cb58883246fc7ebb59cb96cd474021fff3cf","schema_version":2,"tool_args":{"source_id":"meeting_doc_115396","observation_kind":"claim","local_observation_id":"claim_meeting_doc_115396_env_finding","label":"Environmental finding - no significant adverse effect","payload":{"claim_text":"The proposed increases to the Crossing Charge Schedule will have no significant adverse effect on the environment within the meaning of the State Environmental Quality Review Act ('SEQRA'). The EA analyzed a reasonable worst case scenario toll increase and concluded that no significant adverse impacts to the environment would arise at any Authority facility or along toll-free diversion routes from such a toll increase.","subject":"Crossing Charge Schedule proposed increases","data_type":"environmental finding","data_type_normalized":{"raw_text":"environmental finding","normalized_value":"environmental_finding"}},"evidence_refs":[{"source_id":"meeting_doc_115396","evidence_id":"meeting_doc_115396#p003_c0007","source_path":"raw/sources/meeting_doc_115396/blocks.jsonl","page_number":3,"block_id":"p003_c0007","text_sha256":"sha256:04a045818bd4bda7c747e89a63395b07b534fbaeac857852e902522b733daf8f","text_source":"raw_text"},{"source_id":"meeting_doc_115396","evidence_id":"meeting_doc_115396#p004_c0004","source_path":"raw/sources/meeting_doc_115396/blocks.jsonl","page_number":4,"block_id":"p004_c0004","text_sha256":"sha256:a0a4d39624853fc9e878758e7af1b00f5f210edd0f8439adb03b533f41ffc42e","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_c4e4b908013ab2e9","run_id":"2026-06-20T12-13-52-259Z_1885472-762529b1_ingest_meeting-doc-115396","submitted_at":"2026-06-20T12:31:38.647Z","tool_args_sha256":"sha256:c4e4b908013ab2e96abe45135b5b4ac8515e89bc49cc0f2b12f722e5987acde3","schema_version":2,"tool_args":{"source_id":"meeting_doc_115396","observation_kind":"claim","local_observation_id":"claim_meeting_doc_115396_just_reasonable","label":"Just and reasonable finding","payload":{"claim_text":"The proposed Crossing Charge increases are 'just and reasonable' within the meaning of the General Bridge Act of 1946, should that statute be deemed applicable to one or more of the Authority's facilities.","subject":"Crossing Charge Schedule proposed increases","data_type":"legal finding","data_type_normalized":{"raw_text":"legal finding","normalized_value":"legal_finding"}},"evidence_refs":[{"source_id":"meeting_doc_115396","evidence_id":"meeting_doc_115396#p003_c0007","source_path":"raw/sources/meeting_doc_115396/blocks.jsonl","page_number":3,"block_id":"p003_c0007","text_sha256":"sha256:04a045818bd4bda7c747e89a63395b07b534fbaeac857852e902522b733daf8f","text_source":"raw_text"},{"source_id":"meeting_doc_115396","evidence_id":"meeting_doc_115396#p004_c0003","source_path":"raw/sources/meeting_doc_115396/blocks.jsonl","page_number":4,"block_id":"p004_c0003","text_sha256":"sha256:e560a6971bac3e1756c5390ed4a5c4f00e14197a617004eb9fece1b5615054b4","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_9d0fc7a66d9b7d2f","run_id":"2026-06-20T12-13-52-259Z_1885472-762529b1_ingest_meeting-doc-115396","submitted_at":"2026-06-20T12:32:07.553Z","tool_args_sha256":"sha256:9d0fc7a66d9b7d2f33c6769f577f098e2776a96cf9181e285f3eb382233de378","schema_version":2,"tool_args":{"source_id":"meeting_doc_115396","observation_kind":"claim","local_observation_id":"claim_meeting_doc_115396_finplan_context","label":"Financial Plan context for toll increases","payload":{"claim_text":"The MTA's Proposed Financial Plan 2023-2026 contemplates implementation of increased tolls and fares, to achieve budgeted revenue targets. On December 21, 2022, the Board approved the 2023 Budget and 2023-2026 Financial Plan which contemplated implementation of toll increases in 2023.","subject":"MTA Proposed Financial Plan 2023-2026","data_type":"funding context","data_type_normalized":{"raw_text":"funding context","normalized_value":"funding_context"}},"evidence_refs":[{"source_id":"meeting_doc_115396","evidence_id":"meeting_doc_115396#p015_c0008","source_path":"raw/sources/meeting_doc_115396/blocks.jsonl","page_number":15,"block_id":"p015_c0008","text_sha256":"sha256:7b4710f7bdf623b41c787e6357160a144261ea13db0b300742caa7ed0b320f42","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_4778950244d56543","run_id":"2026-06-20T12-13-52-259Z_1885472-762529b1_ingest_meeting-doc-115396","submitted_at":"2026-06-20T12:32:35.625Z","tool_args_sha256":"sha256:4778950244d565436c79c78d435c84a9abc01ba6718cf432239e37cde2050795","schema_version":2,"tool_args":{"source_id":"meeting_doc_115396","observation_kind":"claim","local_observation_id":"claim_meeting_doc_115396_funding_impact","label":"Impact on funding - raising toll revenues","payload":{"claim_text":"Adoption of the new Crossing Charge Schedule will raise toll revenues in 2023 and subsequent years and enable the Authority, which is permitted to generate surplus funds after payment of all bond obligations, operating, administration and other necessary expenses, to subsidize mass transit and assist the MTA in achieving a balanced budget as required by law.","subject":"New Crossing Charge Schedule","data_type":"funding impact","data_type_normalized":{"raw_text":"funding impact","normalized_value":"funding_impact"}},"evidence_refs":[{"source_id":"meeting_doc_115396","evidence_id":"meeting_doc_115396#p016_c0006","source_path":"raw/sources/meeting_doc_115396/blocks.jsonl","page_number":16,"block_id":"p016_c0006","text_sha256":"sha256:62dfd6f99948159e05bb720886deebaff6bfc604ad0f0914058692c423a506cb","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
