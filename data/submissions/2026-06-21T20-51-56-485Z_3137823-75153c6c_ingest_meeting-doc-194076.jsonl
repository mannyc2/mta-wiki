{"submission_id":"sub_0da34e975a9f60b2","run_id":"2026-06-21T20-51-56-485Z_3137823-75153c6c_ingest_meeting-doc-194076","submitted_at":"2026-06-21T20:57:19.173Z","tool_args_sha256":"sha256:0da34e975a9f60b2c4cbef9914ecd08cef9659d5050d732e6d208f89d7d52e0b","schema_version":2,"tool_args":{"source_id":"meeting_doc_194076","observation_kind":"claim","local_observation_id":"claim_meeting_doc_194076_purpose","label":"Committee purpose","payload":{"claim_text":"The Committee on the Operations of the Metro-North Commuter Railroad shall assist the Board Chair and the Board in fulfilling their responsibility to monitor and oversee the operations of the Metro-North Commuter Railroad Company (\"Metro-North\").","subject":"Committee on the Operations of the Metro-North Commuter Railroad","description":"The Committee's purpose is to assist the Board Chair and Board in monitoring and overseeing Metro-North operations"},"evidence_refs":[{"source_id":"meeting_doc_194076","evidence_id":"meeting_doc_194076#p001_c0006","source_path":"raw/sources/meeting_doc_194076/blocks.jsonl","page_number":1,"block_id":"p001_c0006","text_sha256":"sha256:ce6647457f47f9064e6d9a77e6e5bce3e453c9d761bd6c8064cd79b0f2f429bb","text_source":"raw_text","role":"claim_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_79d6def30441b731","run_id":"2026-06-21T20-51-56-485Z_3137823-75153c6c_ingest_meeting-doc-194076","submitted_at":"2026-06-21T20:57:39.228Z","tool_args_sha256":"sha256:79d6def30441b731ed90d36e05fc1d6edf95c40f349527bf1bd3d5e9ca9fe98f","schema_version":2,"tool_args":{"source_id":"meeting_doc_194076","observation_kind":"claim","local_observation_id":"claim_meeting_doc_194076_membership","label":"Committee membership structure","payload":{"claim_text":"The Committee shall consist of 3 or more members of the Board, appointed by the Board Chair.","subject":"Committee on the Operations of the Metro-North Commuter Railroad","description":"The Committee membership consists of 3 or more Board members appointed by the Board Chair"},"evidence_refs":[{"source_id":"meeting_doc_194076","evidence_id":"meeting_doc_194076#p001_c0010","source_path":"raw/sources/meeting_doc_194076/blocks.jsonl","page_number":1,"block_id":"p001_c0010","text_sha256":"sha256:abc7a3d5326e5a3878638e2f2635c11496e5dcef34a9355c23b77e04047719c5","text_source":"raw_text","role":"claim_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_53fc294f33da0df9","run_id":"2026-06-21T20-51-56-485Z_3137823-75153c6c_ingest_meeting-doc-194076","submitted_at":"2026-06-21T20:57:59.193Z","tool_args_sha256":"sha256:53fc294f33da0df96c71d70ea04e83c053a1f4c612d1aa4d65918fe3018bcd9f","schema_version":2,"tool_args":{"source_id":"meeting_doc_194076","observation_kind":"claim","local_observation_id":"claim_meeting_doc_194076_meeting_frequency","label":"Meeting frequency","payload":{"claim_text":"The Committee shall meet on a regularly-scheduled basis at least 11 times per year, and more frequently as circumstances dictate.","subject":"Committee on the Operations of the Metro-North Commuter Railroad","description":"The Committee meets at least 11 times per year on a regularly-scheduled basis"},"evidence_refs":[{"source_id":"meeting_doc_194076","evidence_id":"meeting_doc_194076#p001_c0012","source_path":"raw/sources/meeting_doc_194076/blocks.jsonl","page_number":1,"block_id":"p001_c0012","text_sha256":"sha256:901c0a7b31224dc52fea541ee92bc784e06db6f4cc3a66c04dcd74aec956f9c8","text_source":"raw_text","role":"claim_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_ea34c554c12b5c8f","run_id":"2026-06-21T20-51-56-485Z_3137823-75153c6c_ingest_meeting-doc-194076","submitted_at":"2026-06-21T20:58:17.546Z","tool_args_sha256":"sha256:ea34c554c12b5c8fd06ebb5270ea87a1146725d29b0f79a01a0b6bca416b1c5d","schema_version":2,"tool_args":{"source_id":"meeting_doc_194076","observation_kind":"claim","local_observation_id":"claim_meeting_doc_194076_key_responsibilities_guide","label":"Key responsibilities as a guide","payload":{"claim_text":"The following responsibilities are set forth as a guide with the understanding that the Committee may diverge as appropriate given the circumstances. The Committee is authorized to carry out these and such other responsibilities assigned by the Board Chair or the Board from time to time.","subject":"Committee on the Operations of the Metro-North Commuter Railroad","description":"Key responsibilities are a guide and the Committee may diverge as circumstances dictate"},"evidence_refs":[{"source_id":"meeting_doc_194076","evidence_id":"meeting_doc_194076#p002_c0007","source_path":"raw/sources/meeting_doc_194076/blocks.jsonl","page_number":2,"block_id":"p002_c0007","text_sha256":"sha256:9f929bf3b66ca3c85350f4976944b632dc1fe56db114f9fc72074871027a1217","text_source":"raw_text","role":"claim_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_9df6ab4f68acabb2","run_id":"2026-06-21T20-51-56-485Z_3137823-75153c6c_ingest_meeting-doc-194076","submitted_at":"2026-06-21T20:59:06.627Z","tool_args_sha256":"sha256:9df6ab4f68acabb2779d13026fbd4285cedd00e6d7a683943c3efe72e82e1f2d","schema_version":2,"tool_args":{"source_id":"meeting_doc_194076","observation_kind":"claim","local_observation_id":"claim_meeting_doc_194076_monitoring_responsibilities","label":"Committee operational monitoring responsibilities","payload":{"claim_text":"To fulfill its purpose, the Committee shall: 1. monitor and update the Board Chair and the Board on the operating performance of Metro-North, including information on railroad service; 2. monitor and update the Board Chair and the Board on the safety record of Metro-North; such monitoring shall include reviewing and monitoring customer and employee safety; 3. monitor and update the Board Chair and the Board on the implementation of security programs pertaining to Metro-North operations and facilities; 4. monitor and update the Board Chair and the Board on the finances of Metro-North, including financial reports, ridership reports, and the use of funds by Metro-North; 5. review and make recommendations to the Board Chair and the Board regarding proposed procurement contracts of Metro-North that require Board approval; 6. review and make recommendations to the Board Chair and the Board on proposed capital projects of Metro-North and monitor the status of such projects.","subject":"Committee on the Operations of the Metro-North Commuter Railroad","description":"Committee monitors operating performance, safety, security, finances, procurement contracts, and capital projects of Metro-North"},"evidence_refs":[{"source_id":"meeting_doc_194076","evidence_id":"meeting_doc_194076#p002_c0009","source_path":"raw/sources/meeting_doc_194076/blocks.jsonl","page_number":2,"block_id":"p002_c0009","text_sha256":"sha256:7c76cd0682ee424e5aa3d22e116735f898c3365964ab26035236655c1e2b893a","text_source":"raw_text","role":"claim_list"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_df52af2253cf8805","run_id":"2026-06-21T20-51-56-485Z_3137823-75153c6c_ingest_meeting-doc-194076","submitted_at":"2026-06-21T20:59:24.534Z","tool_args_sha256":"sha256:df52af2253cf8805102ef20bbbbf179c82db5a1e28cfa50a95d4cc553e48f9c8","schema_version":2,"tool_args":{"source_id":"meeting_doc_194076","observation_kind":"claim","local_observation_id":"claim_meeting_doc_194076_service_policy_responsibilities","label":"Committee service and policy responsibilities","payload":{"claim_text":"7. review and make recommendations to the Board Chair and the Board regarding Metro-North service and policy changes that require Board approval; 8. facilitate the identification of approaches and solutions that address Metro-North security issues, including best practices in national and international security respecting transportation operations and facilities and review and make recommendations to the Board Chair and the Board regarding Metro-North security issues; and 9. review periodically with the Counsel of the MTA, the Chief Compliance Officer, and the Counsel of Metro-North: (i) legal and regulatory matters that may have a material impact on Metro-North; and (ii) the scope and effectiveness of compliance policies and programs.","subject":"Committee on the Operations of the Metro-North Commuter Railroad","description":"Committee reviews service and policy changes, addresses security issues, and reviews legal and compliance matters"},"evidence_refs":[{"source_id":"meeting_doc_194076","evidence_id":"meeting_doc_194076#p003_c0002","source_path":"raw/sources/meeting_doc_194076/blocks.jsonl","page_number":3,"block_id":"p003_c0002","text_sha256":"sha256:25bf16317bab01e78ffd76ecf02932f075ae4bfc574e004a195762c360963989","text_source":"raw_text","role":"claim_list"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_6e2a7f1b6148225b","run_id":"2026-06-21T20-51-56-485Z_3137823-75153c6c_ingest_meeting-doc-194076","submitted_at":"2026-06-21T20:59:38.312Z","tool_args_sha256":"sha256:6e2a7f1b6148225bd36e8388c8a243af54a35b70434f14964c4ae3805c14779b","schema_version":2,"tool_args":{"source_id":"meeting_doc_194076","observation_kind":"claim","local_observation_id":"claim_meeting_doc_194076_mtacc_responsibilities","label":"Committee MTACC capital project responsibilities","payload":{"claim_text":"With respect to capital projects undertaken by the MTA Capital Construction Company (MTACC) on behalf of Metro-North: 1. Review and make recommendations to the Board Chair and Board with respect to the proposed procurements made by the MTACC that require Board approval; 2. Review and make recommendations to the Board Chair and the Board with respect to contract procurement solicitations that require Board approval; 3. Monitor the progress of the capital projects undertaken by the MTACC; 4. Monitor the budget and the schedule of capital projects undertaken by the MTACC; 5. Monitor the progress of contract commitments and completions with respect to capital projects; and 6. Track funding needs of capital projects as well as the availability of funds to meet such needs from all sources of funding.","subject":"Committee on the Operations of the Metro-North Commuter Railroad","description":"Committee reviews MTACC procurements, monitors capital project progress, budget, schedule, contract commitments, and tracks funding needs"},"evidence_refs":[{"source_id":"meeting_doc_194076","evidence_id":"meeting_doc_194076#p003_c0003","source_path":"raw/sources/meeting_doc_194076/blocks.jsonl","page_number":3,"block_id":"p003_c0003","text_sha256":"sha256:ea0883a60ff5ff3820dbf91fbaea7e9d818c8f5a9bc50989e6c74cb1f352537a","text_source":"raw_text","role":"claim_list"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_88b24633d62f43da","run_id":"2026-06-21T20-51-56-485Z_3137823-75153c6c_ingest_meeting-doc-194076","submitted_at":"2026-06-21T20:59:54.150Z","tool_args_sha256":"sha256:88b24633d62f43da9a9ddb944b04fab3369782db5e80d6bf67bd30870510d92c","schema_version":2,"tool_args":{"source_id":"meeting_doc_194076","observation_kind":"claim","local_observation_id":"claim_meeting_doc_194076_additional_responsibilities","label":"Committee additional responsibilities","payload":{"claim_text":"In addition, the Committee shall have the following responsibilities: 1. set the annual work plan for the committee; 2. conduct an annual self-evaluation of the performance of the Committee, including its effectiveness and compliance with this Charter; 3. review and assess the adequacy of this Charter annually; and 4. report regularly to the Board Chair and the Board on Committee findings and recommendations and any other matters the Committee deems appropriate or the Board Chair or the Board requests, and maintain minutes or other records of Committee meetings and activities.","subject":"Committee on the Operations of the Metro-North Commuter Railroad","description":"Committee sets annual work plan, conducts self-evaluation, reviews charter adequacy annually, and reports regularly"},"evidence_refs":[{"source_id":"meeting_doc_194076","evidence_id":"meeting_doc_194076#p003_c0005","source_path":"raw/sources/meeting_doc_194076/blocks.jsonl","page_number":3,"block_id":"p003_c0005","text_sha256":"sha256:92dd95928bb183390c9a9e63d649316fc35666b51503f72e148833320e6d7c49","text_source":"raw_text","role":"claim_list"},{"source_id":"meeting_doc_194076","evidence_id":"meeting_doc_194076#p003_c0006","source_path":"raw/sources/meeting_doc_194076/blocks.jsonl","page_number":3,"block_id":"p003_c0006","text_sha256":"sha256:fdde8956fcaed968f9aae6b4cd5cd63ac100b25171fb78b5d13223d20aaeafc6","text_source":"raw_text","role":"claim_list_continued"}]},"validation":{"state":"accepted","issues":[]}}
