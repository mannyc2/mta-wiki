{"submission_id":"sub_33582080fadc985f","run_id":"2026-06-20T12-13-49-504Z_1885472-1cd00c3e_ingest_meeting-doc-113926","submitted_at":"2026-06-20T12:24:05.939Z","tool_args_sha256":"sha256:33582080fadc985f2fcd267e08df6b4bf1c0d273f4820e2593edbb9e5301e19a","schema_version":2,"tool_args":{"source_id":"meeting_doc_113926","observation_kind":"project","local_observation_id":"project_port_washington_branch_rail_replacement_2023","create_new":true,"label":"Port Washington Branch – Rail Replacement, Track Surfacing","payload":{"project_name":"Port Washington Branch – Rail Replacement, Track Surfacing","project_type":"trackwork","status":"planned","description":"On the weekend of July 8-9, the single main track between Great Neck and Port Washington will be taken out of service for approximately 48-hours while portions of the existing rail are replaced and track surfacing, track welding, and mud spot remediation are performed. Bus service will replace train service for approximately 48-hours.","document_time_status":"planned","project_family":"other"},"evidence_refs":[{"source_id":"meeting_doc_113926","evidence_id":"meeting_doc_113926#p001_c0008","source_path":"raw/sources/meeting_doc_113926/blocks.jsonl","page_number":1,"block_id":"p001_c0008","text_sha256":"sha256:0eb43a50f08b9fe2295020bd22d05771782059606957d45550224fc6799b52e3","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_b00d55a02a0742b2","run_id":"2026-06-20T12-13-49-504Z_1885472-1cd00c3e_ingest_meeting-doc-113926","submitted_at":"2026-06-20T12:24:32.202Z","tool_args_sha256":"sha256:b00d55a02a0742b27213cac68dd309a99ce4dd6d9ab3a634a85cf1ac9d405033","schema_version":2,"tool_args":{"source_id":"meeting_doc_113926","observation_kind":"project","local_observation_id":"project_port_jefferson_branch_concrete_tie_installation_2023","create_new":true,"label":"Port Jefferson Branch – Concrete Tie Installation and Track Maintenance","payload":{"project_name":"Port Jefferson Branch – Concrete Tie Installation and Track Maintenance","project_type":"trackwork","status":"planned","description":"On the weekends of July 15-16, July 22-23, July 29-30, August 5-6, August 12-13, and August 19-20 the single main track between Huntington and Port Jefferson will be taken out of service for approximately 48-hours while new concrete ties are installed, and existing rail is replaced. The LIRR Engineering Department will also be upgrading switches, and performing track welding and surfacing over the 6 weekends. Bus service will replace train service for approximately 48-hours per weekend.","document_time_status":"planned","project_family":"other"},"evidence_refs":[{"source_id":"meeting_doc_113926","evidence_id":"meeting_doc_113926#p001_c0008","source_path":"raw/sources/meeting_doc_113926/blocks.jsonl","page_number":1,"block_id":"p001_c0008","text_sha256":"sha256:0eb43a50f08b9fe2295020bd22d05771782059606957d45550224fc6799b52e3","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
