{"submission_id":"sub_608d56c0308df6c4","run_id":"2026-06-23T15-46-58-805Z_1359573-ecf2547a_ingest_meeting-doc-113511","submitted_at":"2026-06-23T15:48:37.995Z","tool_args_sha256":"sha256:608d56c0308df6c4847af3e906c3fa537845892754490235f8d30f7af28f71e5","schema_version":2,"tool_args":{"source_id":"meeting_doc_113511","observation_kind":"claim","local_observation_id":"claim_meeting_doc_113511_program_description","label":"Fuel Hedging Program Description","payload":{"claim_text":"MTA's fuel hedging program mitigates budget risk by dollar cost averaging approximately 50% of projected fuel expenses. The goal of the program is to be 50% hedged for the next 12 months. Monthly hedges are equal to approximately 4% of the projected fuel purchases expected to occur 13-24 months from each hedge execution date. The actual percentage hedged could be higher or lower than the 50% target depending on the actual levels of fuel consumption. While the fuel hedging program includes compressed natural gas, there are currently no active hedges.","subject":"MTA Fuel Hedging Program","data_type":"program_description","data_type_normalized":{"raw_text":"program_description","normalized_value":"program_description"}},"evidence_refs":[{"source_id":"meeting_doc_113511","evidence_id":"meeting_doc_113511#p001_b0033","source_path":"raw/sources/meeting_doc_113511/blocks.jsonl","page_number":1,"block_id":"p001_b0033","text_sha256":"sha256:4d0a38fe8e1d138097affcf92410d2809da1c95ff1c5cc3499cd770ce9904c22","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
