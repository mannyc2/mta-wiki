{"submission_id":"sub_97fe07ee04e4e272","run_id":"2026-06-23T16-01-43-678Z_1373642-a5e0cd9b_ingest_meeting-doc-189806","submitted_at":"2026-06-23T16:16:13.056Z","tool_args_sha256":"sha256:97fe07ee04e4e27214913b012040db6b599545d0a8b8f587a73de15db45228e7","schema_version":2,"tool_args":{"source_id":"meeting_doc_189806","observation_kind":"claim","local_observation_id":"claim_farebox_recovery_ratio_definition","label":"Farebox Recovery Ratio definition","payload":{"claim_text":"Farebox recovery ratio has a long-term focus. It includes costs that are not funded in the current year, except in an accounting-ledger sense, but are, in effect, passed on to future years; those costs include depreciation and interest on long-term debt. In addition, the recovery ratio allocates centralized MTA services to the Agencies, such as Security, the costs of the Inspector General, Civil Rights, Audit, Risk Management, Legal and Shared Services.","subject":"Farebox recovery ratio"},"evidence_refs":[{"source_id":"meeting_doc_189806","evidence_id":"meeting_doc_189806#p001_b0031","source_path":"raw/sources/meeting_doc_189806/blocks.jsonl","page_number":1,"block_id":"p001_b0031","text_sha256":"sha256:c5ee33600b07c4d09f0281de78293a8b7dd94e4a98068f055b327892136dd924","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_a76837b314a0f6ae","run_id":"2026-06-23T16-01-43-678Z_1373642-a5e0cd9b_ingest_meeting-doc-189806","submitted_at":"2026-06-23T16:16:19.883Z","tool_args_sha256":"sha256:a76837b314a0f6ae22c0b8a4315538f8c95085b4339ab130aea0d0d3b3fc629f","schema_version":2,"tool_args":{"source_id":"meeting_doc_189806","observation_kind":"claim","local_observation_id":"claim_farebox_operating_ratio_definition","label":"Farebox Operating Ratio definition","payload":{"claim_text":"Farebox operating ratio focuses on Agency operating financial performance. It reflects the way MTA meets its statutory and bond-covenant budget-balancing requirements, and it excludes certain costs that are not subject to Agency control, but are provided centrally by the MTA.","subject":"Farebox operating ratio"},"evidence_refs":[{"source_id":"meeting_doc_189806","evidence_id":"meeting_doc_189806#p001_b0032","source_path":"raw/sources/meeting_doc_189806/blocks.jsonl","page_number":1,"block_id":"p001_b0032","text_sha256":"sha256:a0eb5fb38a411feee5505d67036384ab4c9af20e1d1f4f58cd63505846a7d1f7","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_953aabd93348dce0","run_id":"2026-06-23T16-01-43-678Z_1373642-a5e0cd9b_ingest_meeting-doc-189806","submitted_at":"2026-06-23T16:16:25.129Z","tool_args_sha256":"sha256:953aabd93348dce00b2d5cf2461575c474f8c57f418645bfb13d1865d01085e7","schema_version":2,"tool_args":{"source_id":"meeting_doc_189806","observation_kind":"claim","local_observation_id":"claim_lirr_mnr_revised_methodology","label":"LIRR/MNR Revised Methodology note","payload":{"claim_text":"In the agenda materials for the Meeting of the Metro-North and Long Island Rail Road Committees, the calculations of the farebox operating and recovery ratios for the LIRR and MNR use a revised methodology to put the railroads on a more comparable basis. Those statistics, which are included in the respective financial and ridership reports of both Agencies, differ from the statistics presented in this table.","subject":"LIRR and MNR farebox methodology","routes":["LIRR","MNR"]},"evidence_refs":[{"source_id":"meeting_doc_189806","evidence_id":"meeting_doc_189806#p001_b0033","source_path":"raw/sources/meeting_doc_189806/blocks.jsonl","page_number":1,"block_id":"p001_b0033","text_sha256":"sha256:88ba94dc32bdd8238a1e2cdc5ed10f9194b13a62ca2837bd36d63586e02c6490","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[],"warnings":["claim.routes is relation context, not a closed enum or identity key. Route arrays should link to route records when supported. Suggested relation: route has_claim claim when the route endpoint resolves exactly."]}}
