{"submission_id":"sub_42aac4ee955b0196","run_id":"2026-06-08T20-24-28-237Z_3411726-36ca0130_ingest_open-data-plan-2026-update","submitted_at":"2026-06-08T20:26:00.032Z","tool_args_sha256":"sha256:42aac4ee955b01969235747bde71dbf454bebfed010b3a2b3fd58e377a5c8f50","tool_args":{"source_id":"open_data_plan_2026_update","observation_kind":"claim","local_observation_id":"claim_new_datasets_2025_highlights","label":"2025 New Dataset Highlights","raw_text":"Our team published 48 new data assets to New York State's open data portal, in 2025... Below are a few of our favorite releases","payload":{"claim_text":"In 2025 the MTA Open Data team published 48 new data assets including: detailed traffic data (Congestion Relief Zone vehicle entries and vehicle crossings on MTA-owned bridges and tunnels); archived GTFS data with improvements (subway and bus schedules); detailed data on bus automated camera enforcement violations; bolstered service alerts and subway ridership data; source datasets for the new capital dashboard; geospatial datasets (routes/branches and stops/stations) for New York City Transit, LIRR, and Metro-North; granular data on employee availability and overtime; detailed car occupancy estimates for LIRR sourced from load weigh data; first asset inventories from enterprise asset management (EAM)","statement":"2025 new dataset releases","year":2025},"evidence_refs":[{"source_id":"open_data_plan_2026_update","evidence_id":"open_data_plan_2026_update#p003_c0002","source_path":"raw/sources/open_data_plan_2026_update/blocks.jsonl","page_number":3,"block_id":"p003_c0002","text_sha256":"sha256:4b12f6125f3c5c187fb124cdd0db563e5beb35829b0e56afa84dedf4b553be5d","text_source":"raw_text","role":"context"},{"source_id":"open_data_plan_2026_update","evidence_id":"open_data_plan_2026_update#p003_c0003","source_path":"raw/sources/open_data_plan_2026_update/blocks.jsonl","page_number":3,"block_id":"p003_c0003","text_sha256":"sha256:c3afe7601059aaf8731ef0fd994f8d6ccec60247b30b59ca8c