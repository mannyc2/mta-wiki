{"submission_id":"sub_58c937a48360e7b2","run_id":"2026-06-21T18-12-17-823Z_2907661-3e660b85_ingest_meeting-doc-179606","submitted_at":"2026-06-21T18:16:57.146Z","tool_args_sha256":"sha256:58c937a48360e7b246a4e965d5f61188411ef59fa87c7c9a8cf4dd3269da692e","schema_version":2,"tool_args":{"source_id":"meeting_doc_179606","observation_kind":"project","local_observation_id":"project_meeting_doc_179606_bay_ridge_95st_elevators","create_new":true,"label":"Bay Ridge - 95 Street Elevator Project","raw_text":"This month, the MTA was excited to open new elevators at the Bay Ridge – 95 Street terminal station in southern Brooklyn. The project includes two new elevators, one from street level to mezzanine and another from mezzanine to platform, upgraded staircases to enhance passenger circulation, and new ADA boarding areas with platform edges and tactile warning strips. Crews made upgrades to communications and electrical systems and employee facilities, in addition to state of good repair work.","payload":{"project_name":"Bay Ridge - 95 Street Elevator Project","project_type":"elevator installation","status":"completed and opened","borough":"Brooklyn","description":"Two new elevators at Bay Ridge-95 St terminal station on the R line, upgraded staircases, new ADA boarding areas, communications/electrical upgrades, and state of good repair work","document_time_status":"implemented","project_family":"other","borough_normalized":"brooklyn"},"evidence_refs":[{"source_id":"meeting_doc_179606","evidence_id":"meeting_doc_179606#p024_c0005","source_path":"raw/sources/meeting_doc_179606/blocks.jsonl","page_number":24,"block_id":"p024_c0005","text_sha256":"sha256:29aeac15918f5f9684dd9b375b5c1fa279fce8bca31445726370084ea9c89ec3","text_source":"raw_text"},{"source_id":"meeting_doc_179606","evidence_id":"meeting_doc_179606#p024_c0006","source_path":"raw/sources/meeting_doc_179606/blocks.jsonl","page_number":24,"block_id":"p024_c0006","text_sha256":"sha256:95c9bbe588e3dd80881daf202ea873e1f779