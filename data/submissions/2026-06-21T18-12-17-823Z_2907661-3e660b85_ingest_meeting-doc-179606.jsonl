{"submission_id":"sub_b637ab667c506016","run_id":"2026-06-21T18-12-17-823Z_2907661-3e660b85_ingest_meeting-doc-179606","submitted_at":"2026-06-21T18:17:03.959Z","tool_args_sha256":"sha256:b637ab667c50601635008d84caed947dd5c8059ed08dd667f5343e28bd362d8b","schema_version":2,"tool_args":{"source_id":"meeting_doc_179606","observation_kind":"project","local_observation_id":"project_meeting_doc_179606_qbnr","target_record_id":"project_queens-bus-network-redesign","label":"Queens Bus Network Redesign","raw_text":"On June 29, the MTA launched the Queens Bus Network Redesign (QBNR) to improve service in the city's largest borough.","payload":{"project_name":"Queens Bus Network Redesign","project_type":"bus network redesign","status":"launched June 29, 2025","borough":"Queens","description":"Launched Phase 1 in Eastern Queens; Phase 2 in Northwest and Southwest Queens starting August 31","document_time_status":"other","project_family":"bus_network_redesign","borough_normalized":"queens"},"evidence_refs":[{"source_id":"meeting_doc_179606","evidence_id":"meeting_doc_179606#p010_c0011","source_path":"raw/sources/meeting_doc_179606/blocks.jsonl","page_number":10,"block_id":"p010_c0011","text_sha256":"sha256:7d2d2882d81755383626ac134bf5e56af892726183f0992324197961892974e8","text_source":"raw_text"},{"source_id":"meeting_doc_179606","evidence_id":"meeting_doc_179606#p011_c0009","source_path":"raw/sources/meeting_doc_179606/blocks.jsonl","page_number":11,"block_id":"p011_c0009","text_sha256":"sha256:710f5e11241c7bfe24ed54314a4b222c7dcb30f889a432fcb371c8abd3f8988b","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_4880ea2038782f98","run_id":"2026-06-21T18-12-17-823Z_2907661-3e660b85_ingest_meeting-doc-179606","submitted_at":"2026-06-21T18:17:12.931Z","tool_args_sha256":"sha256:4880ea2038782f984b4189b71bc7f232faa2619ba05d8954b7f4289e78a92b53","schema_version":2,"tool_args":{"source_id":"meeting_doc_179606","observation_kind":"project","local_observation_id":"project_meeting_doc_179606_ace","target_record_id":"project_ace-automated-camera-enforcement","label":"Automated Camera Enforcement (ACE) Program","raw_text":"This month marks one year since the expansion of the Automated Camera Enforcement (ACE) program to include not just bus lanes, but also vehicles blocking bus stops and illegally double-parked cars. ACE now covers 39 routes with over 1,200 equipped buses serving 775,000 daily riders.","payload":{"project_name":"Automated Camera Enforcement (ACE) Program","project_type":"enforcement program","status":"expanded","description":"Covers 39 routes with over 1,200 equipped buses serving 775,000 daily riders; includes bus lane, bus stop, and double-parking enforcement","document_time_status":"other","project_family":"enforcement_program"},"evidence_refs":[{"source_id":"meeting_doc_179606","evidence_id":"meeting_doc_179606#p011_c0010","source_path":"raw/sources/meeting_doc_179606/blocks.jsonl","page_number":11,"block_id":"p011_c0010","text_sha256":"sha256:950001a26d224b162e7322a2847132cfa8e50454952969ff943332083c47f98e","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
