{"submission_id":"sub_14f99983ae38caa3","run_id":"2026-06-23T16-01-43-634Z_1373642-f6a72d28_ingest_meeting-doc-160331","submitted_at":"2026-06-23T16:16:58.279Z","tool_args_sha256":"sha256:14f99983ae38caa34332e6ade23f27a0beeb62a96793ddaa5bc438b52eeacbff","schema_version":2,"tool_args":{"source_id":"meeting_doc_160331","observation_kind":"claim","local_observation_id":"claim_meeting_doc_160331_program_description","label":"MTA Fuel Hedging Program description","payload":{"claim_text":"MTA's fuel hedging program mitigates budget risk by dollar cost averaging approximately 50% of projected fuel expenses. The goal of the program is to be 50% hedged for the next 12 months. Monthly hedges are equal to approximately 4% of the projected fuel purchases expected to occur 13-24 months from each hedge execution date. The actual percentage hedged could be higher or lower than the 50% target depending on the actual levels of fuel consumption. While the fuel hedging program includes compressed natural gas, there are currently no active hedges.","statement":"MTA's fuel hedging program mitigates budget risk by dollar cost averaging approximately 50% of projected fuel expenses. The goal of the program is to be 50% hedged for the next 12 months.","subject":"MTA Fuel Hedging Program","data_type":"program_description","data_type_normalized":{"raw_text":"program_description","normalized_value":"program_description"}},"evidence_refs":[{"source_id":"meeting_doc_160331","evidence_id":"meeting_doc_160331#p001_b0033","source_path":"raw/sources/meeting_doc_160331/blocks.jsonl","page_number":1,"block_id":"p001_b0033","text_sha256":"sha256:f9f8a173491325bc61eed9bcff5d0fe8101aeed749a041302f323222ab2db6e4","text_source":"raw_text","role":"program_description"}]},"validation":{"state":"accepted","issues":[],"warnings":["claim.statement is accepted as passthrough, but prefer claim_text. Claim statement."]}}
