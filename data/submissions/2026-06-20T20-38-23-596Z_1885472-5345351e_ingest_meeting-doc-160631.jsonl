{"submission_id":"sub_2da3b2cd0ece266e","run_id":"2026-06-20T20-38-23-596Z_1885472-5345351e_ingest_meeting-doc-160631","submitted_at":"2026-06-20T23:00:27.371Z","tool_args_sha256":"sha256:2da3b2cd0ece266e8331050d8ba32ff04e2bc4a297a6254ad7220dfb355c5b66","schema_version":2,"tool_args":{"source_id":"meeting_doc_160631","observation_kind":"project","local_observation_id":"project_rockaway_line_rehab_resiliency_dec2024","target_record_id":"project_rockaway-line-rehabilitation-resiliency","label":"Rockaway Line Rehabilitation & Resiliency Project","raw_text":"The Rockaway Line Rehabilitation & Resiliency Project invests $393 million to safeguard the bridges and viaducts on the Rockaway Line. Beginning January 2025 and ending May 2025, MTA will reconstruct the elevated Hammels Wye and rehabilitate electrical and mechanical systems on the South Channel Bridge.","payload":{"project_name":"Rockaway Line Rehabilitation & Resiliency Project","description":"Project to reconstruct the elevated Hammels Wye and rehabilitate electrical and mechanical systems on the South Channel Bridge. $393 million investment. Includes a 17-week A Train service outage from January 2025 to May 2025.","project_type":"rehabilitation","borough":"Queens","project_family":"other","borough_normalized":"queens"},"evidence_refs":[{"source_id":"meeting_doc_160631","evidence_id":"meeting_doc_160631#p322_c0005","source_path":"raw/sources/meeting_doc_160631/blocks.jsonl","page_number":322,"block_id":"p322_c0005","text_sha256":"sha256:c63f91f14be170321dec11aca4e76153371167481763c036db32bc08d0252782","text_source":"raw_text"},{"source_id":"meeting_doc_160631","evidence_id":"meeting_doc_160631#p322_c0003","source_path":"raw/sources/meeting_doc_160631/blocks.jsonl","page_number":322,"block_id":"p322_c0003","text_sha256":"sha256:512ca72b2aee441b7bf338109cafecc60df5eeed5a994b5345c22d8a86ee8ddc","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_c767a0f9c652abbf","run_id":"2026-06-20T20-38-23-596Z_1885472-5345351e_ingest_meeting-doc-160631","submitted_at":"2026-06-20T23:00:29.303Z","tool_args_sha256":"sha256:c767a0f9c652abbf909b1d24fe7283c59ed275399bc210c94d6162d9de52bc75","schema_version":2,"tool_args":{"source_id":"meeting_doc_160631","observation_kind":"project","local_observation_id":"project_electric_bus_purchase_charging_infra_dec2024","create_new":true,"label":"Electric Bus Purchase and Charging Infrastructure (Dec 2024)","raw_text":"President Torres-Springer announced that the MTA would immediately exercise the option to purchase 270 electric buses and will proceed with the installation of charging infrastructure at 10 bus depots, keeping MTA on track for the 500 electric buses identified for purchase in the 2020-2024 capital plan.","payload":{"project_name":"Electric Bus Purchase and Charging Infrastructure Installation","description":"Exercise option to purchase 270 electric buses and install charging infrastructure at 10 bus depots, keeping MTA on track for 500 electric buses identified for purchase in the 2020-2024 capital plan.","project_type":"procurement","lead_agency":"MTA Construction and Development","project_family":"other"},"evidence_refs":[{"source_id":"meeting_doc_160631","evidence_id":"meeting_doc_160631#p007_c0005","source_path":"raw/sources/meeting_doc_160631/blocks.jsonl","page_number":7,"block_id":"p007_c0005","text_sha256":"sha256:77dfc8aa5c6853222b99b9e13bd1093d012001a35b537f4bc3b0303ee624bf5e","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[],"warnings":["project.lead_agency is relation context, not a closed enum or identity key. Lead agency is relation context. Suggested relation: implemented_by."]}}
{"submission_id":"sub_3fe400b883e0f09a","run_id":"2026-06-20T20-38-23-596Z_1885472-5345351e_ingest_meeting-doc-160631","submitted_at":"2026-06-20T23:00:31.767Z","tool_args_sha256":"sha256:3fe400b883e0f09a06029bc57ee090cafcedae2f359a5f7e103c2faa3cb662a8","schema_version":2,"tool_args":{"source_id":"meeting_doc_160631","observation_kind":"project","local_observation_id":"project_sas_phase2_dec2024_update","target_record_id":"project_annual-2021-second-ave-subway-phase2","label":"Second Avenue Subway Phase 2 (Dec 2024 Update)","raw_text":"President Torres-Springer announced Second Avenue Subway Phase 2 would be moving forward. The project is still on track to meet the planned revenue service date and will be moving immediately into the major stage of contracting for tunnel construction. The project has also identified $1.3 billion in savings compared to the initial project plan estimate.","payload":{"project_name":"Second Avenue Subway Phase 2","description":"Moving forward with restoration of congestion pricing; on track to meet planned revenue service date; moving immediately into major stage of contracting for tunnel construction; identified $1.3 billion in savings compared to initial project plan estimate.","project_type":"construction","status":"in_progress","boroughs":["Manhattan"],"document_time_status":"other","project_family":"capital_or_infrastructure","boroughs_normalized":["manhattan"]},"evidence_refs":[{"source_id":"meeting_doc_160631","evidence_id":"meeting_doc_160631#p007_c0003","source_path":"raw/sources/meeting_doc_160631/blocks.jsonl","page_number":7,"block_id":"p007_c0003","text_sha256":"sha256:570421861433a453f279395045fdc436b0d10f05e1bbce07817b158741d54cbd","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
