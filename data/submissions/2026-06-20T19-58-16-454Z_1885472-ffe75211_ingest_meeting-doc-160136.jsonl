{"submission_id":"sub_2a4c6eb8520fc71c","run_id":"2026-06-20T19-58-16-454Z_1885472-ffe75211_ingest_meeting-doc-160136","submitted_at":"2026-06-20T20:53:42.192Z","tool_args_sha256":"sha256:2a4c6eb8520fc71cc3facdabf3c665dad7c9b6db0ef9dc3cf83f286366e4db31","schema_version":2,"tool_args":{"source_id":"meeting_doc_160136","observation_kind":"claim","local_observation_id":"claim_meeting_doc_160136_city_no_resources","label":"City does not have resources to shoulder ferry facility lease expense","payload":{"claim_text":"The City does not have the resources to shoulder the expense of the ferry facility property lease.","description":"If Metro-North does not reimburse the City for the expense of leasing the ferry facility lands, the lease will terminate and the Newburgh-Beacon Ferry service will be interrupted."},"evidence_refs":[{"source_id":"meeting_doc_160136","evidence_id":"meeting_doc_160136#p002_c0007","source_path":"raw/sources/meeting_doc_160136/blocks.jsonl","page_number":2,"block_id":"p002_c0007","text_sha256":"sha256:b4a15b8b4a0173de82bf8b7b37c6a206b60b13e083676cfbee9c64084986dc9e","text_source":"raw_text","role":"claim_backing"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_f254b4b01d560f9a","run_id":"2026-06-20T19-58-16-454Z_1885472-ffe75211_ingest_meeting-doc-160136","submitted_at":"2026-06-20T21:02:12.310Z","tool_args_sha256":"sha256:f254b4b01d560f9a775d22af146bf27fd7a13af478f5d064f160fc630699539a","schema_version":2,"tool_args":{"source_id":"meeting_doc_160136","observation_kind":"claim","local_observation_id":"claim_meeting_doc_160136_alternative_termination","label":"Alternative: City would terminate lease without Eleventh MOU","payload":{"claim_text":"If Metro-North does not enter into this Eleventh MOU, then the City would terminate the lease agreement for the Newburgh-Beacon Ferry landing, parking facility, and mooring rights. The likely impact of this action would be interruption of the ferry service while a new site is identified, procured, and any required improvements are constructed."},"evidence_refs":[{"source_id":"meeting_doc_160136","evidence_id":"meeting_doc_160136#p002_c0010","source_path":"raw/sources/meeting_doc_160136/blocks.jsonl","page_number":2,"block_id":"p002_c0010","text_sha256":"sha256:28713cb1c6342e9d557119c0dd59ff2d1dd460554f05de045802573acdc60ed3","text_source":"raw_text","role":"claim_backing"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_fbb09f7f7a38ed29","run_id":"2026-06-20T19-58-16-454Z_1885472-ffe75211_ingest_meeting-doc-160136","submitted_at":"2026-06-20T21:02:48.671Z","tool_args_sha256":"sha256:fbb09f7f7a38ed298f3cc44d2726f9224ad4e32e84c8ecaea1e82c44dd5cb987","schema_version":2,"tool_args":{"source_id":"meeting_doc_160136","observation_kind":"claim","local_observation_id":"claim_meeting_doc_160136_budget_impact_zero_net","label":"Zero net operating budget impact","payload":{"claim_text":"Metro-North applies for reimbursement from NYSDOT as the payments are made to the City of Newburgh. There is a zero net impact on the operating budget."},"evidence_refs":[{"source_id":"meeting_doc_160136","evidence_id":"meeting_doc_160136#p002_c0009","source_path":"raw/sources/meeting_doc_160136/blocks.jsonl","page_number":2,"block_id":"p002_c0009","text_sha256":"sha256:3daa6e710231613cfc188c06ec87f05e298eee9997b2aa2da04a6e44547faf6a","text_source":"raw_text","role":"claim_backing"}]},"validation":{"state":"accepted","issues":[]}}
