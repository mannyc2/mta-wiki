{"submission_id":"sub_3c9cf543fe249577","run_id":"2026-06-21T22-28-39-289Z_3137823-41ac8d45_ingest_meeting-doc-205626","submitted_at":"2026-06-21T22:34:56.978Z","tool_args_sha256":"sha256:3c9cf543fe249577ec4a5c279eedce170a9b967205070c6bb37663fc5467d900","schema_version":2,"tool_args":{"source_id":"meeting_doc_205626","observation_kind":"project","local_observation_id":"project_secure_bike_parking_pilot","create_new":true,"label":"Secure Bike Parking Pilot","payload":{"project_name":"Secure Bike Parking Pilot","project_type":"pilot","status":"modification approved for expansion","description":"Pilot to supply and install secure bicycle parking cages with integrated racks at up to six suburban commuter rail stations in New York State. Contract awarded June 25, 2025 to eLock Technologies LLC through competitive RFP. Initially funded for two stations (Beacon MNR, Amityville LIRR). Modification adds four stations: Mount Vernon East and Irvington (MNR), Lindenhurst and Ronkonkoma (LIRR). Contract term: June 25, 2025 – February 25, 2027. 12-month pilot period upon completion of installation (anticipated July 2026). Total contract value increased from $398,400 to $1,195,200.","document_time_status":"other","project_family":"pilot"},"evidence_refs":[{"source_id":"meeting_doc_205626","evidence_id":"meeting_doc_205626#p005_c0007","source_path":"raw/sources/meeting_doc_205626/blocks.jsonl","page_number":5,"block_id":"p005_c0007","text_sha256":"sha256:5bf68c96cee3b8f3eadd7d5fdca6f902572401ad620cdadd0ef319d28d573a43","text_source":"raw_text"},{"source_id":"meeting_doc_205626","evidence_id":"meeting_doc_205626#p006_c0006","source_path":"raw/sources/meeting_doc_205626/blocks.jsonl","page_number":6,"block_id":"p006_c0006","text_sha256":"sha256:6ab70c87dac4bfb8ea7c8e90d69b360b00fc424b113701b727879a7f6289034f","text_source":"raw_text"},{"source_id":"meeting_doc_205626","evidence_id":"meeting_doc_205626#p006_c0007","source_path":"raw/sources/meeting_doc_205626/blocks.jsonl","page_numbe