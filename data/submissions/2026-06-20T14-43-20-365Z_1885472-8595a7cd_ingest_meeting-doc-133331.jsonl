{"submission_id":"sub_f898103bbf6b0a4c","run_id":"2026-06-20T14-43-20-365Z_1885472-8595a7cd_ingest_meeting-doc-133331","submitted_at":"2026-06-20T15:39:26.849Z","tool_args_sha256":"sha256:f898103bbf6b0a4ce77304dd9c1e44ae62090a89ba157d920916b33eaf35b2ab","schema_version":2,"tool_args":{"source_id":"meeting_doc_133331","observation_kind":"claim","local_observation_id":"claim_branch_adjustments_133331","label":"Babylon, Montauk, Far Rockaway, Atlantic Shuttle, Ronkonkoma/Greenport Adjustments","payload":{"claim_text":"Babylon Branch - One train diverted from GCM to Atlantic Terminal in PM Peak, one train diverted from Penn Station to GCM in PM Peak. Schedule adjustments for midday trackwork between Jamaica and Valley Stream. Montauk Branch - Schedule adjustments midday/weekday for connecting Babylon service. Far Rockaway Branch - One train diverted from Penn Station to GCM, one reverse PM Peak train diverted from GCM to Atlantic Terminal. Atlantic Shuttle - Two trains cancelled, replaced with through service on West Hempstead and Babylon Branches in PM Peak. Weekday overnight service reduced from three to two trains per hour. Ronkonkoma/Greenport Branch - Bus service replaces train service between Ronkonkoma and Greenport weekday/midday for trackwork crossing rehabilitations.","subject":"LIRR branch service adjustments","change_type":"service_change","change_type_normalized":{"raw_text":"service_change","normalized_value":"service_change"}},"evidence_refs":[{"source_id":"meeting_doc_133331","evidence_id":"meeting_doc_133331#p002_c0001","source_path":"raw/sources/meeting_doc_133331/blocks.jsonl","page_number":2,"block_id":"p002_c0001","text_sha256":"sha256:492f6969a3b67e142d1443200dfb9aedfcf79a1e1baf30bd73bfa73a4e8e9093","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
