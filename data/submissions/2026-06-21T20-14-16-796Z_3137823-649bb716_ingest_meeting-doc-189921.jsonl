{"submission_id":"sub_6a97432beffd2c79","run_id":"2026-06-21T20-14-16-796Z_3137823-649bb716_ingest_meeting-doc-189921","submitted_at":"2026-06-21T20:23:32.204Z","tool_args_sha256":"sha256:6a97432beffd2c79f4610307d6427ec40d16ec1c243b097785ac19f9d628f568","schema_version":2,"tool_args":{"source_id":"meeting_doc_189921","observation_kind":"claim","local_observation_id":"claim_meeting_doc_189921_mow_grinding","label":"MOW wheel wear initiative - targeted grinding program","payload":{"claim_text":"Faced with a costly and complex challenge of excessive wheel wear, resulting in millions of dollars in overtime, wheel truing, and replacements; a team from Maintenance of Way (MOW) rose to the occasion with a strategic and effective response. Their solution: a targeted grinding program that was swiftly implemented, resulting in the profiling of 49 curves in under two months.","subject":"Maintenance of Way wheel wear initiative","description":"MOW team led by Robert Hermel, Robert Sarno, Ravi Ganpat, and Edwin Marrero analyzed affected lines and partnered with an outside consultant to pinpoint root causes of accelerated wheel and rail wear, implementing a targeted grinding program that profiled 49 curves in under two months."},"evidence_refs":[{"source_id":"meeting_doc_189921","evidence_id":"meeting_doc_189921#p007_c0003","source_path":"raw/sources/meeting_doc_189921/blocks.jsonl","page_number":7,"block_id":"p007_c0003","text_sha256":"sha256:87f8072d5ca9bea0adba73d985f6e2049de5d2b1e5dda1a036a25ac0f09a132d","text_source":"raw_text"},{"source_id":"meeting_doc_189921","evidence_id":"meeting_doc_189921#p007_c0005","source_path":"raw/sources/meeting_doc_189921/blocks.jsonl","page_number":7,"block_id":"p007_c0005","text_sha256":"sha256:03839fc7779a8fa0bd121bd55afa6fd948b9474a6e8b8b8b54e64a1c88d0ddc5","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
