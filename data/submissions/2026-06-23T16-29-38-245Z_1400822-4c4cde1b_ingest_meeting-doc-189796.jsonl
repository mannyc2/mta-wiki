{"submission_id":"sub_46b9f77ed1727d6b","run_id":"2026-06-23T16-29-38-245Z_1400822-4c4cde1b_ingest_meeting-doc-189796","submitted_at":"2026-06-23T16:38:44.869Z","tool_args_sha256":"sha256:46b9f77ed1727d6b43c8609af81edead361414a125561c97c666a447e1fb71c1","schema_version":2,"tool_args":{"source_id":"meeting_doc_189796","observation_kind":"claim","local_observation_id":"claim_meeting_doc_189796_program_description","label":"Fuel Hedging Program Description","payload":{"claim_text":"MTA's fuel hedging program mitigates budget risk by dollar cost averaging approximately 50% of projected fuel expenses. The goal of the program is to be 50% hedged for the next 12 months. Monthly hedges are equal to approximately 4% of the projected fuel purchases expected to occur 13-24 months from each hedge execution date. The actual percentage hedged could be higher or lower than the 50% target depending on the actual levels of fuel consumption. While the fuel hedging program includes compressed natural gas, there are currently no active hedges."},"evidence_refs":[{"source_id":"meeting_doc_189796","evidence_id":"meeting_doc_189796#p001_b0033","source_path":"raw/sources/meeting_doc_189796/blocks.jsonl","page_number":1,"block_id":"p001_b0033","text_sha256":"sha256:f9f8a173491325bc61eed9bcff5d0fe8101aeed749a041302f323222ab2db6e4","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
