{"submission_id":"sub_606e41f92fba296a","run_id":"2026-06-20T13-35-03-938Z_1885472-be084b14_ingest_meeting-doc-129056","submitted_at":"2026-06-20T14:24:15.178Z","tool_args_sha256":"sha256:606e41f92fba296ad51b29a6b2eaab2f078cbb5e3d50dd0ca86c7a05b9472047","schema_version":2,"tool_args":{"source_id":"meeting_doc_129056","observation_kind":"claim","local_observation_id":"claim_meeting_doc_129056_mrt_escalation","label":"Mortgage Recording Tax escalation payments","raw_text":"By State statute, Dutchess, Orange and Rockland Counties are entitled to a share of MTA's MRT-1 and MRT-2 tax receipts collected in these counties during the prior year.","payload":{"claim_text":"By State statute, Dutchess, Orange and Rockland Counties are entitled to a share of MTA's MRT-1 and MRT-2 tax receipts collected in these counties during the prior year. The amount may be no less than $1.5 million for Dutchess and Orange Counties, and no less than $2.0 million for Rockland County. If the annual amounts collected exceed 1989 collection levels (the statutorily determined base period), proportional upward escalation adjustments are mandated by statute.","data_type":"regulatory requirement","data_type_normalized":{"raw_text":"regulatory requirement","normalized_value":"regulatory_requirement"}},"evidence_refs":[{"source_id":"meeting_doc_129056","evidence_id":"meeting_doc_129056#p003_c0016","source_path":"raw/sources/meeting_doc_129056/blocks.jsonl","page_number":3,"block_id":"p003_c0016","text_sha256":"sha256:222cfe42c5cde1c78889b2a4137821d7aa14dbec948bd2ad45dcdd9a3a3a37ea","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
