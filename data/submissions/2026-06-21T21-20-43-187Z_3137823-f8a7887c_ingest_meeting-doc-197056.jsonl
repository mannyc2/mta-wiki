{"submission_id":"sub_b74f53479e697a5d","run_id":"2026-06-21T21-20-43-187Z_3137823-f8a7887c_ingest_meeting-doc-197056","submitted_at":"2026-06-21T21:27:01.324Z","tool_args_sha256":"sha256:b74f53479e697a5dcdf1f29d15040af66b4eac8af6fca9db112bf51a448c5180","schema_version":2,"tool_args":{"source_id":"meeting_doc_197056","observation_kind":"claim","local_observation_id":"claim_farebox_variance_nyct_mta_bus","label":"Farebox revenue variance attribution","payload":{"claim_text":"NYCT and MTA Bus were unfavorable by $22.8M and $5.3M, respectively, mainly due to lower paid bus ridership. These results were partially offset by a favorable variance of $3.3M at MNR, mainly due to higher ridership and higher average fare.","data_type":"variance_explanation","change_type":"unfavorable","routes":["NYCT","MTA Bus","MNR"],"data_type_normalized":{"raw_text":"variance_explanation","normalized_value":"variance_explanation"},"change_type_normalized":{"raw_text":"unfavorable","normalized_value":"unfavorable"}},"evidence_refs":[{"source_id":"meeting_doc_197056","evidence_id":"meeting_doc_197056#p003_c0002","source_path":"raw/sources/meeting_doc_197056/blocks.jsonl","page_number":3,"block_id":"p003_c0002","text_sha256":"sha256:ad2ea8a50acf3a85440d70bcde9bab90714dd9f560982dc0d78c5cb9f7ac679e","text_source":"raw_text","source_quote":"NYCT and MTA Bus were unfavorable by $22.8M and $5.3M, respectively, mainly due to lower paid bus ridership. These results were partially offset by a favorable variance of $3.3M at MNR, mainly due to higher ridership and higher average fare."}]},"validation":{"state":"accepted","issues":[],"warnings":["claim.routes is relation context, not a closed enum or identity key. Route arrays should link to route records when supported. Suggested relation: route has_claim claim when the route endpoint resolves exactly."]}}
{"submission_id":"sub_d3a3e6e77d886393","run_id":"2026-06-21T21-20-43-187Z_3137823-f8a7887c_ingest_meeting-doc-197056","submitted_at":"2026-06-21T21:27:12.621Z","tool_args_sha256":"sha256:d3a3e6e77d8863936087d492677b8f6d324560f57c53ec919f870eff60191ad1","schema_version":2,"tool_args":{"source_id":"meeting_doc_197056","observation_kind":"claim","local_observation_id":"claim_claims_var_actuarial","label":"Claims adverse variance due to actuarial adjustments","payload":{"claim_text":"NYCT, MTA Bus, FMTAC, and the LIRR were unfavorable by $357M, $107.8M, $93.1M, and $10.4M, respectively, mainly due to actuarial adjustments of loss reserves. MNR was unfavorable by $1.9M mainly due to a higher passenger claims provision.","data_type":"variance_explanation","change_type":"unfavorable","routes":["NYCT","MTA Bus","FMTAC","LIRR","MNR"],"data_type_normalized":{"raw_text":"variance_explanation","normalized_value":"variance_explanation"},"change_type_normalized":{"raw_text":"unfavorable","normalized_value":"unfavorable"}},"evidence_refs":[{"source_id":"meeting_doc_197056","evidence_id":"meeting_doc_197056#p004_c0005","source_path":"raw/sources/meeting_doc_197056/blocks.jsonl","page_number":4,"block_id":"p004_c0005","text_sha256":"sha256:d3212365c7fb0d4e88417b660a166e73ad74055aaadd9cdf3335b0b49caa9c7e","text_source":"raw_text","source_quote":"Claims NR (569.2) * NYCT, MTA Bus, FMTAC, and the LIRR were unfavorable by $357M, $107.8M, $93.1M, and $10.4M, respectively, mainly due to actuarial adjustments of loss reserves. MNR was unfavorable by $1.9M mainly due to a higher passenger claims provision."}]},"validation":{"state":"accepted","issues":[],"warnings":["claim.routes is relation context, not a closed enum or identity key. Route arrays should link to route records when supported. Suggested relation: route has_claim claim when the route endpoint resolves exactly."]}}
{"submission_id":"sub_7dd9f736cbe462f2","run_id":"2026-06-21T21-20-43-187Z_3137823-f8a7887c_ingest_meeting-doc-197056","submitted_at":"2026-06-21T21:27:23.297Z","tool_args_sha256":"sha256:7dd9f736cbe462f220c9e8237ee9e6f82d1de059d6fc1290b345915f9f8a5029","schema_version":2,"tool_args":{"source_id":"meeting_doc_197056","observation_kind":"claim","local_observation_id":"claim_payroll_var_vacancies","label":"Payroll favorable variance attribution","payload":{"claim_text":"NYCT was favorable by $66.3M mainly due to vacancies. The LIRR was favorable by $16.4M mainly due to lower average pay rates reflecting new hires. MNR was favorable by $13.2M, mainly due to lump-sum contractual payments, the impact of retroactive wage accruals from contract settlements, and net hiring and attrition, and SIR was favorable by $2.6M, mainly due to timing. These results were partially offset by unfavorable variances of $9.6M at B&T, mainly due to payments for MTA C&D engineers working on operating projects and allocation mix between non-reimbursable and reimbursable expenses, and $1.9M at MTA HQ, mainly due to accounting for unbudgeted compensated absences.","data_type":"variance_explanation","change_type":"favorable","data_type_normalized":{"raw_text":"variance_explanation","normalized_value":"variance_explanation"},"change_type_normalized":{"raw_text":"favorable","normalized_value":"favorable"}},"evidence_refs":[{"source_id":"meeting_doc_197056","evidence_id":"meeting_doc_197056#p003_c0002","source_path":"raw/sources/meeting_doc_197056/blocks.jsonl","page_number":3,"block_id":"p003_c0002","text_sha256":"sha256:ad2ea8a50acf3a85440d70bcde9bab90714dd9f560982dc0d78c5cb9f7ac679e","text_source":"raw_text","source_quote":"Payroll NR 86.7 1.4 NYCT was favorable by $66.3M mainly due to vacancies. The LIRR was favorable by $16.4M mainly due to lower average pay rates reflecting new hires."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_0f7e6c969c948af4","run_id":"2026-06-21T21-20-43-187Z_3137823-f8a7887c_ingest_meeting-doc-197056","submitted_at":"2026-06-21T21:27:32.608Z","tool_args_sha256":"sha256:0f7e6c969c948af4c3e536b1442a2f0c30927dc363268d997aea4ca865640da0","schema_version":2,"tool_args":{"source_id":"meeting_doc_197056","observation_kind":"claim","local_observation_id":"claim_overtime_var_absentee","label":"Overtime favorable variance attribution","payload":{"claim_text":"NYCT was favorable by $79.9M mainly due to lower absentee coverage requirements, partially offset by unfavorable outcomes resulting from overruns totaling $8.5M at MTA HQ mainly due to MTA PD and MTA IT requirements and vacancy/absentee coverage; $2.0M at B&T, mainly due to higher attrition and absentee coverage, and $1.3M at MTA Bus mainly due to maintenance vacancies and absentee coverage.","data_type":"variance_explanation","change_type":"favorable","data_type_normalized":{"raw_text":"variance_explanation","normalized_value":"variance_explanation"},"change_type_normalized":{"raw_text":"favorable","normalized_value":"favorable"}},"evidence_refs":[{"source_id":"meeting_doc_197056","evidence_id":"meeting_doc_197056#p003_c0002","source_path":"raw/sources/meeting_doc_197056/blocks.jsonl","page_number":3,"block_id":"p003_c0002","text_sha256":"sha256:ad2ea8a50acf3a85440d70bcde9bab90714dd9f560982dc0d78c5cb9f7ac679e","text_source":"raw_text","source_quote":"Overtime NR 67.3 5.5 NYCT was favorable by $79.9M mainly due to lower absentee coverage requirements, partially offset by unfavorable outcomes resulting from overruns totaling $8.5M at MTA HQ mainly due to MTA PD and MTA IT requirements"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_17ddfbbcc81edb1e","run_id":"2026-06-21T21-20-43-187Z_3137823-f8a7887c_ingest_meeting-doc-197056","submitted_at":"2026-06-21T21:27:40.316Z","tool_args_sha256":"sha256:17ddfbbcc81edb1e4ed097822a195fd78fd2eba52e3a6687940296f2ed145601","schema_version":2,"tool_args":{"source_id":"meeting_doc_197056","observation_kind":"claim","local_observation_id":"claim_subsidies_var_detail","label":"Subsidies favorable variance detail","payload":{"claim_text":"The favorable variance mainly reflects: PMT of $187.3M; Urban Tax of $48.7M; Investment Income of $32.2M; MRT of $25.8M; Automated Camera Enforcement of $15.0M; MTA Aid of $6.4M; and MTTF of $4.0M; FHV of $1.4M, all due to better-than-expected receipts, as well as a favorable timing variance for Casino Licenses and Gaming Tax Revenues which were favorable by $500 million due to timing of the first casino license fee not anticipated to be received until 2026; Station Maintenance of $6.2M; and SIR Subsidy of $1.2M. Partially offsetting these were unfavorable timing variances for City Subsidy for MTA Bus of $145.6M and CDOT of $11.4M.","data_type":"variance_explanation","change_type":"favorable","data_type_normalized":{"raw_text":"variance_explanation","normalized_value":"variance_explanation"},"change_type_normalized":{"raw_text":"favorable","normalized_value":"favorable"}},"evidence_refs":[{"source_id":"meeting_doc_197056","evidence_id":"meeting_doc_197056#p007_c0003","source_path":"raw/sources/meeting_doc_197056/blocks.jsonl","page_number":7,"block_id":"p007_c0003","text_sha256":"sha256:1bf74b93634f4a3c99b60372e3705cfe8fb6740b4c11f61a0a7cc1c926c40374","text_source":"raw_text","source_quote":"Subsidies NR 671.4 6.4 The favorable variance mainly reflects: PMT of $187.3M; Urban Tax of $48.7M; Investment Income of $32.2M; MRT of $25.8M; Automated Camera Enforcement of $15.0M"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_2d69710d2a93e513","run_id":"2026-06-21T21-20-43-187Z_3137823-f8a7887c_ingest_meeting-doc-197056","submitted_at":"2026-06-21T21:27:50.951Z","tool_args_sha256":"sha256:2d69710d2a93e51351278ca9d0cb694f83cfd69533a38d192660dedad90dd763","schema_version":2,"tool_args":{"source_id":"meeting_doc_197056","observation_kind":"claim","local_observation_id":"claim_debt_service_var","label":"Debt Service favorable variance attribution","payload":{"claim_text":"Year-to-Date Operating Budget Debt Service expenses were $2,416.7 million, which was $27.1 million or 1.1% favorable, primarily due to savings from lower-than-budgeted variable rate debt service and investment income.","data_type":"variance_explanation","change_type":"favorable","data_type_normalized":{"raw_text":"variance_explanation","normalized_value":"variance_explanation"},"change_type_normalized":{"raw_text":"favorable","normalized_value":"favorable"}},"evidence_refs":[{"source_id":"meeting_doc_197056","evidence_id":"meeting_doc_197056#p007_c0003","source_path":"raw/sources/meeting_doc_197056/blocks.jsonl","page_number":7,"block_id":"p007_c0003","text_sha256":"sha256:1bf74b93634f4a3c99b60372e3705cfe8fb6740b4c11f61a0a7cc1c926c40374","text_source":"raw_text","source_quote":"Debt Service NR 27.1 1.1 Year-to-Date Operating Budget Debt Service expenses were $2,416.7 million, which was $27.1 million or 1.1% favorable, primarily due to savings from lower-than-budgeted variable rate debt service and investment income."}]},"validation":{"state":"accepted","issues":[]}}
