{"submission_id":"sub_93e0a7fbcfd99535","run_id":"2026-06-20T17-16-34-875Z_1885472-0aba9512_ingest_meeting-doc-143201","submitted_at":"2026-06-20T22:40:21.108Z","tool_args_sha256":"sha256:93e0a7fbcfd99535a710d5c5c87c6599c9a2c5e09cfd66db978e545228004bad","schema_version":2,"tool_args":{"source_id":"meeting_doc_143201","observation_kind":"project","local_observation_id":"project_pj_switch_install_track_maint_2024","create_new":true,"label":"Port Jefferson Branch Switch Installation and Track Maintenance","raw_text":"Port Jefferson Branch – Switch Installation and Track Maintenance – On the weekends of June 29-30, July 13-14, July 20-21, July 27-28, and August 3-4, both main tracks between Hicksville and Port Jefferson will be taken out of service for a period of approximately 48-hours to support a series of switch installations, as well as rail replacement and bridge maintenance at various locations on the Port Jefferson Branch.","payload":{"project_name":"Port Jefferson Branch Switch Installation and Track Maintenance","project_type":"Track Maintenance","status":"Planned","description":"Switch installations, rail replacement and bridge maintenance on the Port Jefferson Branch between Hicksville and Port Jefferson, with bus service replacing train service on weekends","routes_served":["Port Jefferson Branch"],"document_time_status":"planned","project_family":"other"},"evidence_refs":[{"source_id":"meeting_doc_143201","evidence_id":"meeting_doc_143201#p001_c0007","source_path":"raw/sources/meeting_doc_143201/blocks.jsonl","page_number":1,"block_id":"p001_c0007","text_sha256":"sha256:0cfe2344de62f7fabe59c88df2f86444d854958f4ac315a2fefbdce0c404e27c","text_source":"raw_text","role":"primary"}]},"validation":{"state":"accepted","issues":[],"warnings":["project.routes_served is relation context, not a closed enum or identity key. Route lists should become project-route relations when supported. Suggested relation: serves_route."]}}
