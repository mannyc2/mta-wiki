{"submission_id":"sub_27c8c9bc55a5fd16","run_id":"2026-06-21T17-36-32-402Z_2907661-06ee7e2d_ingest_meeting-doc-173986","submitted_at":"2026-06-21T17:45:23.380Z","tool_args_sha256":"sha256:27c8c9bc55a5fd166c5626d14cba2af071b30f4791068549ea4b61a4b1beebf2","schema_version":2,"tool_args":{"source_id":"meeting_doc_173986","observation_kind":"project","local_observation_id":"project_meeting_doc_173986_bmt_traction_power","target_record_id":"project_bmt-traction-power-upgrade","label":"BMT Traction Power Control System Upgrade","raw_text":"The project will improve reliability and operation of the existing BMT traction power control system and provide redundancy in case of failure.","payload":{"project_name":"BMT Traction Power Control System Upgrade","status":"approximately 98% complete","description":"Replace antiquated Master Terminal Units at Power Control Center with touchscreen LED monitors and a state-of-the-art video wall and construct a new Emergency Backup Power Control Center. Work at 13 power substations, 14 communications rooms, and the Power Control Center.","document_time_status":"other"},"evidence_refs":[{"source_id":"meeting_doc_173986","evidence_id":"meeting_doc_173986#p020_c0004","source_path":"raw/sources/meeting_doc_173986/blocks.jsonl","page_number":20,"block_id":"p020_c0004","text_sha256":"sha256:8f8b1ade53a950f3263c1405fd30334b35c39d64026ebb26f3648a6e0f30ecd9","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
