{"submission_id":"sub_010a4db57bc4f865","run_id":"2026-06-21T18-16-05-902Z_2907661-90636cc9_ingest_meeting-doc-179686","submitted_at":"2026-06-21T18:21:12.326Z","tool_args_sha256":"sha256:010a4db57bc4f86528976ea7ccea3346ab6ed6fd704a8dfd64ea8d18f4c42e4f","schema_version":2,"tool_args":{"source_id":"meeting_doc_179686","observation_kind":"claim","local_observation_id":"claim_meeting_doc_179686_fine_change","label":"Fare evasion fine structure amendment effective January 1, 2025","payload":{"claim_text":"Prior to January 2025, the fine for all incidences of fare evasion on subways and buses was $100. Effective January 1, 2025, the New York Public Authorities Law governing fines related to fare evasion was amended. Fines for fare evasion are now based on the number of violations committed during a four-year period.","change_type":"change","description":"Amendment to fine structure for fare evasion violations","change_type_normalized":{"raw_text":"change","normalized_value":"change"}},"evidence_refs":[{"source_id":"meeting_doc_179686","evidence_id":"meeting_doc_179686#p002_c0002","source_path":"raw/sources/meeting_doc_179686/blocks.jsonl","page_number":2,"block_id":"p002_c0002","text_sha256":"sha256:6e1e972dc36216d50296549086ebb4f6f3fc57c929b146276d0da000d9f7f365","text_source":"raw_text","source_quote":"Prior to January 2025, the fine for all incidences of fare evasion on subways and buses was $100. Effective January 1, 2025, the New York Public Authorities Law governing fines related to fare evasion was amended."}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_205336f7bb1d6e9a","run_id":"2026-06-21T18-16-05-902Z_2907661-90636cc9_ingest_meeting-doc-179686","submitted_at":"2026-06-21T18:21:15.929Z","tool_args_sha256":"sha256:205336f7bb1d6e9ad85b48213096104397fbeec474138b9fe91b2ea1c97deb95","schema_version":2,"tool_args":{"source_id":"meeting_doc_179686","observation_kind":"claim","local_observation_id":"claim_meeting_doc_179686_fine_tiers","label":"Fare evasion fine tiers","payload":{"claim_text":"First offense: warning, no fine. Second offense: $100 fine, $50 OMNY credit if fine is paid on time in full (or, for participants in the Fair Fares NYC program, $50 fine, $25 OMNY credit). Third offense and up: $150 fine (or criminal violation) (or, for participants in the Fair Fares NYC program, $75 fine).","description":"New fare evasion fine tiers based on number of violations during a four-year period"},"evidence_refs":[{"source_id":"meeting_doc_179686","evidence_id":"meeting_doc_179686#p002_c0003","source_path":"raw/sources/meeting_doc_179686/blocks.jsonl","page_number":2,"block_id":"p002_c0003","text_sha256":"sha256:9e625172d45f0c1daf7a12410ad0180f68f82c2216f6d27cb11f5956ebf5da91","text_source":"raw_text","source_quote":"First offense: warning, no fine • Second offense: $100 fine, $50 OMNY credit if fine is paid on time in full (or, for participants in the Fair Fares NYC program, $50 fine, $25 OMNY credit) • Third offense and up: $150 fine (or criminal violation) (or, for participants in the Fair Fares NYC program, $75 fine)"}]},"validation":{"state":"rejected","issues":["evidence_refs[0].source_quote must be 280 characters or fewer"]}}
