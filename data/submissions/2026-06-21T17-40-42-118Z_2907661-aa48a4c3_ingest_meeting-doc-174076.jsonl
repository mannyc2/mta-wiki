{"submission_id":"sub_f0831f50f19c074e","run_id":"2026-06-21T17-40-42-118Z_2907661-aa48a4c3_ingest_meeting-doc-174076","submitted_at":"2026-06-21T17:50:42.148Z","tool_args_sha256":"sha256:f0831f50f19c074e6f993e8bb768850727a4677b642abecb4d384b12995d275a","schema_version":2,"tool_args":{"source_id":"meeting_doc_174076","observation_kind":"claim","local_observation_id":"claim_meeting_doc_174076_promotional_transfer_policy","label":"Promotional transfer policy for Queens bus riders","raw_text":"the MTA is proposing this promotional free transfer policy to allow Queens bus riders tapping with OMNY one additional free bus transfer within a three-hour period from the time of the initial paid tap. The existing transfer window of two hours will remain. Additionally, the existing restrictions on the use of free transfers will remain to minimize the opportunity for round-trip travel (e.g., the restriction on using the free transfer for travel on the same bus route).","payload":{"claim_text":"The MTA is proposing a promotional free transfer policy to allow Queens bus riders tapping with OMNY one additional free bus transfer within a three-hour period from the time of the initial paid tap. The existing transfer window of two hours will remain.","subject":"Promotional Transfer Policy","description":"Promotional free transfer policy for Queens bus riders tapping with OMNY - one additional free bus transfer within three hours"},"evidence_refs":[{"source_id":"meeting_doc_174076","evidence_id":"meeting_doc_174076#p002_c0003","source_path":"raw/sources/meeting_doc_174076/blocks.jsonl","page_number":2,"block_id":"p002_c0003","text_sha256":"sha256:40387734209b4e986b74fc7169e6075caf24fea7aa800a45e375a04c51a445ca","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
