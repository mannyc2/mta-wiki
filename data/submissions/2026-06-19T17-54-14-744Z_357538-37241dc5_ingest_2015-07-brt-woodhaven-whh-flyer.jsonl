{"submission_id":"sub_cbb3762dcf835397","run_id":"2026-06-19T17-54-14-744Z_357538-37241dc5_ingest_2015-07-brt-woodhaven-whh-flyer","submitted_at":"2026-06-19T17:56:43.045Z","tool_args_sha256":"sha256:cbb3762dcf835397c7c7bf73904750fbfa2d3ebebafb20e86eb15091d1a7f357","schema_version":2,"tool_args":{"source_id":"2015_07_brt_woodhaven_whh_flyer","observation_kind":"treatment_component","local_observation_id":"treatment_offset_bus_lanes_woodhaven_blvd_2015","label":"Offset bus lanes on Woodhaven Boulevard","payload":{"treatment_kind":"offset bus lane","description":"Offset (one lane away from the curb) bus lanes on Woodhaven Boulevard between Dry Harbor Road to Metropolitan Avenue. Bus lanes will be in effect Monday through Friday from 7-10 AM and from 4-7 PM. Vehicles can enter or cross over a bus lane to make right turns, access a curb cut or driveway within 200', enter a parking space, or to quickly drop-off or pick up passengers. Parking will remain at the curb with the same regulations as existing.","location_text":"Woodhaven Boulevard between Dry Harbor Road to Metropolitan Avenue","date_text":"Mid-July 2015","treatment_family":"bus_lane","date_text_normalized":{"raw_text":"Mid-July 2015","normalized_date":"2015-07","precision":"month","confidence":"parsed_text"},"normalized_location":{"raw_text":"Woodhaven Boulevard between Dry Harbor Road to Metropolitan Avenue"}},"evidence_refs":[{"source_id":"2015_07_brt_woodhaven_whh_flyer","evidence_id":"2015_07_brt_woodhaven_whh_flyer#p001_c0007","source_path":"raw/sources/2015_07_brt_woodhaven_whh_flyer/blocks.jsonl","page_number":1,"block_id":"p001_c0007","text_sha256":"sha256:0031339213fa68cae794c6a97f2f7ca1cffd6e01f438048a5e7f00a2df4af04f","text_source":"raw_text","source_quote":"DOT will implement offset (one lane away from the curb) bus lanes on Woodhaven Boulevard between Dry Harbor Road to Metropolitan Avenue:"},{"source_id":"2015_07_brt_woodhaven_whh_flyer","evidence_id":"2015_07_brt_woodhaven_whh_flyer#p001_c0008","source_path":"raw/sources/2015_07_brt_woodhaven_whh_flyer/blocks.jsonl","page_number":1,"block_id":"p001_c0008","text_sha256":"sha256:20b3385bf44af1d3aee6bdd3440f02fb3c97d1a15171904792f11b1d132cda33","text_source":"raw_text","source_quote":"▪ Bus lanes will be in effect Monday through Friday from 7-10 AM and from 4-7 PM ▪ Bus lanes will improve bus travel times and reliability for the 30,000 daily bus riders on this corridor ▪ Parking will remain at the curb with the same regulations as existing ▪ Vehicles can enter or cross over a bus lane to make right turns, access a curb cut or driveway within 200', enter a parking space, or to quickly drop-off or pick up passengers"},{"source_id":"2015_07_brt_woodhaven_whh_flyer","evidence_id":"2015_07_brt_woodhaven_whh_flyer#p001_c0009","source_path":"raw/sources/2015_07_brt_woodhaven_whh_flyer/blocks.jsonl","page_number":1,"block_id":"p001_c0009","text_sha256":"sha256:3c3d1ba22a2cb0e1da45f8a2a2aa7cbb81e7efabfc6f81bf7307e56220ccdc6b","text_source":"raw_text","source_quote":"Implementation begins Mid-July"}]},"validation":{"state":"rejected","issues":["evidence_refs[1].source_quote must be 280 characters or fewer"]}}
