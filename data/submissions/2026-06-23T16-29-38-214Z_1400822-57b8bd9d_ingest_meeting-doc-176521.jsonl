{"submission_id":"sub_47cb1a49843356ce","run_id":"2026-06-23T16-29-38-214Z_1400822-57b8bd9d_ingest_meeting-doc-176521","submitted_at":"2026-06-23T16:33:39.793Z","tool_args_sha256":"sha256:47cb1a49843356cedb50dc40559ae17bcac579571b553c66155562666235d983","schema_version":2,"tool_args":{"source_id":"meeting_doc_176521","observation_kind":"claim","local_observation_id":"claim_meeting_doc_176521_program_description","label":"Fuel hedging program description","payload":{"claim_text":"MTA's fuel hedging program mitigates budget risk by dollar cost averaging approximately 50% of projected fuel expenses. The goal of the program is to be 50% hedged for the next 12 months. Monthly hedges are equal to approximately 4% of the projected fuel purchases expected to occur 13-24 months from each hedge execution date. The actual percentage hedged could be higher or lower than the 50% target depending on the actual levels of fuel consumption. While the fuel hedging program includes compressed natural gas, there are currently no active hedges.","subject":"MTA Fuel Hedging Program","data_type":"program_description","data_type_normalized":{"raw_text":"program_description","normalized_value":"program_description"}},"evidence_refs":[{"source_id":"meeting_doc_176521","evidence_id":"meeting_doc_176521#p001_b0033","source_path":"raw/sources/meeting_doc_176521/blocks.jsonl","page_number":1,"block_id":"p001_b0033","text_sha256":"sha256:f9f8a173491325bc61eed9bcff5d0fe8101aeed749a041302f323222ab2db6e4","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
