{"submission_id":"sub_2f9492629e959cdc","run_id":"2026-06-20T12-42-56-610Z_1885472-db60d070_ingest_meeting-doc-124141","submitted_at":"2026-06-20T13:51:04.909Z","tool_args_sha256":"sha256:2f9492629e959cdcdd25d88dd6095253d961e0195079cadfdc863f1efc8f595e","schema_version":2,"tool_args":{"source_id":"meeting_doc_124141","observation_kind":"claim","local_observation_id":"claim_mdoc124141_monthly_passenger_revenue_variance","label":"September Monthly Passenger Revenue Variance","raw_text":"Passenger revenue was unfavorable by ($7.8M) at NYCT mainly due to the LIRR, MNR and MTA Bus. MNR was unfavorable by ($9.9M) and ($0.5M), respectively, mainly due to lower yields. These results were partially offset by a favorable variance of $3.5M at MNR, mainly due to higher ridership.","payload":{"claim_text":"Passenger revenue was unfavorable by ($7.8M) at NYCT mainly due to the LIRR, MNR and MTA Bus. MNR was unfavorable by ($9.9M) and ($0.5M), respectively, mainly due to lower yields. These results were partially offset by a favorable variance of $3.5M at MNR, mainly due to higher ridership.","change_type":"unfavorable","extra_fields":{"subject":"Passenger Revenue","location":"NYCT, MNR","period":"September 2023 monthly"},"change_type_normalized":{"raw_text":"unfavorable","normalized_value":"unfavorable"}},"evidence_refs":[{"source_id":"meeting_doc_124141","evidence_id":"meeting_doc_124141#p003_c0005","source_path":"raw/sources/meeting_doc_124141/blocks.jsonl","page_number":3,"block_id":"p003_c0005","text_sha256":"sha256:a1413cb9247863736980a17d6dbb8020af8ccf739898a1dec2dba22c2189d0c7","text_source":"raw_text","source_quote":"Passenger revenue was unfavorable by ($7.8M) at NYCT mainly due to the LIRR, MNR and MTA Bus. MNR was unfavorable by ($9.9M) and ($0.5M), respectively, mainly due to lower yields. These results were partially offset by a favorable variance of $3.5M at MNR, mainly due to higher ridership."}]},"validation":{"state":"rejected","issues":["evidence_refs[0].source_quote must be 280 characters or fewer"]}}
