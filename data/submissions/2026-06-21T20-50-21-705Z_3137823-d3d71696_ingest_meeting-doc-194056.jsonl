{"submission_id":"sub_6f09d14fcb40dee7","run_id":"2026-06-21T20-50-21-705Z_3137823-d3d71696_ingest_meeting-doc-194056","submitted_at":"2026-06-21T21:00:30.018Z","tool_args_sha256":"sha256:6f09d14fcb40dee7f84d86bacc07f801d0ee548daf72d244a6c1ebd61950e929","schema_version":2,"tool_args":{"source_id":"meeting_doc_194056","observation_kind":"claim","local_observation_id":"claim_main_line_station_bypasses_jan2026","label":"Main Line service adjustment - station bypasses","payload":{"claim_text":"With the eastbound local track out of service between Jamaica and Floral Park, eastbound trains will bypass scheduled stops at Hollis, Queens Village, and Elmont–UBS Arena. Additionally, schedule adjustments will be required on the Hempstead Branch. NYCT bus will cross honor LIRR fares at Hollis and Queens Village and customers travelling to/from Elmont-UBS Arena are encouraged to use nearby Bellerose Station as an alternative.","subject":"Main Line track work service adjustments"},"evidence_refs":[{"source_id":"meeting_doc_194056","evidence_id":"meeting_doc_194056#p002_c0007","source_path":"raw/sources/meeting_doc_194056/blocks.jsonl","page_number":2,"block_id":"p002_c0007","text_sha256":"sha256:464abbf88975e7d77a28be8d374d92936fe26c1c5c4a452c7e95e722633504dc","text_source":"raw_text","role":"context"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_3527e860bcbce665","run_id":"2026-06-21T20-50-21-705Z_3137823-d3d71696_ingest_meeting-doc-194056","submitted_at":"2026-06-21T21:00:44.495Z","tool_args_sha256":"sha256:3527e860bcbce6655272e76112b9c987b908f14518bd7e7b3f3c649371230a17","schema_version":2,"tool_args":{"source_id":"meeting_doc_194056","observation_kind":"claim","local_observation_id":"claim_atlantic_branch_no_service_jan2026","label":"Atlantic Branch service adjustment - no train service","payload":{"claim_text":"With all tracks out of service between Jamaica and Atlantic Terminal, there will be no LIRR train service to East New York, Nostrand Avenue or Atlantic Terminal. NYCT will honor LIRR fares in both directions.","subject":"Atlantic Branch track work service adjustments"},"evidence_refs":[{"source_id":"meeting_doc_194056","evidence_id":"meeting_doc_194056#p003_c0001","source_path":"raw/sources/meeting_doc_194056/blocks.jsonl","page_number":3,"block_id":"p003_c0001","text_sha256":"sha256:392bf536c2fb805fac4f796d4b17ff7d53729225fb932d300368ff98d5abb1fc","text_source":"raw_text","role":"context"}]},"validation":{"state":"accepted","issues":[]}}
