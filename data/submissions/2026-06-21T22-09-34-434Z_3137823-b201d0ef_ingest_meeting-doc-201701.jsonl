{"submission_id":"sub_d272d498044a03a3","run_id":"2026-06-21T22-09-34-434Z_3137823-b201d0ef_ingest_meeting-doc-201701","submitted_at":"2026-06-21T22:18:55.932Z","tool_args_sha256":"sha256:d272d498044a03a3c27ba7c9da253298fc3748ec678aa56408b05d1888c44221","schema_version":2,"tool_args":{"source_id":"meeting_doc_201701","observation_kind":"claim","local_observation_id":"claim_prompt_payment_30_days","payload":{"claim_text":"The Prompt Payment Legislation, implemented in April 1988 requires that the Authority must pay amounts due under its contracts within 30 days of the receipt of a proper invoice or the receipt of the goods or services, whichever is later.","subject":"Prompt Payment Legislation","change_type":"requirement","description":"30-day payment requirement under NYS Prompt Payment Legislation","change_type_normalized":{"raw_text":"requirement","normalized_value":"requirement"}},"evidence_refs":[{"source_id":"meeting_doc_201701","evidence_id":"meeting_doc_201701#p001_c0010","source_path":"raw/sources/meeting_doc_201701/blocks.jsonl","page_number":1,"block_id":"p001_c0010","text_sha256":"sha256:81fad2b0e00864cce1e41e6cecb1aaa303ff568e1e286186bb88db5d6a61ea86","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_9918922bd3f6bb37","run_id":"2026-06-21T22-09-34-434Z_3137823-b201d0ef_ingest_meeting-doc-201701","submitted_at":"2026-06-21T22:19:01.772Z","tool_args_sha256":"sha256:9918922bd3f6bb376c98bccd533ef44d1e24419e2a07f3f201e0918268ad0723","schema_version":2,"tool_args":{"source_id":"meeting_doc_201701","observation_kind":"claim","local_observation_id":"claim_prompt_payment_interest_rate","payload":{"claim_text":"When payment of a proper invoice is delayed beyond the allotted time, the agency must pay interest at the rate set forth by the New York State Commission of Taxation and Finance which is currently at 11%, if such interest payment exceeds a ten dollars threshold.","subject":"Prompt Payment Legislation","change_type":"requirement","description":"Interest rate of 11% for late payments, with $10 threshold","change_type_normalized":{"raw_text":"requirement","normalized_value":"requirement"}},"evidence_refs":[{"source_id":"meeting_doc_201701","evidence_id":"meeting_doc_201701#p001_c0010","source_path":"raw/sources/meeting_doc_201701/blocks.jsonl","page_number":1,"block_id":"p001_c0010","text_sha256":"sha256:81fad2b0e00864cce1e41e6cecb1aaa303ff568e1e286186bb88db5d6a61ea86","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
