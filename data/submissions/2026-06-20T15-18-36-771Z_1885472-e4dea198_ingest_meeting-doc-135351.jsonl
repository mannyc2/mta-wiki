{"submission_id":"sub_d1b1888e43609c38","run_id":"2026-06-20T15-18-36-771Z_1885472-e4dea198_ingest_meeting-doc-135351","submitted_at":"2026-06-20T15:57:11.682Z","tool_args_sha256":"sha256:d1b1888e43609c388a2e185b3c977b1e6a9a6f3cd9de4b23b8d0c209a3847638","schema_version":2,"tool_args":{"source_id":"meeting_doc_135351","observation_kind":"claim","local_observation_id":"claim_meeting_doc_135351_pal_section_2879","label":"PAL Section 2879 Filing Requirement","raw_text":"The report conforms to the format/content requirements of both PAL Section 2879 as well as the Public Authorities Reporting Information System (PARIS) overseen by the New York State Independent Authorities Budget Office. The Board-approved All-Agency Procurement Guidelines will be attached to the report prior to filing, as required by PAL Section 2879.","payload":{"claim_text":"The annual MTA All-Agency Procurement report for the period January 1, 2023 - December 31, 2023 is required under Section 2879 of the Public Authorities Law, and the report conforms to format/content requirements of PAL Section 2879 and the PARIS system overseen by the New York State Independent Authorities Budget Office. The Board-approved All-Agency Procurement Guidelines will be attached prior to filing.","subject":"MTA All-Agency Procurement Report","data_type":"regulatory_requirement","data_type_normalized":{"raw_text":"regulatory_requirement","normalized_value":"regulatory_requirement"}},"evidence_refs":[{"source_id":"meeting_doc_135351","evidence_id":"meeting_doc_135351#p001_c0008","source_path":"raw/sources/meeting_doc_135351/blocks.jsonl","page_number":1,"block_id":"p001_c0008","text_sha256":"sha256:3d3e5903fcb1f3c93024d7f3c4a478358f62f511c0e72f3e64860e7a89115474","text_source":"raw_text","role":"purpose"},{"source_id":"meeting_doc_135351","evidence_id":"meeting_doc_135351#p001_c0010","source_path":"raw/sources/meeting_doc_135351/blocks.jsonl","page_number":1,"block_id":"p001_c0010","text_sha256":"sha256:2054f7592d611ef60