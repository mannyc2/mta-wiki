{"submission_id":"sub_bdead610f2ece966","run_id":"2026-06-20T14-51-38-986Z_1885472-be68b2f1_ingest_meeting-doc-133381","submitted_at":"2026-06-20T15:56:50.951Z","tool_args_sha256":"sha256:bdead610f2ece966392a940a5b297a2480d1a530b827bfb317bc0c2f5f84edcc","schema_version":2,"tool_args":{"source_id":"meeting_doc_133381","observation_kind":"claim","local_observation_id":"claim_meeting_doc_133381_minimum_payments","label":"Minimum Mass Transportation Operating Assistance Payments","payload":{"claim_text":"Under the statute, Dutchess and Orange Counties are each to receive no less than $1.5 million annually, and Rockland County is to receive no less than $2.0 million annually."},"evidence_refs":[{"source_id":"meeting_doc_133381","evidence_id":"meeting_doc_133381#p001_c0008","source_path":"raw/sources/meeting_doc_133381/blocks.jsonl","page_number":1,"block_id":"p001_c0008","text_sha256":"sha256:d70cc840e6c8ed653acc8c2e2678301488a56dc6290421d17b631f4f2dde3eec","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_49b7ce27f14c4683","run_id":"2026-06-20T14-51-38-986Z_1885472-be68b2f1_ingest_meeting-doc-133381","submitted_at":"2026-06-20T15:57:15.752Z","tool_args_sha256":"sha256:49b7ce27f14c4683a4c54da610d3f966cb1e361d7c90e99268953dcaa86959f5","schema_version":2,"tool_args":{"source_id":"meeting_doc_133381","observation_kind":"claim","local_observation_id":"claim_meeting_doc_133381_escalator_formula","label":"MRT Escalator Payment Formula","payload":{"claim_text":"The escalator payment is based on the percentage by which total MRT-1 and MRT-2 receipts attributable to such county exceeds the receipts received in 1989. Escalator Rate = (FY2023 MRT Receipts - FY1989 Base Year MRT Receipts) / FY1989 Base Year MRT Receipts. Escalator Payment = Escalator Rate × Minimum Mass Transit Operating Assistance Payment."},"evidence_refs":[{"source_id":"meeting_doc_133381","evidence_id":"meeting_doc_133381#p001_c0009","source_path":"raw/sources/meeting_doc_133381/blocks.jsonl","page_number":1,"block_id":"p001_c0009","text_sha256":"sha256:0895f3d8cde87edf8726744bb7279c6e21cf5cf76286b5c1a0fb9cbaa69bfd46","text_source":"raw_text"},{"source_id":"meeting_doc_133381","evidence_id":"meeting_doc_133381#p001_c0010","source_path":"raw/sources/meeting_doc_133381/blocks.jsonl","page_number":1,"block_id":"p001_c0010","text_sha256":"sha256:a54876e04b11b04fb0a10168c76fc31701e1e34f558ef1b604ffa357dc80aa99","text_source":"raw_text"},{"source_id":"meeting_doc_133381","evidence_id":"meeting_doc_133381#p001_c0011","source_path":"raw/sources/meeting_doc_133381/blocks.jsonl","page_number":1,"block_id":"p001_c0011","text_sha256":"sha256:d6e24c6d7602acafd8f2d4661bdd1d46b1ff9feaf56ca99d48fd0260db979b69","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
