{"submission_id":"sub_62a6c9043c411fc3","run_id":"2026-06-21T20-41-37-897Z_3137823-188d71bf_ingest_meeting-doc-193956","submitted_at":"2026-06-21T20:46:58.991Z","tool_args_sha256":"sha256:62a6c9043c411fc3b1f1320525c46187604c046e4ce0b13ae3d5f860ff64004b","schema_version":2,"tool_args":{"source_id":"meeting_doc_193956","observation_kind":"claim","local_observation_id":"claim_bt_financial_report","label":"Financial Report - Recurring Agenda Item","payload":{"claim_text":"Summary presentation of the financial indicators for the month, which includes the Balance Sheet for the reported month, Accrual Statement of Operations for the month and year-to-date, variance analysis, traffic volume and ridership information, toll collection rates, and headcount charts. The Financial Report is provided on a one-month lag, except in the month of September, at which time it includes the July and August reports.","subject":"Bridges and Tunnels Committee","data_type":"agenda_item","data_type_normalized":{"raw_text":"agenda_item","normalized_value":"agenda_item"}},"evidence_refs":[{"source_id":"meeting_doc_193956","evidence_id":"meeting_doc_193956#p003_c0006","source_path":"raw/sources/meeting_doc_193956/blocks.jsonl","page_number":3,"block_id":"p003_c0006","text_sha256":"sha256:fd9ff897ca7064583f45fd8333ddcf60433417b3d1b75773fea4f5827115ba9f","text_source":"raw_text"},{"source_id":"meeting_doc_193956","evidence_id":"meeting_doc_193956#p003_c0007","source_path":"raw/sources/meeting_doc_193956/blocks.jsonl","page_number":3,"block_id":"p003_c0007","text_sha256":"sha256:8bb4369c9247871bf4a886727d2f5d825590655d21f37cfa0b4a4572cd62191c","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
