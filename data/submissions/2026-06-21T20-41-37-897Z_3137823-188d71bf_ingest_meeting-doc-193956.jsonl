{"submission_id":"sub_a9306972126dc336","run_id":"2026-06-21T20-41-37-897Z_3137823-188d71bf_ingest_meeting-doc-193956","submitted_at":"2026-06-21T20:46:25.056Z","tool_args_sha256":"sha256:a9306972126dc33601cf541536a79788b7fb00bffe871f40a75bb36c2a2c86c8","schema_version":2,"tool_args":{"source_id":"meeting_doc_193956","observation_kind":"claim","local_observation_id":"claim_2026_bt_agenda_schedule","label":"2026 B&T Committee Agenda Schedule","raw_text":"January 2026 Responsibility 2025 Accomplishments President February 2026 2026 Adopted Budget/Financial Plan 2026-2029 MTA Finance 2025 B&T Operating Surplus MTA Finance Operating Performance Facility Mgt March 2026 Enforcement Security & Operations April 2026 Operating Performance Facility Mgt May 2026 Final Review of 2025 Year-End Operating Budget Results MTA Finance June 2026 Revenue Collection Tolling Mgt Operating Performance Facility Mgt July 2026 Security & Enforcement Security & Operations Customer & Employee Safety Env, Health & Safety August 2026 No meeting scheduled September 2026 2027 Preliminary Budget MTA Finance 2026 Mid-Year Forecast MTA Finance Operating Performance Facility Mgt October 2026 Revenue Collection Tolling Mgt November 2026 2027 Proposed Committee Work Plan Committee Chair & Members December 2026 2027 Approve Committee Work Plan Committee Chair & Members 2027 Proposed Final Budget MTA Finance","payload":{"claim_text":"The 2026 Bridges and Tunnels Committee Work Plan includes monthly meetings with agenda items assigned by month and responsible entity. January: 2025 Accomplishments (President). February: 2026 Adopted Budget/Financial Plan 2026-2029 (MTA Finance), 2025 B&T Operating Surplus (MTA Finance), Operating Performance (Facility Mgt). March: Enforcement (Security & Operations). April: Operating Performance (Facility Mgt). May: Final Review of 2025 Year-End Operating Budget Results (MTA Finance). June: Revenue Collection (Tolling Mgt), Operating Performance (Facility Mgt). July: Security & Enforcement (Security & Operations), Customer & Employee Safety (Env, Health & Safety). August: No meeting scheduled. September: 2027 Preliminary Budget (MTA Finance), 2026 Mid-Year Forecast (MTA Finance), Operating Performance (Facility Mgt). October: Revenue Collection (Tolling Mgt). November: 2027 Proposed Committee Work Plan (Committee Chair & Members). December: 2027 Approve Committee Work Plan (Committee Chair & Members), 2027 Proposed Final Budget (MTA Finance).","subject":"2026 Bridges and Tunnels Committee Work Plan","data_type":"schedule","data_type_normalized":{"raw_text":"schedule","normalized_value":"schedule"}},"evidence_refs":[{"source_id":"meeting_doc_193956","evidence_id":"meeting_doc_193956#p002_c0002","source_path":"raw/sources/meeting_doc_193956/blocks.jsonl","page_number":2,"block_id":"p002_c0002","text_sha256":"sha256:495edded4180356657b0408fa98e7012ca565cba5281b18e7bb23370894ccb81","text_source":"raw_text"},{"source_id":"meeting_doc_193956","evidence_id":"meeting_doc_193956#p002_c0003","source_path":"raw/sources/meeting_doc_193956/blocks.jsonl","page_number":2,"block_id":"p002_c0003","text_sha256":"sha256:4e7edc25f796f5216ae565cbe41d5e7a3eeb63f2fba860bca3089a6a9202d580","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
