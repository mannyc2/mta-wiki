{"submission_id":"sub_8dc3cd2e4a12f818","run_id":"2026-06-20T15-56-19-101Z_1885472-8825b170_ingest_meeting-doc-138301","submitted_at":"2026-06-20T16:24:51.803Z","tool_args_sha256":"sha256:8dc3cd2e4a12f81803ddad567da0389369caab25a19d3795a569057e2e96c4e5","schema_version":2,"tool_args":{"source_id":"meeting_doc_138301","observation_kind":"project","local_observation_id":"project_meeting_doc_138301_fuel_hedge","target_record_id":"project_fuel-hedge-program-2022","label":"Fuel Hedging Program","payload":{"project_name":"Fuel Hedging Program","description":"MTA's fuel hedging program mitigates budget risk by dollar cost averaging approximately 50% of projected fuel expenses. The goal of the program is to be 50% hedged for the next 12 months. Monthly hedges are equal to approximately 4% of the projected fuel purchases expected to occur 13-24 months from each hedge execution date."},"evidence_refs":[{"source_id":"meeting_doc_138301","evidence_id":"meeting_doc_138301#p002_c0001","source_path":"raw/sources/meeting_doc_138301/blocks.jsonl","page_number":2,"block_id":"p002_c0001","text_sha256":"sha256:4e6f009fe307e14ff5f3bb2788c59abdbb3327acc4f6151dd5310ac99481ceff","text_source":"raw_text"},{"source_id":"meeting_doc_138301","evidence_id":"meeting_doc_138301#p002_c0003","source_path":"raw/sources/meeting_doc_138301/blocks.jsonl","page_number":2,"block_id":"p002_c0003","text_sha256":"sha256:dae2429183366dceac6f1376b01fb13fe010a01878ab8636052fa6ba68b65a59","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_a1e37b401d928d29","run_id":"2026-06-20T15-56-19-101Z_1885472-8825b170_ingest_meeting-doc-138301","submitted_at":"2026-06-20T16:26:23.178Z","tool_args_sha256":"sha256:a1e37b401d928d292ebab25f689fd75c3396d9f0c5df52c822dd5865dd488d6c","schema_version":2,"tool_args":{"source_id":"meeting_doc_138301","observation_kind":"claim","local_observation_id":"claim_meeting_doc_138301_fuel_hedge_desc","label":"Fuel Hedging Program Description","payload":{"claim_text":"MTA's fuel hedging program mitigates budget risk by dollar cost averaging approximately 50% of projected fuel expenses. The goal of the program is to be 50% hedged for the next 12 months. Monthly hedges are equal to approximately 4% of the projected fuel purchases expected to occur 13-24 months from each hedge execution date. The actual percentage hedged could be higher or lower than the 50% target depending on the actual levels of fuel consumption. While the fuel hedging program includes compressed natural gas, there are currently no active hedges."},"evidence_refs":[{"source_id":"meeting_doc_138301","evidence_id":"meeting_doc_138301#p002_c0003","source_path":"raw/sources/meeting_doc_138301/blocks.jsonl","page_number":2,"block_id":"p002_c0003","text_sha256":"sha256:dae2429183366dceac6f1376b01fb13fe010a01878ab8636052fa6ba68b65a59","text_source":"raw_text"}]},"validation":{"state":"accepted","issues":[]}}
