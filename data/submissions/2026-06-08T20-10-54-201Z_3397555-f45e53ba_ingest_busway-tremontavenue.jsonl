{"submission_id":"sub_40a389bd40baffa4","run_id":"2026-06-08T20-10-54-201Z_3397555-f45e53ba_ingest_busway-tremontavenue","submitted_at":"2026-06-08T20:12:10.147Z","tool_args_sha256":"sha256:40a389bd40baffa4332f8e3b0b74f06b5fd89de847499d93ccdc3a284db63b62","tool_args":{"source_id":"busway_tremontavenue","observation_kind":"treatment_component","local_observation_id":"treatment_overnight_rules","label":"Overnight busway rules","raw_text":"Overnight from 8pm to 6am: Busway regulations are not in effect. All vehicles may drive all the way through Tremont Avenue and may make left and right turns unless otherwise posted.","payload":{"treatment_kind":"time_of_day_restriction","component_type":"overnight_exemption","description":"8pm to 6am busway regulations not in effect. All vehicles may drive through and make all turns unless otherwise posted."},"evidence_refs":[{"source_id":"busway_tremontavenue","evidence_id":"busway_tremontavenue#p001_b0001","source_path":"raw/sources/busway_tremontavenue/blocks.jsonl","page_number":1,"block_id":"p001_b0001","text_sha256":"sha256:0ef429d84ee86eaa8aa6e96c04598e1413b81e55f9fc609972a861bfdfc4a031","text_source":"raw_text","role":"states overnight rules"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_7c00044b3f4cd2e8","run_id":"2026-06-08T20-10-54-201Z_3397555-f45e53ba_ingest_busway-tremontavenue","submitted_at":"2026-06-08T20:12:55.491Z","tool_args_sha256":"sha256:7c00044b3f4cd2e8e0e7ba020c3f601e61f8bbda8ba166b9c8bd39abd187e853","tool_args":{"source_id":"busway_tremontavenue","observation_kind":"table","local_observation_id":"table_eastbound_exit_rules","label":"Eastbound entry and exit turn rules","raw_text":"Driving Eastbound: If you enter Tremont Avenue from Third and Lafontaine Avenue, you must turn right to exit on Arthur Avenue. If you enter from Belmont and Hughes Avenues, exit on Crotona Avenue. If you enter from Crotona Avenue, exit on Clinton Avenue. If you enter from Clinton, Prospect, and Mapes Avenues, exit on Marmion Avenue. If you enter from Marmion Avenue, exit on Southern Boulevard.","payload":{"table_title":"Eastbound entry/exit turns on Tremont Avenue Busway","columns":["entry_point","exit_turn"],"rows":[["Third and Lafontaine Avenue","right turn onto Arthur Avenue"],["Belmont and Hughes Avenues","right turn onto Crotona Avenue"],["Crotona Avenue","right turn onto Clinton Avenue"],["Clinton, Prospect, and Mapes Avenues","right turn onto Marmion Avenue"],["Marmion Avenue","right turn onto Southern Boulevard"]]},"evidence_refs":[{"source_id":"busway_tremontavenue","evidence_id":"busway_tremontavenue#p001_b0001","source_path":"raw/sources/busway_tremontavenue/blocks.jsonl","page_number":1,"block_id":"p001_b0001","text_sha256":"sha256:0ef429d84ee86eaa8aa6e96c04598e1413b81e55f9fc609972a861bfdfc4a031","text_source":"raw_text","role":"eastbound driving instructions"}]},"validation":{"state":"accepted","issues":[]}}
{"submission_id":"sub_c574f7ba1e8011bb","run_id":"2026-06-08T20-10-54-201Z_3397555-f45e53ba_ingest_busway-tremontavenue","submitted_at":"2026-06-08T20:12:55.503Z","tool_args_sha256":"sha256:c574f7ba1e8011bb74f692c71205ef36a36204ea66d8527bf0d8fe703b336f03","tool_args":{"source_id":"busway_tremontavenue","observation_kind":"table","local_observation_id":"table_westbound_exit_rules","label":"Westbound entry and exit turn rules","raw_text":"Driving Westbound: If you enter Tremont Avenue from Southern Boulevard and Marmion Avenues, you must turn right to exit on Mapes Avenue. If you enter from Mapes Avenue, exit on Prospect Avenue. If you enter from Prospect and Clinton Avenues, exit on Crotona Avenue. If you enter from Crotona Avenue, exit on Belmont Avenue.","payload":{"table_title":"Westbound entry/exit turns on Tremont Avenue Busway","columns":["entry_point","exit_turn"],"rows":[["Southern Boulevard and Marmion Avenues","right turn onto Mapes Avenue"],["Mapes Avenue","right turn onto Prospect Avenue"],["Prospect and Clinton Avenues","right turn onto Crotona Avenue"],["Crotona Avenue","right turn onto Belmont Avenue"]]},"evidence_refs":[{"source_id":"busway_tremontavenue","evidence_id":"busway_tremontavenue#p001_b0001","source_path":"raw/sources/busway_tremontavenue/blocks.jsonl","page_number":1,"block_id":"p001_b0001","text_sha256":"sha256:0ef429d84ee86eaa8aa6e96c04598e1413b81e55f9fc609972a861bfdfc4a031","text_source":"raw_text","role":"westbound driving instructions"}]},"validation":{"state":"accepted","issues":[]}}
