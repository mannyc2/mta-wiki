{"baseline_version":1,"record_count":56,"records":[{"display_name":"YTD Sep 2024 Operating Subsidies Summary","evidence_refs":[{"block_id":"p003_c0007","page_number":3,"source_id":"meeting_doc_155161","text_sha256":"sha256:960f743be85bdde49e2eeb2d74105b8c0254fda130ed127b5c62b78d66decc87"}],"payload":{"claim_text":"Operating Subsidies, which also reflects Investment Income, was favorable for YTD September by $55 million (0.8%). Excluding Investment Income, subsidies directed to the operating budget were favorable by $36 million (0.6%). Driven by favorable results for Urban Tax, Payroll Mobility Tax (PMT), and Mortgage Recording Tax partially offset by unfavorable results for Automated Camera Enforcement (ACE), CDOT, and the For-Hire Vehicle (FHV) Surcharge."},"record_kind":"claim","review_state":"unreviewed","truth_status":"source_stated","v1_record_id":"claim_ytd-sep2024-operating-subsidies-summary"},{"display_name":"MTA-Wide Vacancy Composition September 2024","evidence_refs":[{"block_id":"p016_c0005","page_number":16,"source_id":"meeting_doc_155161","text_sha256":"sha256:5fde4723e3911797b76165571cbaec9f94ae7a296a1fe8792886c3f6953cf596"}],"payload":{"claim_text":"On an MTA-Wide basis, there were 2,844 vacancies in September, representing a vacancy rate of (4%), which was primarily comprised of vacancies in operations and maintenance (82% of total vacancies)."},"record_kind":"claim","review_state":"unreviewed","truth_status":"source_stated","v1_record_id":"claim_mta-wide-vacancy-sep2024"},{"display_name":"Passenger Revenue Variance Drivers","evidence_refs":[{"block_id":"p004_c0005","page_number":4,"source_id":"meeting_doc_155161","text_sha256":"sha256:712f505fb6b71994ec753b51d3d1e5d180510dd3e1b5a01fd5b22bba9f98b4c0"}],"payload":{"claim_text":"The unfavorable variances primarily reflected unfavorable paid ridership for NYCT (both Subway and Bus), MTA Bus (partially offset by higher average yield), and Staten Island Railway. The LIRR and MNR were both favorable due to higher than budgeted ridership."},"record_kind":"claim","review_state":"unreviewed","truth_status":"source_stated","v1_record_id":"claim_passenger-revenue-variance-drivers"},{"display_name":"YTD Sep 2024 Expense Favorable Variance Detail","evidence_refs":[{"block_id":"p003_c0008","page_number":3,"source_id":"meeting_doc_155161","text_sha256":"sha256:48bdcba51298b1f9a479a8b83884d55f67b8f0bd4997c4a5f13941f5e38c9d00"}],"payload":{"claim_text":"Labor expenses were $66 million (1%) favorable, non-labor expenses were $151 million (5%) favorable, and other expense adjustments were $31 million favorable. Within labor expenses, payroll was $139 million (3%) favorable mainly due to vacancies at NYCT, health and welfare $39 million (3%), and OPEB current payments of $31 million (5%), partially offset by unfavorable overtime spending of $194 million (31%). Within non-labor expenses, professional service contracts were $126 million (22%) favorable."},"record_kind":"claim","review_state":"unreviewed","truth_status":"source_stated","v1_record_id":"claim_ytd-sep2024-expense-variance-detail"},{"display_name":"YTD Sep 2024 Operating Revenue Drivers","evidence_refs":[{"block_id":"p003_c0006","page_number":3,"source_id":"meeting_doc_155161","text_sha256":"sha256:6a832d5a49cb2189c832381bc1915906273046e847ba16e9b932026d0f46a2c2"}],"payload":{"claim_text":"Operating revenue for YTD September was $79 million (1%) unfavorable, comprised of unfavorable passenger revenues of $86 million (2%) and unfavorable toll revenue of $6 million (less than 1%), partially offset by favorable other operating revenues of $14 million (2%)."},"record_kind":"claim","review_state":"unreviewed","truth_status":"source_stated","v1_record_id":"claim_ytd-sep2024-operating-revenue-drivers"},{"display_name":"MTA Finance Committee","evidence_refs":[{"block_id":"p001_c0002","page_number":1,"source_id":"meeting_doc_155161","text_sha256":"sha256:c8c971562dffe2071e7a338c9067cc78daac2572b9ad7f25d717f87a54ce0565"},{"block_i