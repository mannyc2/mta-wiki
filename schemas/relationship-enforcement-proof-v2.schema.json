{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mta-wiki.local/schemas/relationship-enforcement-proof-v2.schema.json",
  "title": "MTA Wiki staged relationship enforcement proof v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proof_id",
    "contract_id",
    "proof_status",
    "proof_stage",
    "validation_mode",
    "reviewed_at",
    "reviewed_by",
    "final_matrix",
    "gate_count",
    "all_gates_ready",
    "total_violation_count",
    "gates"
  ],
  "oneOf": [
    {
      "properties": {
        "proof_stage": { "const": "pre_promotion_warning" },
        "validation_mode": { "const": "warn" }
      },
      "not": {
        "anyOf": [
          { "required": ["previous_proof"] },
          { "required": ["transition_receipt"] }
        ]
      }
    },
    {
      "required": ["previous_proof", "transition_receipt"],
      "properties": {
        "proof_stage": { "const": "post_promotion_enforced" },
        "validation_mode": { "const": "enforce" }
      }
    }
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "proof_id": { "const": "relationship-contract-v1-enforcement-proof" },
    "contract_id": { "const": "relationship-contract-v1" },
    "proof_status": { "const": "ready" },
    "proof_stage": {
      "enum": ["pre_promotion_warning", "post_promotion_enforced"]
    },
    "validation_mode": { "enum": ["warn", "enforce"] },
    "reviewed_at": { "type": "string", "minLength": 1 },
    "reviewed_by": { "type": "string", "minLength": 1 },
    "previous_proof": { "$ref": "#/$defs/proofRef" },
    "transition_receipt": { "$ref": "#/$defs/artifactRef" },
    "final_matrix": {
      "allOf": [
        { "$ref": "#/$defs/artifactRef" },
        {
          "type": "object",
          "required": ["relation_count", "tuple_count", "relation_ids_sha256", "tuple_set_sha256"],
          "properties": {
            "relation_count": { "type": "integer", "minimum": 1 },
            "tuple_count": { "type": "integer", "minimum": 1 },
            "relation_ids_sha256": { "$ref": "#/$defs/sha256" },
            "tuple_set_sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      ]
    },
    "gate_count": { "const": 7 },
    "all_gates_ready": { "const": true },
    "total_violation_count": { "const": 0 },
    "gates": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_id", "status", "violation_count", "artifact_path", "artifact_sha256", "criteria"],
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "status": { "const": "ready" },
          "violation_count": { "const": 0 },
          "artifact_path": { "type": "string", "minLength": 1 },
          "artifact_sha256": { "$ref": "#/$defs/sha256" },
          "criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "artifactRef": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "proofRef": {
      "allOf": [
        { "$ref": "#/$defs/artifactRef" },
        {
          "type": "object",
          "required": ["proof_stage"],
          "properties": {
            "proof_stage": { "const": "pre_promotion_warning" }
          }
        }
      ]
    }
  }
}
